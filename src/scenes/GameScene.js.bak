    /* ===== UI ===== */

    _createUI() {
        this._createTopBar();
        this._buildStatsPanel();
    }

    _createTopBar() {
        this.topBarBg = this.add.rectangle(400, 12, 780, 22, 0x000000, 0.5)
            .setScrollFactor(0).setDepth(20);
        this.topBarBg.setStrokeStyle(1, 0x333333);

        this.hpBarOuter = this.add.rectangle(200, 12, 200, 14, 0x1a1a2e)
            .setOrigin(0, 0.5).setScrollFactor(0).setDepth(21);
        this.hpBarOuter.setStrokeStyle(1, 0x444444);
        this.hpBarFill = this.add.rectangle(201, 12, 198, 12, 0xe74c3c)
            .setOrigin(0, 0.5).setScrollFactor(0).setDepth(22);

        this.shieldBarFill = this.add.rectangle(201, 12, 0, 12, 0x3498db, 0.4)
            .setOrigin(0, 0.5).setScrollFactor(0).setDepth(22.5);

        this.levelText = this.add.text(10, 12, '', {
            fontSize: '12px', fill: '#e67e22', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 2
        }).setOrigin(0, 0.5).setScrollFactor(0).setDepth(23);

        this.diffText = this.add.text(790, 12, this.difficulty, {
            fontSize: '10px', fill: '#f39c12', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 1
        }).setOrigin(1, 0.5).setScrollFactor(0).setDepth(23);

        this.hintText = this.add.text(400, 588, '', {
            fontSize: '10px', fill: '#555', fontFamily: 'Arial'
        }).setOrigin(0.5).setScrollFactor(0).setDepth(20);

        this.muteText = this.add.text(790, 30, 'SOUND', {
            fontSize: '10px', fill: '#27ae60', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 1
        }).setOrigin(1, 0.5).setScrollFactor(0).setDepth(23).setInteractive({ useHandCursor: true });
        this.muteText.on('pointerdown', () => this._toggleMute());

        this.corruptionLabel = this.add.text(10, 36, 'COR', {
            fontSize: '9px', fill: '#9b59b6', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 1
        }).setScrollFactor(0).setDepth(23);

        this.corruptionBarOuter = this.add.rectangle(200, 36, 200, 6, 0x1a1a2e)
            .setOrigin(0, 0.5).setScrollFactor(0).setDepth(21);
        this.corruptionBarOuter.setStrokeStyle(1, 0x333333);
        this.corruptionBarFill = this.add.rectangle(201, 36, 0, 4, 0x9b59b6)
            .setOrigin(0, 0.5).setScrollFactor(0).setDepth(22);

        this.talentText = this.add.text(400, 36, '', {
            fontSize: '9px', fill: '#f1c40f', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 1
        }).setScrollFactor(0).setDepth(23);

        this.accountLevelText = this.add.text(10, 48, '', {
            fontSize: '9px', fill: '#e67e22', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 1
        }).setScrollFactor(0).setDepth(23);

        this.accountExpBarOuter = this.add.rectangle(200, 48, 200, 4, 0x1a1a2e)
            .setOrigin(0, 0.5).setScrollFactor(0).setDepth(21);
        this.accountExpBarOuter.setStrokeStyle(1, 0x333333);
        this.accountExpBarFill = this.add.rectangle(201, 48, 0, 2, 0xe67e22)
            .setOrigin(0, 0.5).setScrollFactor(0).setDepth(22);

        this.spellSlots = {};
        const spellKeys = ['fireball', 'shield', 'heal'];
        const spellLabels = ['Q', 'W', 'E'];
        const spellColors = [0xe74c3c, 0x3498db, 0x2ecc71];
        spellKeys.forEach((key, i) => {
            const sx = 690 + i * 36;
            const sy = 565;
            const bg = this.add.rectangle(sx, sy, 30, 30, 0x1a1a2e)
                .setStrokeStyle(2, spellColors[i])
                .setScrollFactor(0).setDepth(24);
            const lbl = this.add.text(sx, sy - 2, spellLabels[i], {
                fontSize: '10px', fill: '#fff', fontFamily: 'Arial', fontStyle: 'bold'
            }).setOrigin(0.5).setScrollFactor(0).setDepth(25);
            const cd = this.add.text(sx, sy + 10, '', {
                fontSize: '8px', fill: '#f39c12', fontFamily: 'Arial'
            }).setOrigin(0.5).setScrollFactor(0).setDepth(25);
            this.spellSlots[key] = { bg, lbl, cd };
        });
    }

    _buildStatsPanel() {
        if (this.statsGroup) this.statsGroup.forEach(e => e.destroy());
        this.statsGroup = [];

        const s = (el) => { el.setScrollFactor(0).setDepth(100); return el; };

        // Collapsed bar (always visible)
        this.statsBarBg = s(this.add.rectangle(110, 60, 200, 22, 0x0a0a1a, 0.8)
            .setStrokeStyle(1, 0x444444));
        this.statsBarText = s(this.add.text(15, 60, '', {
            fontSize: '10px', fill: '#ecf0f1', fontFamily: 'Arial', fontStyle: 'bold'
        }).setOrigin(0, 0.5));
        this.statsBarBtn = s(this.add.text(210, 60, '[ + ]', {
            fontSize: '10px', fill: '#f1c40f', fontFamily: 'Arial'
        }).setOrigin(1, 0.5).setInteractive({ useHandCursor: true }));
        this.statsBarBtn.on('pointerdown', () => this._toggleStats());

        // Expanded panel (hidden by default)
        const px = 10, py = 78, pw = 210, ph = 152;
        this.statsPanelBg = s(this.add.rectangle(px + pw / 2, py + ph / 2, pw, ph, 0x0a0a1a, 0.9)
            .setStrokeStyle(1, 0x444444));
        this.statsPanelBg.setVisible(false);

        this.statsCloseBtn = s(this.add.text(px + pw - 10, py + 4, '[ - ]', {
            fontSize: '10px', fill: '#f1c40f', fontFamily: 'Arial'
        }).setOrigin(1, 0).setInteractive({ useHandCursor: true }));
        this.statsCloseBtn.on('pointerdown', () => this._toggleStats());
        this.statsCloseBtn.setVisible(false);

        this.statsTitle = s(this.add.text(px + 10, py + 6, 'STATS', {
            fontSize: '12px', fill: '#f1c40f', fontFamily: 'Arial', fontStyle: 'bold'
        }));
        this.statsTitle.setVisible(false);

        const labels = ['Acc Lv:', 'HP:', 'Damage:', 'Acc EXP:'];
        const colors = ['#f1c40f', '#27ae60', '#e74c3c', '#f1c40f'];
        this.statsLabels = [];
        this.statsValues = [];

        labels.forEach((label, i) => {
            const y = py + 26 + i * 22;
            const lt = s(this.add.text(px + 12, y, label, {
                fontSize: '11px', fill: '#95a5a6', fontFamily: 'Arial'
            }));
            lt.setVisible(false);
            this.statsLabels.push(lt);

            const vt = s(this.add.text(px + pw - 16, y, '', {
                fontSize: '11px', fill: colors[i], fontFamily: 'Arial', fontStyle: 'bold'
            }).setOrigin(1, 0));
            vt.setVisible(false);
            this.statsValues.push(vt);
        });

        this._statsExpanded = false;
    }

    _toggleStats() {
        this._statsExpanded = !this._statsExpanded;
        this.statsPanelBg.setVisible(this._statsExpanded);
        this.statsCloseBtn.setVisible(this._statsExpanded);
        this.statsTitle.setVisible(this._statsExpanded);
        this.statsLabels.forEach(e => e.setVisible(this._statsExpanded));
        this.statsValues.forEach(e => e.setVisible(this._statsExpanded));
        this.statsBarBtn.setText(this._statsExpanded ? '[ - ]' : '[ + ]');
    }

    _toggleMute() {
        const m = toggleMute();
        this.muteText.setText(m ? 'MUTE' : 'SOUND');
        this.muteText.setColor(m ? '#e74c3c' : '#27ae60');
    }

    _openTalentTree() {
        if (this.menuOpen || this.transitioning) return;
        this.menuOpen = true;
        this.physics.pause();
        if (this.enemies) this.enemies.getChildren().forEach(e => { if (e.body) e.body.setVelocity(0); });
        if (this.stumps) this.stumps.getChildren().forEach(s => { if (s.body) s.body.setVelocity(0); });

        this.scene.launch('TalentTree', {
            unlockedTalents: this.unlockedTalents,
            talentPoints: this.talentPoints,
            classKey: this.classKey,
            unlockedAccountTalents: this.unlockedAccountTalents,
            accountTalentPoints: this.accountTalentPoints,
            accountLevel: this.accountLevel,
            returnScene: 'Game'
        });
        this.scene.pause();
    }

    _openBestiary() {
        if (this.menuOpen || this.transitioning) return;
        this.menuOpen = true;
        this.physics.pause();
        if (this.enemies) this.enemies.getChildren().forEach(e => { if (e.body) e.body.setVelocity(0); });
        if (this.stumps) this.stumps.getChildren().forEach(s => { if (s.body) s.body.setVelocity(0); });

        const bookScene = this.classKey === 'alchemist' ? 'MaterialBook' :
                          this.classKey === 'angel' ? 'SoulBook' : 'Bestiary';

        this.scene.launch(bookScene, {
            classKey: this.classKey,
            difficulty: this.difficulty,
            returnScene: 'Game'
        });
        this.scene.pause();
    }

    receiveBestiaryData() {
        this.menuOpen = false;
        this.physics.resume();
        this.scene.resume();
        this.recalcStats();
    }

    _openCrafting() {
        if (this.menuOpen || this.transitioning) return;
        this.menuOpen = true;
        this.physics.pause();
        if (this.enemies) this.enemies.getChildren().forEach(e => { if (e.body) e.body.setVelocity(0); });
        if (this.stumps) this.stumps.getChildren().forEach(s => { if (s.body) s.body.setVelocity(0); });

        const isAlchemist = this.classKey === 'alchemist';
        initMaterialBook();
        const matData = getMaterialBookData();

        this.scene.launch('Craft', {
            materials: this.materials,
            equipBag: this.equipBag,
            maxEquipBag: this.maxEquipBag,
            isAlchemist: isAlchemist,
            returnScene: 'Game',
            classKey: this.classKey,
            difficulty: this.difficulty,
            materialBookData: matData,
            hasRelicCraftBonus: !!(this.relicEffects && this.relicEffects.craft_bonus),
            onCraftResult: (result) => {
                if (result.items) {
                    result.items.forEach(item => {
                        if (this.addEquip(item)) {
                            this.floatingText(this.player.x, this.player.y - 40, '+' + item.name, '#2ecc71');
                        }
                    });
                }
                this.materials = result.materials || this.materials;
            }
        });
        this.scene.pause();
    }

    receiveCraftData(materials) {
        this.materials = materials || this.materials;
        this.menuOpen = false;
        this.physics.resume();
        this.scene.resume();
        this.recalcStats();
    }

    receiveTalentData(data) {
        this.unlockedTalents = data.unlockedTalents || [];
        this.talentPoints = data.talentPoints || 0;
        this.talentEffects = getTalentEffects(this.unlockedTalents);
        this.unlockedAccountTalents = data.unlockedAccountTalents || [];
        this.accountTalentPoints = data.accountTalentPoints || 0;
        this.accountEffects = getAccountTalentEffects(this.unlockedAccountTalents);
        this.recalcStats();
        this.menuOpen = false;
        this.physics.resume();
    }

    _updateCorruption() {
        if (this.corruption > 0) {
            const decay = this.classStats ? this.classStats.corruptionDecay : CORRUPTION.decayRate;
            this.corruption = Math.max(0, this.corruption - decay);
        }
        if (this.corruption >= this.corruptionMax) {
            const rotDmg = this.classStats ? this.classStats.corruptionDmg : CORRUPTION.rotDmg;
            this.takeDamage(rotDmg);
            this.player.setTint(0x9b59b6);
        }
    }

    /* ===== SPELLS ===== */

    _castSpell(slot) {
        const spell = SPELLS[slot];
        if (!spell) return;
        if (this.spellCooldowns[slot] > 0) return;
        if (slot !== 'purify' && this.corruption + spell.corruptionCost > this.corruptionMax) return;

        this.corruption += spell.corruptionCost;
        this.spellCooldowns[slot] = spell.cooldown;

        if (slot === 'fireball' || slot === 'acid_flask' || slot === 'soul_strike') this._castProjectile(spell);
        else if (slot === 'shield' || slot === 'iron_skin') this._castShield(spell);
        else if (slot === 'life_link') this._castLifeLink(spell);
        else if (slot === 'heal' || slot === 'healing_potion') this._castHeal(spell);
        else if (slot === 'purify') this._castPurify(spell);
    }

    _getClassSpells() {
        if (this.classKey === 'alchemist') return { q: 'acid_flask', w: 'iron_skin', e: 'healing_potion' };
        if (this.classKey === 'angel') return { q: 'soul_strike', w: 'life_link', e: 'purify' };
        return { q: 'fireball', w: 'shield', e: 'heal' };
    }

    _castProjectile(spell) {
        let vx = 0, vy = 0;
        let ox = 0, oy = 0;
        if (this.facing === 'left')  { vx = -spell.speed; ox = -20; }
        else if (this.facing === 'right') { vx = spell.speed; ox = 20; }
        else if (this.facing === 'up')    { vy = -spell.speed; oy = -20; }
        else if (this.facing === 'down')  { vy = spell.speed; oy = 20; }
        else { vx = spell.speed; ox = 20; }

        const px = this.player.x + ox;
        const py = this.player.y + oy;
        const texKey = spell.key === 'acid_flask' ? 'acid_flask' : spell.key === 'soul_strike' ? 'soul_strike' : 'fireball';
        const fb = this.add.sprite(px, py, texKey).setDepth(15);
        this.physics.add.existing(fb);
        fb.body.setVelocity(vx, vy);
        const spellSpeedMult = 1 + (this.computedSpellSpeed || 0) / 100;
        fb.body.velocity.x *= spellSpeedMult;
        fb.body.velocity.y *= spellSpeedMult;
        const spellDmgMult = 1 + (this.computedSpellDamage || 0) / 100;
        fb.damage = Math.floor((spell.damage + this.playerDamage * 0.5) * spellDmgMult);
        fb.lifespan = spell.range / spell.speed;
        fb.spellKey = spell.key;
        fb.dot = (spell.dot || 0) + (this.computedDotPower || 0);
        fb.dotDuration = (spell.dotDuration || 0) + (this.computedDotDuration || 0);
        this.fireballs.push(fb);

        const glow = this.add.circle(px, py, 12, spell.color, 0.3).setDepth(14);
        fb.glow = glow;

        this.tweens.add({
            targets: fb, scaleX: 1.3, scaleY: 1.3, duration: 100,
            yoyo: true, repeat: -1
        });
    }

    _castShield(spell) {
        this.shieldActive = true;
        this.shieldHP = spell.absorption + Math.floor(this.playerMaxHP * 0.1);
        this.shieldTimer = spell.duration;

        this.shieldVfx = this.add.sprite(this.player.x, this.player.y, 'shield_vfx')
            .setDepth(15).setAlpha(0.8);
        this.tweens.add({
            targets: this.shieldVfx, alpha: 0.4, duration: 500, yoyo: true, repeat: -1
        });

        this.floatingText(this.player.x, this.player.y - 30, 'SHIELD!', '#3498db');
    }

    _castHeal(spell) {
        const healAmt = Math.floor(this.playerMaxHP * spell.healPercent);
        this.playerHP = Math.min(this.playerMaxHP, this.playerHP + healAmt);

        const healVfx = this.add.sprite(this.player.x, this.player.y, 'heal_vfx').setDepth(15);
        this.tweens.add({
            targets: healVfx, scaleX: 2, scaleY: 2, alpha: 0, duration: 600,
            onComplete: () => healVfx.destroy()
        });

        this.floatingText(this.player.x, this.player.y - 30, '+' + healAmt + ' HP', '#2ecc71');
        this.updateUI();
    }

    _castLifeLink(spell) {
        this.shieldActive = true;
        this.shieldHP = spell.absorption;
        this.shieldTimer = spell.duration;
        this.lifeLinkActive = true;
        this.lifeLinkTimer = spell.duration;
        this.lifeLinkHealPerSec = spell.healPerSec;

        this.shieldVfx = this.add.sprite(this.player.x, this.player.y, 'shield_vfx')
            .setDepth(15).setAlpha(0.8).setTint(0xf1c40f);
        this.tweens.add({
            targets: this.shieldVfx, alpha: 0.4, duration: 500, yoyo: true, repeat: -1
        });

        this.floatingText(this.player.x, this.player.y - 30, 'LIFE LINK!', '#f1c40f');
    }

    _castPurify(spell) {
        const reduce = spell.corruptionReduce || 0;
        this.corruption = Math.max(0, this.corruption - reduce);

        const purifyHealMult = (this.relicEffects && this.relicEffects.purify_heal) ? 1.05 : 1;
        const healAmt = Math.floor(this.playerMaxHP * spell.healPercent * purifyHealMult);
        this.playerHP = Math.min(this.playerMaxHP, this.playerHP + healAmt);

        const purifyVfx = this.add.sprite(this.player.x, this.player.y, 'heal_vfx').setDepth(15)
            .setTint(0xf1c40f);
        this.tweens.add({
            targets: purifyVfx, scaleX: 3, scaleY: 3, alpha: 0, duration: 800,
            onComplete: () => purifyVfx.destroy()
        });

        this.floatingText(this.player.x, this.player.y - 30, 'PURIFY! -' + reduce + ' COR', '#f1c40f');
        this.updateUI();
    }

    _updateSpells(delta) {
        const dt = delta / 1000;

        ['fireball', 'shield', 'heal'].forEach(k => {
            if (this.spellCooldowns[k] > 0) {
                this.spellCooldowns[k] = Math.max(0, this.spellCooldowns[k] - dt);
            }
        });

        for (let i = this.fireballs.length - 1; i >= 0; i--) {
            const fb = this.fireballs[i];
            if (fb.glow) {
                fb.glow.x = fb.x;
                fb.glow.y = fb.y;
            }
            fb.lifespan -= dt;
            if (fb.lifespan <= 0) {
                if (fb.glow) fb.glow.destroy();
                fb.destroy();
                this.fireballs.splice(i, 1);
                continue;
            }

            let hit = false;
            let spellTotalDmg = 0;
            if (this.enemies) {
                this.enemies.getChildren().forEach(e => {
                        if (e.active && Phaser.Math.Distance.Between(fb.x, fb.y, e.x, e.y) < 20) {
                        if (e === this.boss || e === this.mineBoss || e === this.caveBoss || e === this.villageBoss || e === this.hellBoss) return;
                        const totalDmg = fb.damage + (fb.dot || 0) * (fb.dotDuration || 0);
                        e.stats.hp -= totalDmg;
                        spellTotalDmg += totalDmg;
                        this.floatingText(e.x, e.y - 20, '-' + totalDmg, '#e74c3c');
                        hit = true;
                        if (e.stats.hp <= 0) {
                            if (e.stats.isBossClone) this._killBossClone(e);
                            else this.killEnemy(e);
                        }
                        // SpellChain relic: jump to nearest enemy
                        if (this.relicEffects && this.relicEffects.fireball_chain && !fb.chained) {
                            let nearest = null, nearDist = 150;
                            this.enemies.getChildren().forEach(e2 => {
                                if (e2.active && e2 !== e && e2.stats) {
                                    const d = Phaser.Math.Distance.Between(e.x, e.y, e2.x, e2.y);
                                    if (d < nearDist) { nearDist = d; nearest = e2; }
                                }
                            });
                            if (nearest) {
                                const chainDmg = Math.floor(totalDmg * 0.6);
                                nearest.stats.hp -= chainDmg;
                                this.floatingText(nearest.x, nearest.y - 20, '-' + chainDmg, '#9b59b6');
                                if (nearest.stats.hp <= 0) {
                                    if (nearest === this.hellBoss) this._victoryHellBoss();
                                    else if (nearest.stats.isBossClone) this._killBossClone(nearest);
                                    else this.killEnemy(nearest);
                                }
                                fb.chained = true;
                            }
                        }
                    }
                });
            }
            if (this.boss && this.boss.active && Phaser.Math.Distance.Between(fb.x, fb.y, this.boss.x, this.boss.y) < 30) {
                let totalDmg = fb.damage + (fb.dot || 0) * (fb.dotDuration || 0);
                if (this.computedBossDamage) totalDmg = Math.floor(totalDmg * (1 + this.computedBossDamage / 100));
                this.boss.stats.hp -= totalDmg;
                spellTotalDmg += totalDmg;
                this.floatingText(this.boss.x, this.boss.y - 20, '-' + totalDmg, '#e74c3c');
                if (this.boss.hpFill) this.boss.hpFill.width = this.boss.hpBg.width * (this.boss.stats.hp / this.boss.stats.maxHp);
                hit = true;
                if (this.boss.stats.hp <= 0) this.killBoss();
            }
            if (this.mineBoss && this.mineBoss.active && Phaser.Math.Distance.Between(fb.x, fb.y, this.mineBoss.x, this.mineBoss.y) < 30) {
                let totalDmg = fb.damage + (fb.dot || 0) * (fb.dotDuration || 0);
                if (this.computedBossDamage) totalDmg = Math.floor(totalDmg * (1 + this.computedBossDamage / 100));
                this.mineBoss.stats.hp -= totalDmg;
                spellTotalDmg += totalDmg;
                this.floatingText(this.mineBoss.x, this.mineBoss.y - 20, '-' + totalDmg, '#e74c3c');
                if (this.mineBoss.hpFill) this.mineBoss.hpFill.width = this.mineBoss.hpBg.width * (this.mineBoss.stats.hp / this.mineBoss.stats.maxHp);
                hit = true;
                if (this.mineBoss.stats.hp <= 0) this.killMineBoss();
            }
            if (hit && this.computedLifeSteal > 0 && spellTotalDmg > 0) {
                const healAmount = Math.floor(spellTotalDmg * this.computedLifeSteal / 100);
                if (healAmount > 0) {
                    this.playerHP = Math.min(this.playerMaxHP, this.playerHP + healAmount);
                    this.floatingText(this.player.x, this.player.y - 40, '+' + healAmount, '#2ecc71');
                }
            }
            if (this.mineChests) {
                this.mineChests.getChildren().forEach(ch => {
                    if (ch.active && !ch.broken && Phaser.Math.Distance.Between(fb.x, fb.y, ch.x, ch.y) < 20) {
                        this.hitChest(ch, fb.damage);
                        hit = true;
                    }
                });
            }
            if (this.caveChests) {
                this.caveChests.getChildren().forEach(ch => {
                    if (ch.active && !ch.broken && Phaser.Math.Distance.Between(fb.x, fb.y, ch.x, ch.y) < 20) {
                        this.hitChest(ch, fb.damage);
                        hit = true;
                    }
                });
            }
            if (this.caveBoss && this.caveBoss.active && Phaser.Math.Distance.Between(fb.x, fb.y, this.caveBoss.x, this.caveBoss.y) < 40) {
                let totalDmg = fb.damage + (fb.dot || 0) * (fb.dotDuration || 0);
                if (this.computedBossDamage) totalDmg = Math.floor(totalDmg * (1 + this.computedBossDamage / 100));
                this.caveBoss.stats.hp -= totalDmg;
                spellTotalDmg += totalDmg;
                this.floatingText(this.caveBoss.x, this.caveBoss.y - 20, '-' + totalDmg, '#e74c3c');
                if (this.caveBoss.hpFill) this.caveBoss.hpFill.width = this.caveBoss.hpBg.width * (this.caveBoss.stats.hp / this.caveBoss.stats.maxHp);
                hit = true;
                if (this.caveBoss.stats.hp <= 0) this.killCaveBoss();
            }
            if (this.caveSmallBats) {
                this.caveSmallBats.getChildren().forEach(e => {
                    if (e.active && Phaser.Math.Distance.Between(fb.x, fb.y, e.x, e.y) < 15) {
                        e.stats.hp -= fb.damage;
                        spellTotalDmg += fb.damage;
                        this.floatingText(e.x, e.y - 20, '-' + fb.damage, '#e74c3c');
                        hit = true;
                        if (e.stats.hp <= 0) this.killEnemy(e);
                    }
                });
            }
            if (this.villageChests) {
                this.villageChests.getChildren().forEach(ch => {
                    if (ch.active && !ch.broken && Phaser.Math.Distance.Between(fb.x, fb.y, ch.x, ch.y) < 20) {
                        ch.stats.hp -= fb.damage;
                        if (ch.hpFill) ch.hpFill.width = ch.hpBg.width * (ch.stats.hp / ch.stats.maxHp);
                        hit = true;
                        if (ch.stats.hp <= 0) this.breakVillageChest(ch);
                    }
                });
            }
            if (this.villageZombies) {
                this.villageZombies.getChildren().forEach(e => {
                    if (e.active && Phaser.Math.Distance.Between(fb.x, fb.y, e.x, e.y) < 15) {
                        e.stats.hp -= fb.damage;
                        spellTotalDmg += fb.damage;
                        this.floatingText(e.x, e.y - 20, '-' + fb.damage, '#5a6a4a');
                        hit = true;
                        if (e.stats.hp <= 0) this.killEnemy(e);
                    }
                });
            }
            if (this.villageBoss && this.villageBoss.active && Phaser.Math.Distance.Between(fb.x, fb.y, this.villageBoss.x, this.villageBoss.y) < 40) {
                let totalDmg = fb.damage + (fb.dot || 0) * (fb.dotDuration || 0);
                if (this.computedBossDamage) totalDmg = Math.floor(totalDmg * (1 + this.computedBossDamage / 100));
                this.villageBoss.stats.hp -= totalDmg;
                spellTotalDmg += totalDmg;
                this.floatingText(this.villageBoss.x, this.villageBoss.y - 20, '-' + totalDmg, '#e74c3c');
                if (this.villageBoss.hpFill) this.villageBoss.hpFill.width = this.villageBoss.hpBg.width * (this.villageBoss.stats.hp / this.villageBoss.stats.maxHp);
                hit = true;
                if (this.villageBoss && this.villageBoss.active) {
                    const bs = this.villageBoss.stats;
                    if (!bs.splitDone && bs.hp / bs.maxHp <= VILLAGE_BOSS_TYPE.splitThreshold) {
                        bs.splitDone = true;
                        this._villageBossSplit(this.villageBoss);
                    } else if (bs.hp <= 0 && !bs.splitDone) {
                        bs.splitDone = true;
                        this._villageBossSplit(this.villageBoss);
                    }
                }
            }
            if (this.hellBoss && this.hellBoss.active && Phaser.Math.Distance.Between(fb.x, fb.y, this.hellBoss.x, this.hellBoss.y) < 40) {
                let totalDmg = fb.damage + (fb.dot || 0) * (fb.dotDuration || 0);
                if (this.computedBossDamage) totalDmg = Math.floor(totalDmg * (1 + this.computedBossDamage / 100));
                this.hellBoss.stats.hp -= totalDmg;
                spellTotalDmg += totalDmg;
                this.floatingText(this.hellBoss.x, this.hellBoss.y - 20, '-' + totalDmg, '#e74c3c');
                if (this.hellBoss.hpFill) this.hellBoss.hpFill.width = this.hellBoss.hpBg.width * (this.hellBoss.stats.hp / this.hellBoss.stats.maxHp);
                hit = true;
                if (this.hellBoss.stats.hp <= 0) this._victoryHellBoss();
            }
            if (this.snowyIceSpirit && this.snowyIceSpirit.active && Phaser.Math.Distance.Between(fb.x, fb.y, this.snowyIceSpirit.x, this.snowyIceSpirit.y) < 40) {
                let totalDmg = fb.damage + (fb.dot || 0) * (fb.dotDuration || 0);
                if (this.computedBossDamage) totalDmg = Math.floor(totalDmg * (1 + this.computedBossDamage / 100));
                this.snowyIceSpirit.stats.hp -= totalDmg;
                spellTotalDmg += totalDmg;
                this.floatingText(this.snowyIceSpirit.x, this.snowyIceSpirit.y - 20, '-' + totalDmg, '#3498db');
                if (this.snowyIceSpirit.hpFill) this.snowyIceSpirit.hpFill.width = this.snowyIceSpirit.hpBg.width * (this.snowyIceSpirit.stats.hp / this.snowyIceSpirit.stats.maxHp);
                hit = true;
                if (this.snowyIceSpirit.stats.hp <= 0) this._snowyIceSpiritDied();
            }
            if (this.snowyIceShards) {
                this.snowyIceShards.getChildren().forEach(s => {
                    if (s.active && s.stats && Phaser.Math.Distance.Between(fb.x, fb.y, s.x, s.y) < 15) {
                        s.stats.hp -= fb.damage;
                        spellTotalDmg += fb.damage;
                        this.floatingText(s.x, s.y - 15, '-' + fb.damage, '#3498db');
                        hit = true;
                        if (s.stats.hp <= 0) {
                            if (s.hpBg) s.hpBg.destroy();
                            if (s.hpFill) s.hpFill.destroy();
                            s.destroy();
                        }
                    }
                });
            }
            if (this.stumps) {
                this.stumps.getChildren().forEach(s => {
                    if (s.active && Phaser.Math.Distance.Between(fb.x, fb.y, s.x, s.y) < 18) {
                        s.stats.hp -= fb.damage;
                        this.floatingText(s.x, s.y - 15, '-' + fb.damage, '#f39c12');
                        if (s.hpFill) s.hpFill.width = s.hpBg.width * (s.stats.hp / s.stats.maxHp);
                        hit = true;
                        if (s.stats.hp <= 0) this.breakStump(s);
                    }
                });
            }

            const wb = this.physics.world.bounds;
            if (hit || fb.x < wb.x - 20 || fb.x > wb.x + wb.width + 20 || fb.y < wb.y - 20 || fb.y > wb.y + wb.height + 20) {
                if (fb.glow) fb.glow.destroy();
                fb.destroy();
                this.fireballs.splice(i, 1);
            }
        }

        if (this.shieldActive) {
            this.shieldTimer -= dt;
            if (this.shieldVfx) {
                this.shieldVfx.x = this.player.x;
                this.shieldVfx.y = this.player.y;
            }
            if (this.shieldTimer <= 0 || this.shieldHP <= 0) {
                this.shieldActive = false;
                this.shieldHP = 0;
                this.lifeLinkActive = false;
                if (this.shieldVfx) { this.shieldVfx.destroy(); this.shieldVfx = null; }
            }
        }

        if (this.lifeLinkActive && this.lifeLinkTimer > 0) {
            this.lifeLinkTimer -= dt;
            if (this.lifeLinkTimer <= 0) {
                this.lifeLinkActive = false;
            } else {
                const healAmt = Math.floor(this.playerMaxHP * this.lifeLinkHealPerSec * dt);
                if (healAmt > 0) {
                    this.playerHP = Math.min(this.playerMaxHP, this.playerHP + healAmt);
                }
            }
        }
    }

    updateUI() {
        const req = Math.floor(100 * Math.pow(this.playerLevel, 1.5));

        const accReq = getAccountLevelUpReq(this.accountLevel);
        this.levelText.setText('Acc Lv.' + this.accountLevel);
        this.hpBarFill.width = Math.max(0, 198 * (this.playerHP / this.playerMaxHP));
        if (this.playerHP / this.playerMaxHP > 0.6) this.hpBarFill.setFillStyle(0x27ae60);
        else if (this.playerHP / this.playerMaxHP > 0.3) this.hpBarFill.setFillStyle(0xf39c12);
        else this.hpBarFill.setFillStyle(0xe74c3c);

        if (this.shieldActive && this.shieldHP > 0) {
            this.shieldBarFill.width = Math.min(198, 198 * (this.shieldHP / this.playerMaxHP));
            this.shieldBarFill.x = 201 + this.hpBarFill.width;
        } else {
            this.shieldBarFill.width = 0;
        }

        this.corruptionBarFill.width = Math.max(0, 198 * (this.corruption / this.corruptionMax));
        if (this.corruption / this.corruptionMax > 0.8) this.corruptionBarFill.setFillStyle(0xe74c3c);
        else if (this.corruption / this.corruptionMax > 0.5) this.corruptionBarFill.setFillStyle(0xe67e22);
        else this.corruptionBarFill.setFillStyle(0x9b59b6);

        this.talentText.setText(this.talentPoints > 0 ? 'TALENTS: ' + this.talentPoints + ' [T]' : '');

        this.accountLevelText.setText('Acc Lv.' + this.accountLevel + '  ' + this.accountExp + '/' + accReq);
        this.accountExpBarFill.width = Math.max(0, 198 * (this.accountExp / accReq));

        this.statsBarText.setText(
            'Acc Lv.' + this.accountLevel +
            '  HP:' + this.playerHP + '/' + this.playerMaxHP +
            '  DMG:' + this.playerDamage +
            '  EXP:' + this.accountExp + '/' + accReq
        );

        if (this._statsExpanded && this.statsValues.length >= 4) {
            this.statsValues[0].setText('' + this.accountLevel);
            this.statsValues[1].setText(this.playerHP + ' / ' + this.playerMaxHP);
            this.statsValues[1].setColor(this.playerHP / this.playerMaxHP > 0.3 ? '#27ae60' : '#e74c3c');
            this.statsValues[2].setText('' + this.playerDamage);
            this.statsValues[3].setText(this.accountExp + ' / ' + accReq);
        }

        if (this.spellSlots) {
            ['fireball', 'shield', 'heal'].forEach(key => {
                const s = this.spellSlots[key];
                const cd = this.spellCooldowns[key];
                if (cd > 0) {
                    s.cd.setText(cd.toFixed(1));
                    s.bg.setFillStyle(0x111111);
                    s.bg.setAlpha(0.6);
                } else {
                    s.cd.setText('');
                    s.bg.setFillStyle(0x1a1a2e);
                    s.bg.setAlpha(1);
                }
            });
        }
    }

    floatingText(x, y, text, color) {
        const t = this.add.text(x, y, text, {
            fontSize: '12px', fill: color, fontFamily: 'Arial',
            fontStyle: 'bold', stroke: '#000', strokeThickness: 2
        }).setOrigin(0.5);
        this.tweens.add({
            targets: t, y: t.y - 30, alpha: 0, duration: 700,
            onComplete: () => t.destroy()
        });
    }

    /* ===== INPUT ===== */

    _bindKeys() {
        this.cursors = this.input.keyboard.createCursorKeys();
        this.spaceKey = this.input.keyboard.addKey(Phaser.Input.Keyboard.KeyCodes.SPACE);
        this.pKey = this.input.keyboard.addKey(Phaser.Input.Keyboard.KeyCodes.P);
        this.iKey = this.input.keyboard.addKey(Phaser.Input.Keyboard.KeyCodes.I);
        this.tabKey = this.input.keyboard.addKey(Phaser.Input.Keyboard.KeyCodes.TAB);
        this.mKey = this.input.keyboard.addKey(Phaser.Input.Keyboard.KeyCodes.M);
        this.tKey = this.input.keyboard.addKey(Phaser.Input.Keyboard.KeyCodes.T);
        this.qKey = this.input.keyboard.addKey(Phaser.Input.Keyboard.KeyCodes.Q);
        this.wKey = this.input.keyboard.addKey(Phaser.Input.Keyboard.KeyCodes.W);
        this.eKey = this.input.keyboard.addKey(Phaser.Input.Keyboard.KeyCodes.E);
        this.bKey = this.input.keyboard.addKey(Phaser.Input.Keyboard.KeyCodes.B);
        this.nKey = this.input.keyboard.addKey(Phaser.Input.Keyboard.KeyCodes.N);
        this.cKey = this.input.keyboard.addKey(Phaser.Input.Keyboard.KeyCodes.C);
    }

    _checkNpcProximity() {
        if (this.menuOpen || this.transitioning) {
            this.nearbyNpc = null;
            return;
        }
        this.nearbyNpc = null;
        let minDist = 60;
        this.npcSprites.forEach(spr => {
            if (!spr.active) return;
            const d = Phaser.Math.Distance.Between(this.player.x, this.player.y, spr.x, spr.y);
            if (d < minDist) {
                minDist = d;
                this.nearbyNpc = spr;
            }
        });
        if (this.nearbyNpc) {
            const status = getNpcQuestStatus(this.nearbyNpc.npcKey);
            if (status === 'quest_available') {
                this.hintText.setText('SPACE: Talk to ' + this.nearbyNpc.nameTag.text);
            } else if (status === 'quest_complete') {
                this.hintText.setText('SPACE: Turn in quest to ' + this.nearbyNpc.nameTag.text);
            } else {
                this.hintText.setText('SPACE: Talk to ' + this.nearbyNpc.nameTag.text);
            }
        }
    }

    _interactWithNpc() {
        if (!this.nearbyNpc) return;
        const npcKey = this.nearbyNpc.npcKey;

        // Cart Driver special interaction
        if (npcKey === 'cart_driver' && this.hasSecretKey) {
            this._startCartRide();
            return;
        }

        const npc = NPC_DB[npcKey];
        if (!npc) return;

        const status = getNpcQuestStatus(npcKey);

        if (status === 'quest_complete') {
            const active = getActiveQuests();
            const completable = active.filter(q => isQuestComplete(q.key));
            if (completable.length > 0) {
                const q = completable[0];
                const rewards = completeQuest(q.key);
                if (rewards) {
                    if (rewards.exp) {
                        this.playerExp += rewards.exp;
                        this.floatingText(this.player.x, this.player.y - 40, '+' + rewards.exp + ' EXP', '#f1c40f');
                    }
                    if (rewards.accountExp) {
                        this.accountExp += rewards.accountExp;
                        this.floatingText(this.player.x, this.player.y - 60, '+' + rewards.accountExp + ' Account EXP', '#e67e22');
                    }
                    if (rewards.talentPoints) {
                        this.talentPoints += rewards.talentPoints;
                        this.floatingText(this.player.x, this.player.y - 80, '+' + rewards.talentPoints + ' Talent Point', '#9b59b6');
                    }
                    if (q.rewardItems && q.rewardItems.length > 0) {
                        const { rollEquip } = require('../utils.js');
                        const item = rollEquip();
                        if (this.addEquip(item)) {
                            this.floatingText(this.player.x + 30, this.player.y - 40, '+' + item.name, '#3498db');
                        }
                    }
                }
                this._updateQuestIcons();
                saveQuests();
            }
            return;
        }

        const available = getAvailableQuests(npcKey);
        if (available.length > 0) {
            const qKey = available[0];
            acceptQuest(qKey);
            const quest = QUEST_DB[qKey];
            this.floatingText(this.player.x, this.player.y - 40, 'New Quest: ' + quest.name, '#f1c40f');
            this._updateQuestIcons();
            saveQuests();
        } else {
            const greeting = getLang() === 'ru' && npc.greetingRu ? npc.greetingRu
                : getLang() === 'de' && npc.greetingDe ? npc.greetingDe
                : npc.greeting;
            this.floatingText(this.player.x, this.player.y - 40, greeting, '#aaa');
        }
    }

    _startCartRide() {
        if (this.transitioning) return;
        this.transitioning = true;
        this.menuOpen = true;
        this.physics.pause();

        const cd = CART_DRIVER_NPC.cart_driver;
        const lang = getLang();
        const greeting = lang === 'ru' ? cd.greetingRu : lang === 'de' ? cd.greetingDe : cd.greeting;
        this.floatingText(this.player.x, this.player.y - 40, greeting, '#f1c40f');

        this.time.delayedCall(1500, () => {
            this.cameras.main.fadeOut(800, 0, 0, 0);
            this.time.delayedCall(800, () => {
                this._clearForest();

                this.cameras.main.setBackgroundColor('#1a0e05');
                this.add.image(400, 300, 'cart_ride').setDepth(0);

                const cartText = this.add.text(400, 280, '...', {
                    fontSize: '20px', fill: '#f5cba7', fontFamily: 'Georgia', fontStyle: 'italic'
                }).setOrigin(0.5).setDepth(10);

                const dots = ['...', '....', '.....', 'The road is long...'];
                let dotIdx = 0;
                const dotTimer = this.time.addEvent({
                    delay: 800, repeat: dots.length - 1,
                    callback: () => {
                        dotIdx++;
                        if (dotIdx < dots.length) cartText.setText(dots[dotIdx]);
                    }
                });

                this.cameras.main.fadeIn(500, 0, 0, 0);

                this.time.delayedCall(3500, () => {
                    this.cameras.main.fadeOut(800, 0, 0, 0);
                    this.time.delayedCall(800, () => {
                        cartText.destroy();
                        this._setupMeadow();
                        this.cameras.main.fadeIn(500, 0, 0, 0);
                        this.transitioning = false;
                        this.menuOpen = false;
                        this.physics.resume();
                        this.hasSecretKey = false;
                        this.doSave();
                    });
                });
            });
        });
    }

    _setupMeadow() {
        this.cameras.main.setBackgroundColor('#1a3a1a');
        this.physics.world.setBounds(0, 0, MEADOW_WIDTH, MEADOW_HEIGHT);
        this.cameras.main.setBounds(0, 0, MEADOW_WIDTH, MEADOW_HEIGHT);

        this.meadowBg = this.add.image(400, 300, 'meadow_ground').setDepth(0);

        this.meadowGate = this.add.sprite(MEADOW_GATE_POS.x, MEADOW_GATE_POS.y, 'mine_gate').setDepth(5);
        this.physics.add.existing(this.meadowGate, true);
        this.meadowGate.body.setSize(64, 80);

        this.gateHint = this.add.text(MEADOW_GATE_POS.x, MEADOW_GATE_POS.y + 50, '', {
            fontSize: '12px', fill: '#f1c40f', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 2
        }).setOrigin(0.5).setDepth(12);

        this.player.x = 400;
        this.player.y = 500;
        this.player.body.setCollideWorldBounds(true);
        this.cameras.main.startFollow(this.player, true, 0.1, 0.1);
        this.cameras.main.setDeadzone(100, 80);

        this.zone = 'meadow';
        this.hintText.setText('Arrows=move | SPACE=interact | I=inventory | TAB=stats | T=talents | C=craft | Q=quests | P=pause | M=sound');

        this.doSave();
    }

    _checkMeadowGate() {
        if (this.zone !== 'meadow' || this.transitioning || this.menuOpen) return;
        if (!this.meadowGate) return;
        const dist = Phaser.Math.Distance.Between(
            this.player.x, this.player.y, MEADOW_GATE_POS.x, MEADOW_GATE_POS.y
        );
        if (dist < 70) {
            this.gateHint.setText('SPACE to unlock the gate');
        } else {
            this.gateHint.setText('');
        }
    }

    _unlockMeadowGate() {
        if (this.transitioning || this.menuOpen) return;
        if (this.zone !== 'meadow') return;
        if (!this.meadowGate) return;
        const dist = Phaser.Math.Distance.Between(
            this.player.x, this.player.y, MEADOW_GATE_POS.x, MEADOW_GATE_POS.y
        );
        if (dist >= 70) return;

        this.transitioning = true;
        this.gateHint.setText('');
        playPortal();
        this.cameras.main.fadeOut(800, 0, 0, 0);
        this.time.delayedCall(800, () => {
            this._clearMeadow();
            this._setupCave();
            this.cameras.main.fadeIn(500, 0, 0, 0);
            this.transitioning = false;
        });
    }

    _clearMeadow() {
        this.physics.world.colliders.destroy();
        if (this.meadowBg) { this.meadowBg.destroy(); this.meadowBg = null; }
        if (this.meadowGate) { this.meadowGate.destroy(); this.meadowGate = null; }
        if (this.gateHint) { this.gateHint.destroy(); this.gateHint = null; }
    }

    _openQuestLog() {
        if (this.menuOpen) return;
        this.questLogOpen = true;
        this.menuOpen = true;
        this.physics.pause();

        this.questLogGroup = [];
        const mk = (el) => { el.setScrollFactor(0).setDepth(100); return el; };

        this.questLogGroup.push(mk(this.add.rectangle(400, 300, 800, 600, 0x000000, 0.97)
            .setStrokeStyle(2, 0xf1c40f).setInteractive()));

        this.questLogGroup.push(mk(this.add.text(400, 35, t('quest.title'), {
            fontSize: '26px', fill: '#f1c40f', fontFamily: 'Arial', fontStyle: 'bold'
        }).setOrigin(0.5)));

        const active = getActiveQuests();
        if (active.length === 0) {
            this.questLogGroup.push(mk(this.add.text(400, 300, t('quest.noQuests'), {
                fontSize: '16px', fill: '#666', fontFamily: 'Arial', align: 'center'
            }).setOrigin(0.5)));
        } else {
            active.forEach((q, i) => {
                const y = 75 + i * 95;
                const complete = isQuestComplete(q.key);
                const color = complete ? '#2ecc71' : '#ecf0f1';

                this.questLogGroup.push(mk(this.add.text(60, y, q.name, {
                    fontSize: '15px', fill: color, fontFamily: 'Arial', fontStyle: 'bold'
                })));

                this.questLogGroup.push(mk(this.add.text(60, y + 20, q.description, {
                    fontSize: '12px', fill: '#95a5a6', fontFamily: 'Arial',
                    wordWrap: { width: 520 }
                })));

                const prog = getQuestProgress(q.key);
                const actionLabel = q.type === 'kill' ? t('quest.kill') : t('quest.collect');
                const progText = `${actionLabel} ${q.target}: ${prog.current}/${prog.total}`;
                this.questLogGroup.push(mk(this.add.text(640, y, progText, {
                    fontSize: '12px', fill: complete ? '#2ecc71' : '#f39c12', fontFamily: 'Arial', fontStyle: 'bold'
                }).setOrigin(1, 0)));

                const rewardParts = [];
                if (q.rewards) {
                    if (q.rewards.exp) rewardParts.push('+' + q.rewards.exp + ' EXP');
                    if (q.rewards.accountExp) rewardParts.push('+' + q.rewards.accountExp + ' Acc EXP');
                    if (q.rewards.talentPoints) rewardParts.push('+' + q.rewards.talentPoints + ' TP');
                }
                if (q.rewardItems && q.rewardItems.length > 0) {
                    rewardParts.push(q.rewardItems.length + ' item(s)');
                }
                if (rewardParts.length > 0) {
                    this.questLogGroup.push(mk(this.add.text(640, y + 20, t('quest.rewards') + ': ' + rewardParts.join('  '), {
                        fontSize: '11px', fill: '#f39c12', fontFamily: 'Arial'
                    }).setOrigin(1, 0)));
                }

                if (i < active.length - 1) {
                    this.questLogGroup.push(mk(this.add.rectangle(400, y + 80, 680, 1, 0x333)));
                }
            });
        }

        const closeBtn = mk(this.add.rectangle(400, 560, 140, 35, 0x34495e)
            .setStrokeStyle(1, 0x555).setInteractive({ useHandCursor: true }));
        this.questLogGroup.push(closeBtn);
        this.questLogGroup.push(mk(this.add.text(400, 560, t('quest.close'), {
            fontSize: '16px', fill: '#fff', fontFamily: 'Arial', fontStyle: 'bold'
        }).setOrigin(0.5)));
        closeBtn.on('pointerdown', () => this._closeQuestLog());
        this.input.keyboard.on('keydown-N', () => this._closeQuestLog());
        this.input.keyboard.on('keydown-ESC', () => this._closeQuestLog());
    }

    _closeQuestLog() {
        this.questLogGroup.forEach(e => e.destroy());
        this.questLogGroup = [];
        this.questLogOpen = false;
        this.menuOpen = false;
        this.physics.resume();
    }

    /* ==========================================================
       ZONE: FOREST
       ========================================================== */

    _setupForest() {
        this._clearArena();
        this.bossDefeated = false;

        this.cameras.main.setBackgroundColor('#16213e');
        this.physics.world.setBounds(0, 0, GAME_WIDTH, FOREST_HEIGHT);
        this.cameras.main.setBounds(0, 0, GAME_WIDTH, FOREST_HEIGHT);

        this.forestBg = this.add.tileSprite(0, 0, GAME_WIDTH, FOREST_HEIGHT, 'ground')
            .setOrigin(0, 0).setScale(1, FOREST_HEIGHT / 200).setDepth(0);

        this.portalSprite = this.add.sprite(PORTAL_POS.x, PORTAL_POS.y, 'tree_hole').setDepth(1);
        this.portalHint = this.add.text(PORTAL_POS.x, PORTAL_POS.y + 50, '', {
            fontSize: '11px', fill: '#f1c40f', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 2
        }).setOrigin(0.5).setDepth(12);

        this.player.x = FOREST_RETURN_POS.x;
        this.player.y = FOREST_RETURN_POS.y;
        this.player.body.setCollideWorldBounds(true);

        this.cameras.main.startFollow(this.player, true, 0.08, 0.08);
        this.cameras.main.setDeadzone(100, 80);

        this.enemies = this.physics.add.group();
        this.stumps = this.physics.add.group();
        this._spawnEnemies();
        this._spawnStumps();

        this.physics.add.overlap(this.player, this.enemies, (p, e) => {
            if (e.active && e.stats && !this.menuOpen && !this.transitioning) {
                this.takeDamage(e.stats.damage);
            }
        }, null, this);

        this.zone = 'forest';
        this._spawnNPCs();
        this.hintText.setText('Arrows=move | SPACE=attack/NPC | I=inventory | TAB=stats | T=talents | C=craft | Q=quests | P=pause | M=sound');
        startMusic();
    }

    _spawnEnemies() {
        for (let i = 0; i < ENEMY_COUNT; i++) {
            const t = ENEMY_TYPES[i];
            this._makeEnemy(t, 100 + Math.random() * 600, 300 + Math.random() * 400);
        }
    }

    _spawnNPCs() {
        this.npcSprites.forEach(n => n.destroy());
        this.questIcons.forEach(n => n.destroy());
        this.npcSprites = [];
        this.questIcons = [];
        this.nearbyNpc = null;

        Object.entries(NPC_DB).forEach(([key, npc]) => {
            if (npc.biome !== this.zone) return;
            const spr = this.add.sprite(npc.x, npc.y, npc.texKey).setDepth(8);
            this.physics.add.existing(spr, true);
            spr.body.setSize(24, 24);
            spr.npcKey = key;
            this.npcSprites.push(spr);

            const lang = getLang();
            const displayName = lang === 'ru' ? (npc.nameRu || npc.name) : lang === 'de' ? (npc.nameDe || npc.name) : npc.name;
            const nameTag = this.add.text(npc.x, npc.y - 30, displayName, {
                fontSize: '10px', fill: '#f1c40f', fontFamily: 'Arial', fontStyle: 'bold',
                stroke: '#000', strokeThickness: 2
            }).setOrigin(0.5).setDepth(9);
            spr.nameTag = nameTag;

            const icon = this.add.sprite(npc.x, npc.y - 44, 'quest_icon').setDepth(10);
            this.questIcons.push(icon);
            spr.questIcon = icon;
        });

        // Cart Driver NPC (only in forest, only if has key)
        if (this.cartDriverNpc) { this.cartDriverNpc.destroy(); this.cartDriverNpc = null; }
        if (this.zone === 'forest' && this.hasSecretKey) {
            const cd = CART_DRIVER_NPC.cart_driver;
            const spr = this.add.sprite(cd.x, cd.y, cd.texKey).setDepth(8);
            this.physics.add.existing(spr, true);
            spr.body.setSize(24, 24);
            spr.npcKey = 'cart_driver';
            this.npcSprites.push(spr);
            this.cartDriverNpc = spr;

            const lang = getLang();
            const displayName = lang === 'ru' ? cd.nameRu : lang === 'de' ? cd.nameDe : cd.name;
            const nameTag = this.add.text(cd.x, cd.y - 30, displayName, {
                fontSize: '10px', fill: '#f1c40f', fontFamily: 'Arial', fontStyle: 'bold',
                stroke: '#000', strokeThickness: 2
            }).setOrigin(0.5).setDepth(9);
            spr.nameTag = nameTag;

            const icon = this.add.sprite(cd.x, cd.y - 44, 'quest_icon').setDepth(10);
            this.questIcons.push(icon);
            spr.questIcon = icon;
        }

        this._updateQuestIcons();
    }

    _updateQuestIcons() {
        this.npcSprites.forEach(spr => {
            const status = getNpcQuestStatus(spr.npcKey);
            if (spr.questIcon) {
                spr.questIcon.setVisible(status === 'quest_available' || status === 'quest_complete');
                if (status === 'quest_complete') {
                    spr.questIcon.setTint(0x2ecc71);
                } else {
                    spr.questIcon.clearTint();
                }
            }
            if (spr.nameTag) {
                spr.nameTag.setPosition(spr.x, spr.y - 30);
            }
        });
    }

    _makeEnemy(t, x, y) {
        const walkTexKey = t.key + '_walk';
        const walkAnimKey = t.key === 'skeleton_archer' ? 'skeleton_archer_walk_anim' :
                           t.key === 'skeleton_shaman' ? 'skeleton_shaman_walk_anim' :
                           t.key === 'skeleton_warrior' ? 'skeleton_walk' :
                           t.key + '_walk';
        const e = this.add.sprite(x, y, walkTexKey).setDepth(5);
        this.physics.add.existing(e, false);
        e.body.setSize(t.bw, t.bh);
        e.body.setCollideWorldBounds(true);
        e.walkAnimKey = walkAnimKey;

        e.stats = {
            key: t.key, name: t.name,
            hp: Math.floor(t.hp * this.diffMulti.hp),
            maxHp: Math.floor(t.hp * this.diffMulti.hp),
            damage: Math.floor(t.dmg * this.diffMulti.dmg),
            exp: Math.floor(t.exp * this.diffMulti.exp),
            bw: t.bw, bh: t.bh,
            wTimer: 0, wDir: 0
        };

        const hw = t.bw + 4;
        e.hpBg = this.add.rectangle(x, y - t.bh / 2 - 8, hw, 3, 0x333333).setOrigin(0.5).setDepth(11);
        e.hpFill = this.add.rectangle(x, y - t.bh / 2 - 8, hw, 3, 0xe74c3c).setOrigin(0.5).setDepth(11);
        this.enemies.add(e);
        return e;
    }

    _spawnStumps() {
        for (let i = 0; i < STUMP_COUNT; i++) {
            this._createStump(60 + Math.random() * 680, 450 + Math.random() * 300);
        }
    }

    _createStump(x, y) {
        const s = this.add.sprite(x, y, 'stump').setDepth(5);
        this.physics.add.existing(s, false);
        s.body.setSize(24, 18);
        s.body.setCollideWorldBounds(true);
        s.stats = { hp: 30, maxHp: 30 };
        s.hpBg = this.add.rectangle(x, y - 18, 28, 3, 0x333333).setOrigin(0.5).setDepth(11);
        s.hpFill = this.add.rectangle(x, y - 18, 28, 3, 0x8b6914).setOrigin(0.5).setDepth(11);
        this.stumps.add(s);
    }

    _checkPortalProximity() {
        if (this.zone !== 'forest' || this.transitioning || this.menuOpen) return;
        const dist = Phaser.Math.Distance.Between(
            this.player.x, this.player.y, PORTAL_POS.x, PORTAL_POS.y
        );
        if (dist < PORTAL_ENTER_DIST) {
            this.portalHint.setText('SPACE to enter');
        } else {
            this.portalHint.setText('');
        }
    }

    _enterPortal() {
        if (this.transitioning || this.menuOpen) return;
        if (this.zone !== 'forest') return;
        const dist = Phaser.Math.Distance.Between(
            this.player.x, this.player.y, PORTAL_POS.x, PORTAL_POS.y
        );
        if (dist >= PORTAL_ENTER_DIST) return;

        this.transitioning = true;
        this.portalHint.setText('');
        playPortal();
        this.cameras.main.fadeOut(500, 0, 0, 0);
        this.time.delayedCall(500, () => {
            this._clearForest();
            this._setupArena();
            this.cameras.main.fadeIn(500, 0, 0, 0);
            this.transitioning = false;
        });
    }

    _clearForest() {
        this.physics.world.colliders.destroy();
        if (this.enemies && this.enemies.getLength && this.enemies.getLength() > 0) {
            this.enemies.getChildren().forEach(e => {
                if (e.hpBg) e.hpBg.destroy();
                if (e.hpFill) e.hpFill.destroy();
            });
            this.enemies.clear(true, true);
        }
        if (this.enemies) { this.enemies.destroy(); this.enemies = null; }
        if (this.stumps && this.stumps.getLength && this.stumps.getLength() > 0) {
            this.stumps.getChildren().forEach(s => {
                if (s.hpBg) s.hpBg.destroy();
                if (s.hpFill) s.hpFill.destroy();
            });
            this.stumps.clear(true, true);
        }
        if (this.stumps) { this.stumps.destroy(); this.stumps = null; }
        if (this.forestBg) { this.forestBg.destroy(); this.forestBg = null; }
        if (this.portalSprite) { this.portalSprite.destroy(); this.portalSprite = null; }
        if (this.portalHint) { this.portalHint.destroy(); this.portalHint = null; }
        this.npcSprites.forEach(n => { if (n.nameTag) n.nameTag.destroy(); if (n.questIcon) n.questIcon.destroy(); n.destroy(); });
        this.npcSprites = [];
        this.questIcons = [];
        this.nearbyNpc = null;
    }

    /* ==========================================================
       ZONE: BOSS ARENA
       ========================================================== */

    _setupArena() {
        this.cameras.main.setBackgroundColor('#0d0d1a');
        this.physics.world.setBounds(0, 0, GAME_WIDTH, GAME_HEIGHT);
        this.cameras.main.setBounds(0, 0, GAME_WIDTH, GAME_HEIGHT);

        this.add.image(400, 300, 'boss_ground').setDepth(0);

        this.exitPortal = this.add.sprite(ARENA_EXIT_POS.x, ARENA_EXIT_POS.y, this.mineUnlocked ? 'mine_ladder' : 'boss_portal').setDepth(1);
        this.exitHint = this.add.text(ARENA_EXIT_POS.x, ARENA_EXIT_POS.y + 50, '', {
            fontSize: '11px', fill: '#aa50ee', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 2
        }).setOrigin(0.5).setDepth(12);

        this.player.x = 400;
        this.player.y = 500;
        this.player.body.setCollideWorldBounds(true);
        this.cameras.main.stopFollow();

        this.bossAlive = false;
        this.bossDefeated = this.mineUnlocked;

        this.enemies = this.physics.add.group();
        this.stumps = this.physics.add.group();

        if (!this.mineUnlocked) {
            this._spawnBoss();
        }

        this.physics.add.overlap(this.player, this.enemies, (p, e) => {
            if (e.active && e.stats && !this.menuOpen && !this.transitioning) {
                this.takeDamage(e.stats.damage);
            }
        }, null, this);

        this.zone = 'arena';
        this.hintText.setText(this.mineUnlocked ? 'Enter the Mine! | I=inventory | TAB=stats | P=pause' : 'Defeat the Ancient Treant! | I=inventory | TAB=stats | P=pause');
        startMusic();
    }

    _spawnBoss() {
        const bt = BOSS_TYPE;
        const hp = Math.floor(bt.hp[this.difficulty] || bt.hp.Normal);
        const dmg = Math.floor(bt.dmg[this.difficulty] || bt.dmg.Normal);
        const exp = Math.floor(bt.exp[this.difficulty] || bt.exp.Normal);
        const spd = bt.speeds[this.difficulty] || bt.speeds.Normal;

        this.boss = this.add.sprite(400, 180, 'treant_walk').setDepth(5);
        this.physics.add.existing(this.boss, false);
        this.boss.body.setSize(bt.bw, bt.bh);
        this.boss.body.setCollideWorldBounds(true);
        this.boss.play('treant_walk');

        this.boss.stats = {
            name: bt.name,
            hp: hp, maxHp: hp,
            damage: dmg, exp: exp,
            speed: spd,
            bw: bt.bw, bh: bt.bh,
            aoeTimer: 0, aoeInterval: bt.aoeInterval,
            aoeDmgMul: bt.aoeDmgMul, aoeRadius: bt.aoeRadius
        };

        const hw = bt.bw + 20;
        this.boss.hpBg = this.add.rectangle(400, 100, hw, 5, 0x333333).setOrigin(0.5).setDepth(15);
        this.boss.hpFill = this.add.rectangle(400, 100, hw, 5, 0xe74c3c).setOrigin(0.5).setDepth(15);

        this.bossNameText = this.add.text(400, 85, bt.name, {
            fontSize: '12px', fill: '#ff4444', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 2
        }).setOrigin(0.5).setDepth(15);

        this.bossAlive = true;
        this.enemies.add(this.boss);
    }

    _checkExitProximity() {
        if (this.zone !== 'arena' || this.transitioning || this.menuOpen) return;
        const dist = Phaser.Math.Distance.Between(
            this.player.x, this.player.y, ARENA_EXIT_POS.x, ARENA_EXIT_POS.y
        );
        if (dist < 50) {
            this.exitHint.setText(this.mineUnlocked ? 'SPACE to enter the Mine' : 'SPACE to exit');
        } else {
            this.exitHint.setText('');
        }
    }

    _exitArena() {
        if (this.transitioning || this.menuOpen) return;
        if (this.zone !== 'arena') return;
        const dist = Phaser.Math.Distance.Between(
            this.player.x, this.player.y, ARENA_EXIT_POS.x, ARENA_EXIT_POS.y
        );
        if (dist >= 50) return;

        this.transitioning = true;
        this.exitHint.setText('');
        playPortal();
        this.cameras.main.fadeOut(500, 0, 0, 0);
        this.time.delayedCall(500, () => {
            this._clearArena();
            if (this.mineUnlocked) {
                this._setupMine();
            } else {
                this._setupForest();
            }
            this.cameras.main.fadeIn(500, 0, 0, 0);
            this.transitioning = false;
        });
    }

    _clearArena() {
        this.physics.world.colliders.destroy();
        if (this.fireballs) {
            this.fireballs.forEach(fb => { if (fb.glow) fb.glow.destroy(); fb.destroy(); });
            this.fireballs = [];
        }
        if (this.shieldActive) {
            this.shieldActive = false;
            this.shieldHP = 0;
            if (this.shieldVfx) { this.shieldVfx.destroy(); this.shieldVfx = null; }
        }
        if (this.boss) {
            if (this.boss.hpBg) this.boss.hpBg.destroy();
            if (this.boss.hpFill) this.boss.hpFill.destroy();
            if (this.bossNameText) this.bossNameText.destroy();
            if (this.boss.aoeRing) { this.boss.aoeRing.destroy(); this.boss.aoeRing = null; }
            if (this.boss.aoeRing2) { this.boss.aoeRing2.destroy(); this.boss.aoeRing2 = null; }
            this.boss.destroy();
            this.boss = null;
        }
        if (this.bossTimer) { this.bossTimer.destroy(); this.bossTimer = null; }
        if (this.defeatedText) { this.defeatedText.destroy(); this.defeatedText = null; }
        if (this.defeatedLoot) {
            this.defeatedLoot.forEach(t => { if (t && t.destroy) t.destroy(); });
            this.defeatedLoot = null;
        }
        if (this.enemies && this.enemies.getLength && this.enemies.getLength() > 0) {
            this.enemies.getChildren().forEach(e => {
                if (e.hpBg) e.hpBg.destroy();
                if (e.hpFill) e.hpFill.destroy();
            });
            this.enemies.clear(true, true);
        }
        if (this.enemies) { this.enemies.destroy(); this.enemies = null; }
        if (this.stumps && this.stumps.getLength && this.stumps.getLength() > 0) {
            this.stumps.getChildren().forEach(s => {
                if (s.hpBg) s.hpBg.destroy();
                if (s.hpFill) s.hpFill.destroy();
            });
            this.stumps.clear(true, true);
        }
        if (this.stumps) { this.stumps.destroy(); this.stumps = null; }
        if (this.exitPortal) { this.exitPortal.destroy(); this.exitPortal = null; }
        if (this.exitHint) { this.exitHint.destroy(); this.exitHint = null; }
        this.bossAlive = false;
    }

    /* ==========================================================
       ZONE: MINE (Dark Cave)
       ========================================================== */

    _setupMine() {
        this.cameras.main.setBackgroundColor('#0a0a0a');
        this.physics.world.setBounds(0, 0, GAME_WIDTH, FOREST_HEIGHT);
        this.cameras.main.setBounds(0, 0, GAME_WIDTH, FOREST_HEIGHT);

        this.mineBg = this.add.tileSprite(0, 0, GAME_WIDTH, FOREST_HEIGHT, 'mine_ground')
            .setOrigin(0, 0).setScale(1, FOREST_HEIGHT / 200).setDepth(0);

        this.mineRails = this.add.tileSprite(0, 0, GAME_WIDTH, FOREST_HEIGHT, 'mine_rails')
            .setOrigin(0, 0).setDepth(1).setAlpha(0.4);

        this.exitLadder = this.add.sprite(MINE_EXIT_POS.x, MINE_EXIT_POS.y, 'mine_ladder').setDepth(1);
        this.exitHint = this.add.text(MINE_EXIT_POS.x, MINE_EXIT_POS.y + 40, '', {
            fontSize: '11px', fill: '#f1c40f', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 2
        }).setOrigin(0.5).setDepth(12);

        this.mineBossPortal = this.add.sprite(MINE_BOSS_PORTAL_POS.x, MINE_BOSS_PORTAL_POS.y, 'mine_boss_portal').setDepth(2);
        this.mineBossPortalHint = this.add.text(MINE_BOSS_PORTAL_POS.x, MINE_BOSS_PORTAL_POS.y + 44, '', {
            fontSize: '11px', fill: '#bf77f6', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 2
        }).setOrigin(0.5).setDepth(12);

        this.player.x = MINE_RETURN_POS.x;
        this.player.y = MINE_RETURN_POS.y;
        this.player.body.setCollideWorldBounds(true);
        this.cameras.main.startFollow(this.player, true, 0.08, 0.08);
        this.cameras.main.setDeadzone(100, 80);

        this.enemies = this.physics.add.group();
        this.stumps = this.physics.add.group();
        this.mineRocks = this.physics.add.group();
        this.mineCrystals = this.physics.add.group();
        this.mineChests = this.physics.add.group();

        this._spawnMineEnemies();
        this._spawnMineRocks();
        this._spawnMineCrystals();
        this._spawnMineChests();
        this._spawnMineTorches();

        this.mineDarkness = this.add.image(400, 300, 'mine_darkness').setDepth(13).setAlpha(0.9).setScrollFactor(0);

        this.physics.add.overlap(this.player, this.enemies, (p, e) => {
            if (e.active && e.stats && !this.menuOpen && !this.transitioning) {
                this.takeDamage(e.stats.damage);
            }
        }, null, this);

        this.mineBossDefeated = false;
        this.mineBossAlive = false;

        this.zone = 'mine';
        this._spawnNPCs();
        this.hintText.setText('Q=quests | I=inventory | TAB=stats | T=talents | P=pause');
        startMusic();
    }

    _clearMine() {
        this.physics.world.colliders.destroy();
        if (this.fireballs) {
            this.fireballs.forEach(fb => { if (fb.glow) fb.glow.destroy(); fb.destroy(); });
            this.fireballs = [];
        }
        if (this.shieldActive) {
            this.shieldActive = false;
            this.shieldHP = 0;
            if (this.shieldVfx) { this.shieldVfx.destroy(); this.shieldVfx = null; }
        }
        if (this.enemies && this.enemies.getLength && this.enemies.getLength() > 0) {
            this.enemies.getChildren().forEach(e => {
                if (e.hpBg) e.hpBg.destroy();
                if (e.hpFill) e.hpFill.destroy();
            });
            this.enemies.clear(true, true);
        }
        if (this.enemies) { this.enemies.destroy(); this.enemies = null; }
        if (this.stumps && this.stumps.getLength && this.stumps.getLength() > 0) {
            this.stumps.getChildren().forEach(s => {
                if (s.hpBg) s.hpBg.destroy();
                if (s.hpFill) s.hpFill.destroy();
            });
            this.stumps.clear(true, true);
        }
        if (this.stumps) { this.stumps.destroy(); this.stumps = null; }
        if (this.mineRocks && this.mineRocks.getLength && this.mineRocks.getLength() > 0) {
            this.mineRocks.clear(true, true);
        }
        if (this.mineRocks) { this.mineRocks.destroy(); this.mineRocks = null; }
        if (this.mineCrystals && this.mineCrystals.getLength && this.mineCrystals.getLength() > 0) {
            this.mineCrystals.getChildren().forEach(cr => this.tweens.killTweensOf(cr));
            this.mineCrystals.clear(true, true);
        }
        if (this.mineCrystals) { this.mineCrystals.destroy(); this.mineCrystals = null; }
        if (this.mineChests && this.mineChests.getLength && this.mineChests.getLength() > 0) {
            this.mineChests.getChildren().forEach(ch => {
                if (ch.hintText) ch.hintText.destroy();
                if (ch.hpBg) ch.hpBg.destroy();
                if (ch.hpFill) ch.hpFill.destroy();
            });
            this.mineChests.clear(true, true);
        }
        if (this.mineChests) { this.mineChests.destroy(); this.mineChests = null; }
        if (this.mineBg) { this.mineBg.destroy(); this.mineBg = null; }
        if (this.mineRails) { this.mineRails.destroy(); this.mineRails = null; }
        if (this.exitLadder) { this.exitLadder.destroy(); this.exitLadder = null; }
        if (this.exitHint) { this.exitHint.destroy(); this.exitHint = null; }
        if (this.mineBossPortal) { this.mineBossPortal.destroy(); this.mineBossPortal = null; }
        if (this.mineBossPortalHint) { this.mineBossPortalHint.destroy(); this.mineBossPortalHint = null; }
        if (this.mineTorches) {
            this.mineTorches.forEach(t => {
                if (t.torch) t.torch.destroy();
                if (t.glow) t.glow.destroy();
            });
            this.mineTorches = null;
        }
        if (this.mineDarkness) { this.mineDarkness.destroy(); this.mineDarkness = null; }
        if (this.mineBoss) {
            if (this.mineBoss.hpBg) this.mineBoss.hpBg.destroy();
            if (this.mineBoss.hpFill) this.mineBoss.hpFill.destroy();
            if (this.mineBossNameText) this.mineBossNameText.destroy();
            if (this.mineBoss.aoeRing) { this.mineBoss.aoeRing.destroy(); this.mineBoss.aoeRing = null; }
            if (this.mineBoss.aoeRing2) { this.mineBoss.aoeRing2.destroy(); this.mineBoss.aoeRing2 = null; }
            this.mineBoss.destroy();
            this.mineBoss = null;
        }
        if (this.mineBossTimer) { this.mineBossTimer.destroy(); this.mineBossTimer = null; }
    }

    _spawnMineEnemies() {
        for (let i = 0; i < MINE_ENEMY_COUNT; i++) {
            const t = MINE_ENEMY_TYPES[i % MINE_ENEMY_TYPES.length];
            this._makeMineEnemy(t, 80 + Math.random() * 640, 200 + Math.random() * 500);
        }
    }

    _makeMineEnemy(t, x, y) {
        const e = this.add.sprite(x, y, t.key).setDepth(5);
        this.physics.add.existing(e, false);
        e.body.setSize(t.bw, t.bh);
        e.body.setCollideWorldBounds(true);

        e.stats = {
            key: t.key, name: t.name,
            hp: Math.floor(t.hp * this.diffMulti.hp),
            maxHp: Math.floor(t.hp * this.diffMulti.hp),
            damage: Math.floor(t.dmg * this.diffMulti.dmg),
            exp: Math.floor(t.exp * this.diffMulti.exp),
            bw: t.bw, bh: t.bh,
            wTimer: 0, wDir: 0
        };

        const hw = t.bw + 4;
        e.hpBg = this.add.rectangle(x, y - t.bh / 2 - 8, hw, 3, 0x333333).setOrigin(0.5).setDepth(11);
        e.hpFill = this.add.rectangle(x, y - t.bh / 2 - 8, hw, 3, 0xe74c3c).setOrigin(0.5).setDepth(11);
        this.enemies.add(e);
        return e;
    }

    _spawnMineRocks() {
        for (let i = 0; i < MINE_ROCK_COUNT; i++) {
            const r = this.add.sprite(60 + Math.random() * 680, 150 + Math.random() * 550, 'mine_rock').setDepth(4);
            this.physics.add.existing(r, false);
            r.body.setSize(28, 22);
            r.body.setImmovable(true);
            this.mineRocks.add(r);
        }
    }

    _spawnMineCrystals() {
        for (let i = 0; i < MINE_CRYSTAL_COUNT; i++) {
            const cr = this.add.sprite(60 + Math.random() * 680, 150 + Math.random() * 550, 'mine_crystal').setDepth(3);
            cr.setAlpha(0.6 + Math.random() * 0.4);
            this.tweens.add({
                targets: cr, alpha: 0.3, duration: 1500 + Math.random() * 2000,
                yoyo: true, repeat: -1, ease: 'Sine.easeInOut'
            });
            this.mineCrystals.add(cr);
        }
    }

    _spawnMineChests() {
        for (let i = 0; i < MINE_CHEST_COUNT; i++) {
            const cx = 100 + Math.random() * 600;
            const cy = 250 + Math.random() * 400;
            this._createMineChest(cx, cy);
        }
    }

    _createMineChest(x, y) {
        const ch = this.add.sprite(x, y, 'mine_chest').setDepth(6);
        this.physics.add.existing(ch, false);
        ch.body.setSize(24, 18);
        ch.body.setCollideWorldBounds(true);
        ch.stats = { hp: 50, maxHp: 50 };
        ch.hpBg = this.add.rectangle(x, y - 18, 28, 3, 0x333333).setOrigin(0.5).setDepth(11);
        ch.hpFill = this.add.rectangle(x, y - 18, 28, 3, 0xf39c12).setOrigin(0.5).setDepth(11);
        ch.loot = [];
        const count = 1 + Math.floor(Math.random() * 2);
        for (let i = 0; i < count; i++) {
            if (Math.random() < MINE_CHEST_DROP_CHANCE) {
                ch.loot.push(rollEquip());
            }
        }
        ch.hintText = this.add.text(x, y - 22, '', {
            fontSize: '10px', fill: '#f1c40f', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 2
        }).setOrigin(0.5).setDepth(12);
        ch.broken = false;
        this.mineChests.add(ch);
        return ch;
    }

    hitChest(ch, damage) {
        if (ch.broken) return;
        ch.stats.hp -= damage;
        ch.setTint(0xffffff);
        this.tweens.add({
            targets: ch, scaleX: 1.15, scaleY: 1.15, duration: 60, yoyo: true,
            onComplete: () => {
                if (ch.active) {
                    ch.clearTint();
                    ch.setScale(1);
                }
            }
        });
        this.floatingText(ch.x, ch.y - 20, '-' + damage, '#f39c12');
        if (ch.stats.hp <= 0) {
            this.breakChest(ch);
        } else {
            ch.hpFill.width = ch.hpBg.width * (ch.stats.hp / ch.stats.maxHp);
        }
    }

    breakChest(ch) {
        if (ch.broken) return;
        ch.broken = true;
        ch.body.enable = false;
        ch.setTexture(ch.isCaveChest ? CAVE_CHEST_OPEN_KEY : 'mine_chest_broken');
        ch.hpBg.destroy();
        ch.hpFill.destroy();
        playBreak();
        onCollect('mine_chest');
        this._updateQuestIcons();

        const hasLoot = ch.loot.length > 0;
        if (hasLoot) {
            ch.loot.forEach((item, i) => {
                if (this.addEquip(item)) {
                    const rc = '#' + RARITY_COLORS[item.rarity].toString(16).padStart(6, '0');
                    this.floatingText(ch.x + (i * 20 - 10), ch.y - 35, '+' + item.name, rc);
                } else {
                    this.floatingText(ch.x, ch.y - 35, 'Bag full!', '#e74c3c');
                }
            });
        } else {
            const matCount = 1 + Math.floor(Math.random() * 2);
            for (let i = 0; i < matCount; i++) {
                const item = rollMaterial(this.zone);
                if (this.addMaterial(item)) {
                    const rc = '#' + RARITY_COLORS[item.rarity].toString(16).padStart(6, '0');
                    this.floatingText(ch.x + (i * 18 - 9), ch.y - 35, '+' + item.name, rc);
                }
            }
        }

        this.time.delayedCall(12000, () => {
            if (ch.active && !ch.isCaveChest) {
                ch.setTexture('mine_chest');
                ch.broken = false;
                ch.body.enable = true;
                ch.stats.hp = ch.stats.maxHp;
                ch.hpBg = this.add.rectangle(ch.x, ch.y - 18, 28, 3, 0x333333).setOrigin(0.5).setDepth(11);
                ch.hpFill = this.add.rectangle(ch.x, ch.y - 18, 28, 3, 0xf39c12).setOrigin(0.5).setDepth(11);
                ch.loot = [];
                const cnt = 1 + Math.floor(Math.random() * 2);
                for (let i = 0; i < cnt; i++) {
                    if (Math.random() < MINE_CHEST_DROP_CHANCE) {
                        ch.loot.push(rollEquip());
                    }
                }
            }
        });
    }

    _spawnMineTorches() {
        this.mineTorches = [];
        const positions = [
            { x: 80, y: 200 }, { x: 720, y: 200 },
            { x: 80, y: 400 }, { x: 720, y: 400 },
            { x: 80, y: 600 }, { x: 720, y: 600 },
            { x: 400, y: 300 }, { x: 200, y: 500 },
            { x: 600, y: 500 }, { x: 400, y: 700 }
        ];
        positions.forEach(p => {
            const torch = this.add.sprite(p.x, p.y, 'torch').setDepth(14);
            const glow = this.add.image(p.x, p.y - 4, 'torch_glow').setDepth(2).setAlpha(0.8);
            this.tweens.add({
                targets: [torch, glow],
                alpha: { from: 0.7, to: 1 },
                duration: 400 + Math.random() * 300,
                yoyo: true,
                repeat: -1,
                ease: 'Sine.easeInOut',
                delay: Math.random() * 500
            });
            this.tweens.add({
                targets: glow,
                scaleX: { from: 0.9, to: 1.15 },
                scaleY: { from: 0.9, to: 1.15 },
                duration: 600 + Math.random() * 400,
                yoyo: true,
                repeat: -1,
                ease: 'Sine.easeInOut',
                delay: Math.random() * 300
            });
            this.mineTorches.push({ torch, glow });
        });
    }

    _checkMineExitProximity() {
        if (this.zone !== 'mine' || this.transitioning || this.menuOpen) return;
        const dist = Phaser.Math.Distance.Between(
            this.player.x, this.player.y, MINE_EXIT_POS.x, MINE_EXIT_POS.y
        );
        if (dist < 50) {
            this.exitHint.setText('SPACE to exit');
        } else {
            this.exitHint.setText('');
        }

        if (this.mineBossPortal && !this.mineBossDefeated) {
            const bdist = Phaser.Math.Distance.Between(
                this.player.x, this.player.y, MINE_BOSS_PORTAL_POS.x, MINE_BOSS_PORTAL_POS.y
            );
            if (bdist < 50) {
                this.mineBossPortalHint.setText('SPACE to enter boss room');
            } else {
                this.mineBossPortalHint.setText('');
            }
        } else if (this.mineBossPortalHint) {
            this.mineBossPortalHint.setText('');
        }

        if (this.mineChests) {
            this.mineChests.getChildren().forEach(ch => {
                if (!ch.active || ch.broken) return;
                const cdist = Phaser.Math.Distance.Between(
                    this.player.x, this.player.y, ch.x, ch.y
                );
                if (cdist < 55) {
                    ch.hintText.setText('Attack!');
                } else {
                    ch.hintText.setText('');
                }
            });
        }
    }

    _exitMine() {
        if (this.transitioning || this.menuOpen) return;
        if (this.zone !== 'mine') return;
        const dist = Phaser.Math.Distance.Between(
            this.player.x, this.player.y, MINE_EXIT_POS.x, MINE_EXIT_POS.y
        );
        if (dist >= 50) return;

        this.transitioning = true;
        this.exitHint.setText('');
        playPortal();
        this.cameras.main.fadeOut(500, 0, 0, 0);
        this.time.delayedCall(500, () => {
            this._clearMine();
            this._setupForest();
            this.cameras.main.fadeIn(500, 0, 0, 0);
            this.transitioning = false;
        });
    }

    _enterMineBossArena() {
        if (this.transitioning || this.menuOpen) return;
        if (this.zone !== 'mine') return;
        if (this.mineBossDefeated) return;

        this.transitioning = true;
        this.mineBossPortalHint.setText('');
        playPortal();
        this.cameras.main.fadeOut(500, 0, 0, 0);
        this.time.delayedCall(500, () => {
            this._clearMine();
            this._setupMineBossArena();
            this.cameras.main.fadeIn(500, 0, 0, 0);
            this.transitioning = false;
        });
    }

    _setupMineBossArena() {
        this.cameras.main.setBackgroundColor('#0a0510');
        this.physics.world.setBounds(0, 0, GAME_WIDTH, GAME_HEIGHT);
        this.cameras.main.setBounds(0, 0, GAME_WIDTH, GAME_HEIGHT);

        this.add.image(400, 300, 'boss_ground').setDepth(0);

        this.mineArenaExit = this.add.sprite(ARENA_EXIT_POS.x, ARENA_EXIT_POS.y, 'mine_ladder').setDepth(1);
        this.mineArenaExitHint = this.add.text(ARENA_EXIT_POS.x, ARENA_EXIT_POS.y + 50, '', {
            fontSize: '11px', fill: '#bf77f6', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 2
        }).setOrigin(0.5).setDepth(12);

        this.player.x = 400;
        this.player.y = 500;
        this.player.body.setCollideWorldBounds(true);
        this.cameras.main.stopFollow();

        this.mineBossDefeated = false;
        this.mineBossAlive = false;

        this.enemies = this.physics.add.group();
        this.stumps = this.physics.add.group();
        this._spawnMineBoss();

        this.physics.add.overlap(this.player, this.enemies, (p, e) => {
            if (e.active && e.stats && !this.menuOpen && !this.transitioning) {
                this.takeDamage(e.stats.damage);
            }
        }, null, this);

        this.zone = 'mine_boss';
        this.hintText.setText('Defeat the Skeleton Lord! | I=inventory | TAB=stats | P=pause');
        startMusic();
    }

    _clearMineBossArena() {
        this.physics.world.colliders.destroy();
        if (this.mineBoss) {
            if (this.mineBoss.hpBg) this.mineBoss.hpBg.destroy();
            if (this.mineBoss.hpFill) this.mineBoss.hpFill.destroy();
            if (this.mineBossNameText) this.mineBossNameText.destroy();
            if (this.mineBoss.aoeRing) { this.mineBoss.aoeRing.destroy(); this.mineBoss.aoeRing = null; }
            if (this.mineBoss.aoeRing2) { this.mineBoss.aoeRing2.destroy(); this.mineBoss.aoeRing2 = null; }
            this.mineBoss.destroy();
            this.mineBoss = null;
        }
        if (this.bossTimer) { this.bossTimer.destroy(); this.bossTimer = null; }
        if (this.defeatedText) { this.defeatedText.destroy(); this.defeatedText = null; }
        if (this.defeatedLoot) {
            this.defeatedLoot.forEach(t => { if (t && t.destroy) t.destroy(); });
            this.defeatedLoot = null;
        }
        if (this.enemies && this.enemies.getLength && this.enemies.getLength() > 0) {
            this.enemies.getChildren().forEach(e => {
                if (e.hpBg) e.hpBg.destroy();
                if (e.hpFill) e.hpFill.destroy();
            });
            this.enemies.clear(true, true);
        }
        if (this.enemies) { this.enemies.destroy(); this.enemies = null; }
        if (this.stumps && this.stumps.getLength && this.stumps.getLength() > 0) this.stumps.clear(true, true);
        if (this.stumps) { this.stumps.destroy(); this.stumps = null; }
        if (this.mineArenaExit) { this.mineArenaExit.destroy(); this.mineArenaExit = null; }
        if (this.mineArenaExitHint) { this.mineArenaExitHint.destroy(); this.mineArenaExitHint = null; }
        this.mineBossAlive = false;
    }

    _exitMineBossArena() {
        if (this.transitioning || this.menuOpen) return;
        if (this.zone !== 'mine_boss') return;
        const dist = Phaser.Math.Distance.Between(
            this.player.x, this.player.y, ARENA_EXIT_POS.x, ARENA_EXIT_POS.y
        );
        if (dist >= 50) return;

        this.transitioning = true;
        if (this.mineArenaExitHint) this.mineArenaExitHint.setText('');
        playPortal();
        this.cameras.main.fadeOut(500, 0, 0, 0);
        this.time.delayedCall(500, () => {
            this._clearMineBossArena();
            this._setupMine();
            this.cameras.main.fadeIn(500, 0, 0, 0);
            this.transitioning = false;
        });
    }

    _checkMineBossArenaExitProximity() {
        if (this.zone !== 'mine_boss' || this.transitioning || this.menuOpen) return;
        const dist = Phaser.Math.Distance.Between(
            this.player.x, this.player.y, ARENA_EXIT_POS.x, ARENA_EXIT_POS.y
        );
        if (dist < 50) {
            if (this.mineArenaExitHint) this.mineArenaExitHint.setText('SPACE to exit');
        } else {
            if (this.mineArenaExitHint) this.mineArenaExitHint.setText('');
        }
    }

    _spawnMineBoss() {
        const bt = MINE_BOSS_TYPE;
        const hp = Math.floor(bt.hp[this.difficulty] || bt.hp.Normal);
        const dmg = Math.floor(bt.dmg[this.difficulty] || bt.dmg.Normal);
        const exp = Math.floor(bt.exp[this.difficulty] || bt.exp.Normal);
        const spd = bt.speeds[this.difficulty] || bt.speeds.Normal;

        this.mineBoss = this.add.sprite(400, 200, 'skeleton_lord_walk').setDepth(5);
        this.physics.add.existing(this.mineBoss, false);
        this.mineBoss.body.setSize(bt.bw, bt.bh);
        this.mineBoss.body.setCollideWorldBounds(true);
        this.mineBoss.play('skeleton_lord_walk');

        this.mineBoss.stats = {
            name: bt.name,
            hp: hp, maxHp: hp,
            damage: dmg, exp: exp,
            speed: spd,
            bw: bt.bw, bh: bt.bh,
            aoeTimer: 0, aoeInterval: bt.aoeInterval,
            aoeDmgMul: bt.aoeDmgMul, aoeRadius: bt.aoeRadius
        };

        const hw = bt.bw + 20;
        this.mineBoss.hpBg = this.add.rectangle(400, 100, hw, 5, 0x333333).setOrigin(0.5).setDepth(15);
        this.mineBoss.hpFill = this.add.rectangle(400, 100, hw, 5, 0x9b59b6).setOrigin(0.5).setDepth(15);

        this.mineBossNameText = this.add.text(400, 85, bt.name, {
            fontSize: '12px', fill: '#bf77f6', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 2
        }).setOrigin(0.5).setDepth(15);

        this.mineBossAlive = true;
        this.enemies.add(this.mineBoss);
    }

    _updateMineBoss() {
        if (!this.mineBossAlive || !this.mineBoss || !this.mineBoss.active) return;
        const b = this.mineBoss;
        const s = b.stats;

        b.hpBg.x = 400;
        b.hpBg.y = 100;
        b.hpFill.x = 400;
        b.hpFill.y = 100;

        if (this.menuOpen || this.transitioning) {
            b.body.setVelocity(0);
            return;
        }

        const dx = this.player.x - b.x;
        const dy = this.player.y - b.y;
        const dist = Math.sqrt(dx * dx + dy * dy);

        if (dist > 30) {
            const nx = dx / dist;
            const ny = dy / dist;
            b.body.setVelocity(nx * s.speed, ny * s.speed);
            if (!b.anims.isPlaying || b.anims.currentAnim.key !== 'skeleton_lord_walk') {
                b.play('skeleton_lord_walk');
            }
            b.setFlipX(dx < 0);
        } else {
            b.body.setVelocity(0);
            b.stop();
            b.setFrame(0);
        }

        s.aoeTimer += this.game.loop.delta;
        if (s.aoeTimer >= s.aoeInterval) {
            s.aoeTimer = 0;
            this._mineBossAoE(b);
        }
    }

    _mineBossAoE(boss) {
        const aoeDmg = Math.floor(boss.stats.damage * boss.stats.aoeDmgMul);
        const radius = boss.stats.aoeRadius;
        playBossAoE();

        const ring = this.add.sprite(boss.x, boss.y, 'skeleton_lord_aoe')
            .setAlpha(0.9)
            .setScale(0.3);
        this.tweens.add({
            targets: ring, scaleX: 1.8, scaleY: 1.8, alpha: 0, duration: 600,
            onComplete: () => ring.destroy()
        });

        const ring2 = this.add.sprite(boss.x, boss.y, 'skeleton_lord_aoe')
            .setAlpha(0.5)
            .setScale(0.1);
        this.tweens.add({
            targets: ring2, scaleX: 1.2, scaleY: 1.2, alpha: 0, duration: 500, delay: 100,
            onComplete: () => ring2.destroy()
        });

        this.time.delayedCall(350, () => {
            const dist = Phaser.Math.Distance.Between(
                this.player.x, this.player.y, boss.x, boss.y
            );
            if (dist < radius) {
                this.takeDamage(aoeDmg);
                const pushX = this.player.x - boss.x;
                const pushY = this.player.y - boss.y;
                const pushDist = Math.sqrt(pushX * pushX + pushY * pushY) || 1;
                this.player.x += (pushX / pushDist) * 45;
                this.player.y += (pushY / pushDist) * 45;
            }
        });
    }

    killMineBoss() {
        const b = this.mineBoss;
        const exp = b.stats.exp;
        const expBonus = 1 + (this.accountEffects ? (this.accountEffects.expPercent || 0) / 100 : 0);
        this.playerExp += exp;
        this.accountExp += Math.floor(exp * expBonus);
        this.kills++;
        this.mineBossAlive = false;
        this.mineBossDefeated = true;
        playBossDeath();
        recordKill('skeleton_lord');
        recordSoulCollect('skeleton_lord');
        onKill('skeleton_lord');
        this._updateQuestIcons();

        b.body.setVelocity(0);
        b.setTint(0xff0000);
        this.tweens.add({
            targets: b, alpha: 0, scaleX: 1.5, scaleY: 1.5, duration: 800,
            onComplete: () => {
                b.hpBg.destroy();
                b.hpFill.destroy();
                b.destroy();
                this.mineBoss = null;
            }
        });

        if (b.aoeRing) { b.aoeRing.destroy(); b.aoeRing = null; }
        if (b.aoeRing2) { b.aoeRing2.destroy(); b.aoeRing2 = null; }
        if (this.mineBossNameText) this.mineBossNameText.destroy();

        this.floatingText(400, 200, '+' + exp + ' EXP', '#f1c40f');

        this.defeatedText = this.add.text(400, 250, 'SKELETON LORD DEFEATED!', {
            fontSize: '28px', fill: '#bf77f6', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 4
        }).setOrigin(0.5).setScrollFactor(0);
        this.tweens.add({
            targets: this.defeatedText, alpha: 0, duration: 5000,
            onComplete: () => { if (this.defeatedText) this.defeatedText.destroy(); this.defeatedText = null; }
        });

        this.defeatedLoot = [];
        const lootItems = [];
        if (Math.random() < BOSS_DROP_CHANCE) {
            const item = rollEquip();
            if (this.addEquip(item)) {
                lootItems.push(item);
                playLoot();
            }
        }
        if (Math.random() < 0.6) {
            const item2 = rollEquip();
            if (this.addEquip(item2)) {
                lootItems.push(item2);
                playLoot();
            }
        }

        // Account equipment drop from mine boss
        if (Math.random() < BOSS_DROP_CHANCE) {
            const accItem = rollAccountEquip();
            if (this.addAccountEquip(accItem)) {
                lootItems.push({ ...accItem, name: accItem.name + ' [ACCOUNT]' });
                playLoot();
            }
        }

        // Secret Key drop (guaranteed on Hard+)
        if (!this.hasSecretKey && DIFF_MULT[this.difficulty] && DIFF_MULT[this.difficulty].hp > 1) {
            this.hasSecretKey = true;
            const keyItem = { ...SECRET_KEY_ITEM };
            lootItems.push(keyItem);
            playLoot();
            this.floatingText(400, 280, SECRET_KEY_ITEM.name + ' obtained!', '#f1c40f');
        }

        lootItems.forEach((item, i) => {
            const rc = '#' + RARITY_COLORS[item.rarity].toString(16).padStart(6, '0');
            const lt = this.add.text(400, 300 + i * 24, '+' + item.name, {
                fontSize: '16px', fill: rc, fontFamily: 'Arial', fontStyle: 'bold',
                stroke: '#000', strokeThickness: 2
            }).setOrigin(0.5).setScrollFactor(0);
            this.defeatedLoot.push(lt);
            this.tweens.add({
                targets: lt, alpha: 0, duration: 5000,
                onComplete: () => { if (lt.active) lt.destroy(); }
            });
        });

        if (lootItems.length === 0) {
            const noLoot = this.add.text(400, 300, 'No drops...', {
                fontSize: '14px', fill: '#95a5a6', fontFamily: 'Arial',
                stroke: '#000', strokeThickness: 2
            }).setOrigin(0.5).setScrollFactor(0);
            this.defeatedLoot.push(noLoot);
            this.tweens.add({
                targets: noLoot, alpha: 0, duration: 5000,
                onComplete: () => { if (noLoot.active) noLoot.destroy(); }
            });
        }

        this.checkLevelUp();
        this._checkAccountLevelUp();
        this.updateUI();
    }

    /* ===== CAVE ZONE ===== */

    _setupCave() {
        const caveOffsetX = (GAME_WIDTH - CAVE_WIDTH) / 2;
        this.cameras.main.setBackgroundColor('#0d0d0d');
        this.physics.world.setBounds(caveOffsetX, 0, CAVE_WIDTH, CAVE_HEIGHT);
        this.cameras.main.setBounds(caveOffsetX, 0, CAVE_WIDTH, CAVE_HEIGHT);

        this.caveBg = this.add.tileSprite(caveOffsetX, 0, CAVE_WIDTH, CAVE_HEIGHT, 'cave_ground')
            .setOrigin(0, 0).setDepth(0);

        this.caveOffsetX = caveOffsetX;
        this.player.x = caveOffsetX + CAVE_WIDTH / 2;
        this.player.y = 50;
        this.player.body.setCollideWorldBounds(true);
        this.cameras.main.startFollow(this.player, true, 0.08, 0.08);
        this.cameras.main.setDeadzone(50, 40);

        this.enemies = this.physics.add.group();
        this.stumps = this.physics.add.group();
        this.caveChests = this.physics.add.group();
        this.caveTorches = [];

        this._spawnCaveEnemies();
        this._spawnCaveChests();
        this._spawnCaveTorches();

        this.caveDarkness = this.add.image(caveOffsetX + CAVE_WIDTH / 2, 300, 'mine_darkness')
            .setScale(CAVE_WIDTH / 800, CAVE_HEIGHT / 600)
            .setDepth(13).setAlpha(0.92).setScrollFactor(0);

        this.caveBossDefeated = false;
        this.caveBossAlive = false;
        this.caveBossSpawned = false;
        this.caveSmallBats = this.physics.add.group();

        this.physics.add.overlap(this.player, this.enemies, (p, e) => {
            if (e.active && e.stats && !this.menuOpen && !this.transitioning) {
                this.takeDamage(e.stats.damage);
            }
        }, null, this);

        this.physics.add.overlap(this.player, this.caveSmallBats, (p, e) => {
            if (e.active && e.stats && !this.menuOpen && !this.transitioning) {
                this.takeDamage(e.stats.damage);
            }
        }, null, this);

        this.zone = 'cave';
        this._spawnNPCs();
        this.hintText.setText('Q=quests | I=inventory | TAB=stats | T=talents | P=pause');
        startMusic();
    }

    _clearCave() {
        this.physics.world.colliders.destroy();
        if (this.fireballs) {
            this.fireballs.forEach(fb => { if (fb.glow) fb.glow.destroy(); fb.destroy(); });
            this.fireballs = [];
        }
        if (this.shieldActive) {
            this.shieldActive = false;
            this.shieldHP = 0;
            if (this.shieldVfx) { this.shieldVfx.destroy(); this.shieldVfx = null; }
        }
        if (this.enemies && this.enemies.getLength && this.enemies.getLength() > 0) {
            this.enemies.getChildren().forEach(e => {
                if (e.hpBg) e.hpBg.destroy();
                if (e.hpFill) e.hpFill.destroy();
                if (e.nameText) e.nameText.destroy();
                if (e.aoeRing) { e.aoeRing.destroy(); }
                if (e.aoeRing2) { e.aoeRing2.destroy(); }
            });
            this.enemies.clear(true, true);
        }
        if (this.enemies) { this.enemies.destroy(); this.enemies = null; }
        if (this.stumps && this.stumps.getLength && this.stumps.getLength() > 0) this.stumps.clear(true, true);
        if (this.stumps) { this.stumps.destroy(); this.stumps = null; }
        if (this.caveChests && this.caveChests.getLength && this.caveChests.getLength() > 0) {
            this.caveChests.getChildren().forEach(ch => {
                if (ch.hintText) ch.hintText.destroy();
                if (ch.hpBg) ch.hpBg.destroy();
                if (ch.hpFill) ch.hpFill.destroy();
            });
            this.caveChests.clear(true, true);
        }
        if (this.caveChests) { this.caveChests.destroy(); this.caveChests = null; }
        if (this.caveSmallBats && this.caveSmallBats.getLength && this.caveSmallBats.getLength() > 0) {
            this.caveSmallBats.getChildren().forEach(e => {
                if (e.hpBg) e.hpBg.destroy();
                if (e.hpFill) e.hpFill.destroy();
            });
            this.caveSmallBats.clear(true, true);
        }
        if (this.caveSmallBats) { this.caveSmallBats.destroy(); this.caveSmallBats = null; }
        if (this.caveBg) { this.caveBg.destroy(); this.caveBg = null; }
        if (this.caveDarkness) { this.caveDarkness.destroy(); this.caveDarkness = null; }
        if (this.caveTorches) {
            this.caveTorches.forEach(t => {
                if (t.torch) t.torch.destroy();
                if (t.glow) t.glow.destroy();
            });
            this.caveTorches = null;
        }
        if (this.caveStairs) { this.caveStairs.destroy(); this.caveStairs = null; }
        if (this.caveStairsHint) { this.caveStairsHint.destroy(); this.caveStairsHint = null; }
        if (this.caveBoss) {
            if (this.caveBoss.hpBg) this.caveBoss.hpBg.destroy();
            if (this.caveBoss.hpFill) this.caveBoss.hpFill.destroy();
            if (this.caveBossNameText) this.caveBossNameText.destroy();
            if (this.caveBoss.aoeRing) { this.caveBoss.aoeRing.destroy(); }
            if (this.caveBoss.aoeRing2) { this.caveBoss.aoeRing2.destroy(); }
            this.caveBoss.destroy();
            this.caveBoss = null;
        }
        if (this.caveBossTimer) { this.caveBossTimer.destroy(); this.caveBossTimer = null; }
        if (this.defeatedText) { this.defeatedText.destroy(); this.defeatedText = null; }
        if (this.defeatedLoot) {
            this.defeatedLoot.forEach(t => { if (t && t.destroy) t.destroy(); });
            this.defeatedLoot = null;
        }
    }

    /* ===== CAVE SPAWNING ===== */

    _spawnCaveEnemies() {
        const ox = this.caveOffsetX;
        const pairs = [
            { tank: CAVE_ENEMY_TYPES[2], dps: CAVE_ENEMY_TYPES[0] },
            { tank: CAVE_ENEMY_TYPES[2], dps: CAVE_ENEMY_TYPES[0] },
            { tank: CAVE_ENEMY_TYPES[2], dps: CAVE_ENEMY_TYPES[0] },
            { tank: CAVE_ENEMY_TYPES[2], dps: CAVE_ENEMY_TYPES[0] },
            { tank: CAVE_ENEMY_TYPES[3], dps: CAVE_ENEMY_TYPES[1] },
            { tank: CAVE_ENEMY_TYPES[3], dps: CAVE_ENEMY_TYPES[1] },
            { tank: CAVE_ENEMY_TYPES[3], dps: CAVE_ENEMY_TYPES[1] },
            { tank: CAVE_ENEMY_TYPES[3], dps: CAVE_ENEMY_TYPES[1] },
            { tank: CAVE_ENEMY_TYPES[2], dps: CAVE_ENEMY_TYPES[1] },
            { tank: CAVE_ENEMY_TYPES[2], dps: CAVE_ENEMY_TYPES[1] }
        ];

        for (let i = 0; i < pairs.length; i++) {
            const y = 100 + (i * 105);
            const xTank = ox + 60 + Math.random() * (CAVE_WIDTH - 120);
            const xDps = xTank + 30 + Math.random() * 40;
            this._makeCaveEnemy(pairs[i].tank, xTank, y);
            this._makeCaveEnemy(pairs[i].dps, xDps, y + 15);
        }
    }

    _makeCaveEnemy(t, x, y) {
        const animKey = t.key === 'cave_spider' ? 'cave_spider_walk_anim' :
                        t.key === 'cave_bat' ? 'cave_bat_walk_anim' :
                        t.key === 'stone_golem' ? 'stone_golem_walk_anim' :
                        'earth_worm_walk_anim';
        const walkTex = t.key === 'cave_spider' ? 'cave_spider_walk' :
                        t.key === 'cave_bat' ? 'cave_bat_walk' :
                        t.key === 'stone_golem' ? 'stone_golem_walk' :
                        'earth_worm_walk';
        const e = this.add.sprite(x, y, walkTex).setDepth(5);
        this.physics.add.existing(e, false);
        e.body.setSize(t.bw, t.bh);
        e.body.setCollideWorldBounds(true);
        e.play(animKey);

        e.stats = {
            key: t.key, name: t.name,
            hp: Math.floor(t.hp * this.diffMulti.hp),
            maxHp: Math.floor(t.hp * this.diffMulti.hp),
            damage: Math.floor(t.dmg * this.diffMulti.dmg),
            exp: Math.floor(t.exp * this.diffMulti.exp),
            bw: t.bw, bh: t.bh,
            wTimer: 0, wDir: 0
        };

        const hw = t.bw + 4;
        e.hpBg = this.add.rectangle(x, y - t.bh / 2 - 8, hw, 3, 0x333333).setOrigin(0.5).setDepth(11);
        e.hpFill = this.add.rectangle(x, y - t.bh / 2 - 8, hw, 3, 0xe74c3c).setOrigin(0.5).setDepth(11);
        this.enemies.add(e);
        return e;
    }

    _spawnCaveChests() {
        const ox = this.caveOffsetX;
        for (let i = 0; i < CAVE_CHEST_COUNT; i++) {
            const cy = 120 + (i * 108);
            const cx = ox + 40 + Math.random() * (CAVE_WIDTH - 80);
            this._createCaveChest(cx, cy);
        }
    }

    _createCaveChest(x, y) {
        const ch = this.add.sprite(x, y, CAVE_CHEST_CLOSED_KEY).setDepth(6);
        this.physics.add.existing(ch, false);
        ch.body.setSize(CAVE_CHEST_W, CAVE_CHEST_H);
        ch.body.setCollideWorldBounds(true);
        ch.stats = { hp: 50, maxHp: 50 };
        ch.hpBg = this.add.rectangle(x, y - 14, CAVE_CHEST_W + 4, 3, 0x333333).setOrigin(0.5).setDepth(11);
        ch.hpFill = this.add.rectangle(x, y - 14, CAVE_CHEST_W + 4, 3, 0xf39c12).setOrigin(0.5).setDepth(11);
        ch.loot = [];
        const count = 1 + Math.floor(Math.random() * 2);
        for (let i = 0; i < count; i++) {
            if (Math.random() < CAVE_CHEST_DROP_CHANCE) {
                ch.loot.push(rollEquip());
            }
        }
        ch.hintText = this.add.text(x, y - 18, '', {
            fontSize: '10px', fill: '#f1c40f', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 2
        }).setOrigin(0.5).setDepth(12);
        ch.broken = false;
        ch.isCaveChest = true;
        this.caveChests.add(ch);
        return ch;
    }

    _spawnCaveTorches() {
        this.caveTorches = [];
        const ox = this.caveOffsetX;
        const positions = [
            { x: ox + 30, y: 100 }, { x: ox + CAVE_WIDTH - 30, y: 100 },
            { x: ox + 30, y: 300 }, { x: ox + CAVE_WIDTH - 30, y: 300 },
            { x: ox + 30, y: 500 }, { x: ox + CAVE_WIDTH - 30, y: 500 },
            { x: ox + 30, y: 700 }, { x: ox + CAVE_WIDTH - 30, y: 700 },
            { x: ox + 30, y: 900 }, { x: ox + CAVE_WIDTH - 30, y: 900 },
            { x: ox + CAVE_WIDTH / 2, y: 200 }, { x: ox + CAVE_WIDTH / 2, y: 600 },
            { x: ox + CAVE_WIDTH / 2, y: 1000 }
        ];
        positions.forEach(p => {
            const torch = this.add.sprite(p.x, p.y, 'torch').setDepth(14);
            const glow = this.add.image(p.x, p.y - 4, 'torch_glow').setDepth(2).setAlpha(0.8);
            this.tweens.add({
                targets: [torch, glow], alpha: { from: 0.6, to: 1 },
                duration: 400 + Math.random() * 300, yoyo: true, repeat: -1,
                ease: 'Sine.easeInOut', delay: Math.random() * 500
            });
            this.tweens.add({
                targets: glow, scaleX: { from: 0.8, to: 1.2 }, scaleY: { from: 0.8, to: 1.2 },
                duration: 600 + Math.random() * 400, yoyo: true, repeat: -1,
                ease: 'Sine.easeInOut', delay: Math.random() * 300
            });
            this.caveTorches.push({ torch, glow });
        });
    }

    _checkCaveProximity() {
        if (this.zone !== 'cave' || this.transitioning || this.menuOpen) return;

        if (this.caveChests) {
            this.caveChests.getChildren().forEach(ch => {
                if (!ch.active || ch.broken) return;
                const cdist = Phaser.Math.Distance.Between(
                    this.player.x, this.player.y, ch.x, ch.y
                );
                ch.hintText.setText(cdist < 45 ? 'Attack!' : '');
            });
        }

        if (this.caveStairs && this.caveBossDefeated) {
            const sdist = Phaser.Math.Distance.Between(
                this.player.x, this.player.y, this.caveStairs.x, this.caveStairs.y
            );
            if (this.caveStairsHint) {
                this.caveStairsHint.setText(sdist < 50 ? 'SPACE to enter Village' : '');
            }
        }
    }

    _enterCaveVillage() {
        if (this.transitioning || this.menuOpen) return;
        if (this.zone !== 'cave' || !this.caveBossDefeated) return;
        if (!this.caveStairs) return;
        const dist = Phaser.Math.Distance.Between(
            this.player.x, this.player.y, this.caveStairs.x, this.caveStairs.y
        );
        if (dist >= 50) return;

        this.transitioning = true;
        if (this.caveStairsHint) this.caveStairsHint.setText('');
        playPortal();
        this.cameras.main.fadeOut(800, 0, 0, 0);
        this.time.delayedCall(800, () => {
            this._clearCave();
            this._setupVillage();
            this.cameras.main.fadeIn(500, 0, 0, 0);
            this.transitioning = false;
        });
    }

    /* ===== CAVE MOB AI ===== */

    _updateCaveMobs() {
        if (this.zone !== 'cave' || this.menuOpen || this.transitioning) return;
        if (!this.enemies) return;

        this.enemies.getChildren().forEach(e => {
            if (!e.active || !e.stats) return;
            if (e === this.caveBoss) return;

            const dx = this.player.x - e.x;
            const dy = this.player.y - e.y;
            const dist = Math.sqrt(dx * dx + dy * dy);

            if (dist < 200) {
                const speed = 50;
                if (dist > 30) {
                    e.body.setVelocity((dx / dist) * speed, (dy / dist) * speed);
                    e.setFlipX(dx < 0);
                } else {
                    e.body.setVelocity(0);
                }
            } else {
                e.body.setVelocity(0);
            }

            e.hpBg.x = e.x;
            e.hpBg.y = e.y - e.stats.bh / 2 - 8;
            e.hpFill.x = e.x;
            e.hpFill.y = e.y - e.stats.bh / 2 - 8;
        });

        // Small bats (summoned by boss) — chase player
        if (this.caveSmallBats) {
            this.caveSmallBats.getChildren().forEach(e => {
                if (!e.active || !e.stats) return;
                const dx = this.player.x - e.x;
                const dy = this.player.y - e.y;
                const dist = Math.sqrt(dx * dx + dy * dy);
                if (dist < 250) {
                    const speed = 70;
                    if (dist > 20) {
                        e.body.setVelocity((dx / dist) * speed, (dy / dist) * speed);
                        e.setFlipX(dx < 0);
                    } else {
                        e.body.setVelocity(0);
                    }
                } else {
                    e.body.setVelocity(0);
                }
                e.hpBg.x = e.x;
                e.hpBg.y = e.y - e.stats.bh / 2 - 6;
                e.hpFill.x = e.x;
                e.hpFill.y = e.y - e.stats.bh / 2 - 6;
            });
        }
    }

    _caveBossSpawnCheck() {
        if (this.zone !== 'cave' || this.caveBossSpawned || this.caveBossDefeated) return;
        if (this.enemies.getChildren().length <= 2) {
            this.caveBossSpawned = true;
            this._spawnCaveBoss();
        }
    }

    _spawnCaveBoss() {
        const bt = CAVE_BOSS_TYPE;
        const hp = Math.floor(bt.hp[this.difficulty] || bt.hp.Normal);
        const dmg = Math.floor(bt.dmg[this.difficulty] || bt.dmg.Normal);
        const exp = Math.floor(bt.exp[this.difficulty] || bt.exp.Normal);
        const spd = bt.speeds[this.difficulty] || bt.speeds.Normal;

        this.caveBoss = this.add.sprite(this.caveOffsetX + CAVE_WIDTH / 2, CAVE_HEIGHT - 150, 'giant_bat_walk').setDepth(5);
        this.physics.add.existing(this.caveBoss, false);
        this.caveBoss.body.setSize(bt.bw, bt.bh);
        this.caveBoss.body.setCollideWorldBounds(true);
        this.caveBoss.play('giant_bat_walk_anim');

        this.caveBoss.stats = {
            name: bt.name, hp: hp, maxHp: hp,
            damage: dmg, exp: exp, speed: spd,
            bw: bt.bw, bh: bt.bh,
            dashTimer: 0, dashInterval: bt.dashInterval,
            dashSpeed: bt.dashSpeed, dashDmgMul: bt.dashDmgMul,
            screechTimer: 0, screechCooldown: bt.screechCooldown,
            screechRadius: bt.screechRadius, screechDmgMul: bt.screechDmgMul,
            summonHpThreshold: bt.summonHpThreshold,
            summonCount: bt.summonCount,
            summoned: false, isDashing: false
        };

        const hw = bt.bw + 20;
        this.caveBoss.hpBg = this.add.rectangle(this.caveOffsetX + CAVE_WIDTH / 2, 100, hw, 5, 0x333333).setOrigin(0.5).setDepth(15).setScrollFactor(0);
        this.caveBoss.hpFill = this.add.rectangle(this.caveOffsetX + CAVE_WIDTH / 2, 100, hw, 5, 0x8e44ad).setOrigin(0.5).setDepth(15).setScrollFactor(0);
        this.caveBossNameText = this.add.text(this.caveOffsetX + CAVE_WIDTH / 2, 85, bt.name, {
            fontSize: '12px', fill: '#bf77f6', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 2
        }).setOrigin(0.5).setDepth(15).setScrollFactor(0);

        this.caveBossAlive = true;
        this.enemies.add(this.caveBoss);
    }

    _updateCaveBoss() {
        if (!this.caveBossAlive || !this.caveBoss || !this.caveBoss.active) return;
        const b = this.caveBoss;
        const s = b.stats;

        b.hpBg.x = GAME_WIDTH / 2;
        b.hpBg.y = 100;
        b.hpFill.x = GAME_WIDTH / 2;
        b.hpFill.y = 100;

        if (this.menuOpen || this.transitioning) {
            b.body.setVelocity(0);
            return;
        }
        if (s.isDashing) return;

        const dx = this.player.x - b.x;
        const dy = this.player.y - b.y;
        const dist = Math.sqrt(dx * dx + dy * dy);

        if (dist > 50) {
            b.body.setVelocity((dx / dist) * s.speed, (dy / dist) * s.speed);
            b.setFlipX(dx < 0);
        } else {
            b.body.setVelocity(0);
        }

        s.dashTimer += this.game.loop.delta;
        if (s.dashTimer >= s.dashInterval) {
            s.dashTimer = 0;
            this._caveBossDash(b);
        }

        s.screechTimer += this.game.loop.delta;
        if (s.screechTimer >= s.screechCooldown) {
            s.screechTimer = 0;
            this._caveBossScreech(b);
        }

        if (!s.summoned && s.hp / s.maxHp <= s.summonHpThreshold) {
            s.summoned = true;
            this._caveBossSummon(b);
        }
    }

    _caveBossDash(boss) {
        const s = boss.stats;
        s.isDashing = true;
        const dx = this.player.x - boss.x;
        const dy = this.player.y - boss.y;
        const dist = Math.sqrt(dx * dx + dy * dy) || 1;
        boss.body.setVelocity((dx / dist) * s.dashSpeed, (dy / dist) * s.dashSpeed);
        boss.setTint(0x00ffff);
        this.time.delayedCall(400, () => {
            if (boss.active) {
                boss.body.setVelocity(0);
                boss.clearTint();
                s.isDashing = false;
                const pdist = Phaser.Math.Distance.Between(
                    this.player.x, this.player.y, boss.x, boss.y
                );
                if (pdist < 60) {
                    this.takeDamage(Math.floor(boss.stats.damage * s.dashDmgMul));
                }
            }
        });
    }

    _caveBossScreech(boss) {
        const s = boss.stats;
        const dmg = Math.floor(boss.stats.damage * s.screechDmgMul);
        playBossAoE();

        const ring = this.add.sprite(boss.x, boss.y, 'skeleton_lord_aoe')
            .setAlpha(0.7).setScale(0.2);
        this.tweens.add({
            targets: ring, scaleX: 2.0, scaleY: 2.0, alpha: 0, duration: 700,
            onComplete: () => ring.destroy()
        });

        this.time.delayedCall(350, () => {
            const dist = Phaser.Math.Distance.Between(
                this.player.x, this.player.y, boss.x, boss.y
            );
            if (dist < s.screechRadius) {
                this.takeDamage(dmg);
                this.floatingText(this.player.x, this.player.y - 30, 'SCREECH!', '#e74c3c');
            }
        });
    }

    _caveBossSummon(boss) {
        playBossAoE();
        this.floatingText(boss.x, boss.y - 40, 'SUMMONING!', '#9b59b6');
        for (let i = 0; i < boss.stats.summonCount; i++) {
            const angle = (i / boss.stats.summonCount) * Math.PI * 2;
            const sx = boss.x + Math.cos(angle) * 80;
            const sy = boss.y + Math.sin(angle) * 80;
            this._spawnSmallBat(sx, sy);
        }
    }

    _spawnSmallBat(x, y) {
        const bt = CAVE_SMALL_BAT;
        const e = this.add.sprite(x, y, 'small_bat_walk').setDepth(5);
        this.physics.add.existing(e, false);
        e.body.setSize(bt.bw, bt.bh);
        e.body.setCollideWorldBounds(true);
        e.play('small_bat_walk_anim');

        e.stats = {
            key: bt.key, name: bt.name,
            hp: Math.floor(bt.hp * this.diffMulti.hp),
            maxHp: Math.floor(bt.hp * this.diffMulti.hp),
            damage: Math.floor(bt.dmg * this.diffMulti.dmg),
            exp: Math.floor(bt.exp * this.diffMulti.exp),
            bw: bt.bw, bh: bt.bh
        };

        const hw = bt.bw + 4;
        e.hpBg = this.add.rectangle(x, y - bt.bh / 2 - 6, hw, 3, 0x333333).setOrigin(0.5).setDepth(11);
        e.hpFill = this.add.rectangle(x, y - bt.bh / 2 - 6, hw, 3, 0xe74c3c).setOrigin(0.5).setDepth(11);
        this.caveSmallBats.add(e);
    }

    killCaveBoss() {
        const b = this.caveBoss;
        const exp = b.stats.exp;
        const expBonus = 1 + (this.accountEffects ? (this.accountEffects.expPercent || 0) / 100 : 0);
        this.playerExp += exp;
        this.accountExp += Math.floor(exp * expBonus);
        this.kills++;
        this.caveBossAlive = false;
        this.caveBossDefeated = true;
        playBossDeath();
        recordKill('giant_bat');
        recordSoulCollect('giant_bat');
        onKill('giant_bat');
        this._updateQuestIcons();

        b.body.setVelocity(0);
        b.setTint(0xff0000);
        this.tweens.add({
            targets: b, alpha: 0, scaleX: 1.5, scaleY: 1.5, duration: 800,
            onComplete: () => {
                if (b.hpBg) b.hpBg.destroy();
                if (b.hpFill) b.hpFill.destroy();
                b.destroy();
                this.caveBoss = null;
            }
        });
        if (b.aoeRing) { b.aoeRing.destroy(); }
        if (b.aoeRing2) { b.aoeRing2.destroy(); }
        if (this.caveBossNameText) this.caveBossNameText.destroy();

        this.floatingText(this.caveOffsetX + CAVE_WIDTH / 2, 200, '+' + exp + ' EXP', '#f1c40f');

        this.defeatedText = this.add.text(this.caveOffsetX + CAVE_WIDTH / 2, 250, 'GIANT BAT DEFEATED!', {
            fontSize: '28px', fill: '#bf77f6', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 4
        }).setOrigin(0.5).setScrollFactor(0);
        this.tweens.add({
            targets: this.defeatedText, alpha: 0, duration: 5000,
            onComplete: () => { if (this.defeatedText) this.defeatedText.destroy(); this.defeatedText = null; }
        });

        this.defeatedLoot = [];
        const lootItems = [];
        if (Math.random() < BOSS_DROP_CHANCE) {
            const item = rollEquip();
            if (this.addEquip(item)) {
                lootItems.push(item);
                playLoot();
            }
        }
        if (Math.random() < 0.6) {
            const item2 = rollEquip();
            if (this.addEquip(item2)) {
                lootItems.push(item2);
                playLoot();
            }
        }
        if (Math.random() < BOSS_DROP_CHANCE) {
            const accItem = rollAccountEquip();
            if (this.addAccountEquip(accItem)) {
                lootItems.push({ ...accItem, name: accItem.name + ' [ACCOUNT]' });
                playLoot();
            }
        }

        const relic = rollCaveRelic(this.classKey);
        if (relic && this.addAccountEquip(relic)) {
            lootItems.push({ ...relic, name: relic.name + ' [RELIC]' });
            playLoot();
            this.floatingText(this.caveOffsetX + CAVE_WIDTH / 2, 280, 'Relic obtained!', '#9b59b6');
        }

        lootItems.forEach((item, i) => {
            const rc = '#' + RARITY_COLORS[item.rarity].toString(16).padStart(6, '0');
            const lt = this.add.text(this.caveOffsetX + CAVE_WIDTH / 2, 300 + i * 24, '+' + item.name, {
                fontSize: '16px', fill: rc, fontFamily: 'Arial', fontStyle: 'bold',
                stroke: '#000', strokeThickness: 2
            }).setOrigin(0.5).setScrollFactor(0);
            this.defeatedLoot.push(lt);
            this.tweens.add({
                targets: lt, alpha: 0, duration: 5000,
                onComplete: () => { if (lt.active) lt.destroy(); }
            });
        });

        if (lootItems.length === 0) {
            const noLoot = this.add.text(this.caveOffsetX + CAVE_WIDTH / 2, 300, 'No drops...', {
                fontSize: '14px', fill: '#95a5a6', fontFamily: 'Arial',
                stroke: '#000', strokeThickness: 2
            }).setOrigin(0.5).setScrollFactor(0);
            this.defeatedLoot.push(noLoot);
            this.tweens.add({
                targets: noLoot, alpha: 0, duration: 5000,
                onComplete: () => { if (noLoot.active) noLoot.destroy(); }
            });
        }

        this.caveStairs = this.add.sprite(this.caveOffsetX + CAVE_WIDTH / 2, CAVE_HEIGHT - 80, 'cave_stairs').setDepth(1);
        this.caveStairsHint = this.add.text(this.caveOffsetX + CAVE_WIDTH / 2, CAVE_HEIGHT - 55, '', {
            fontSize: '11px', fill: '#f1c40f', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 2
        }).setOrigin(0.5).setDepth(12);

        this.checkLevelUp();
        this._checkAccountLevelUp();
        this.updateUI();
    }

    _destroyOrphanedCaveStairs() {
        if (this.caveStairs) { this.caveStairs.destroy(); this.caveStairs = null; }
        if (this.caveStairsHint) { this.caveStairsHint.destroy(); this.caveStairsHint = null; }
        const toRemove = [];
        this.children.list.forEach(child => {
            if (child.texture && child.texture.key === 'cave_stairs') toRemove.push(child);
        });
        toRemove.forEach(s => s.destroy());
    }

    // ===== VILLAGE ZONE =====
    _setupVillage(frozen = false) {
        this._destroyOrphanedCaveStairs();
        const ox = (GAME_WIDTH - VILLAGE_WIDTH) / 2;
        this.villageFrozen = frozen;
        if (frozen) {
            this.cameras.main.setBackgroundColor('#1a2438');
        } else {
            this.cameras.main.setBackgroundColor('#1a1408');
        }
        this.physics.world.setBounds(ox, 0, VILLAGE_WIDTH, VILLAGE_TOTAL_HEIGHT);
        this.cameras.main.setBounds(ox, 0, VILLAGE_WIDTH, VILLAGE_TOTAL_HEIGHT);
        this.villageOffsetX = ox;

        this.villageBg = this.add.tileSprite(ox, 0, VILLAGE_WIDTH, VILLAGE_TOTAL_HEIGHT, frozen ? 'snow_ground' : 'village_ground')
            .setOrigin(0, 0).setDepth(0);

        this.player.x = ox + VILLAGE_WIDTH / 2;
        this.player.y = 50;
        this.player.body.setCollideWorldBounds(true);
        this.cameras.main.startFollow(this.player, true, 0.08, 0.08);
        this.cameras.main.setDeadzone(50, 40);

        this.enemies = this.physics.add.group();
        this.villageChests = this.physics.add.group();
        this.villageCorpses = this.physics.add.group();
        this.villageZombies = this.physics.add.group();
        this.villageCampsCleared = 0;
        this.villageAllCleared = false;
        this.childSpawned = false;
        this.villageBossAlive = false;
        this.villageBossDefeated = false;
        this.villageBossSpawned = false;
        this.snowyVillageAllCleared = false;
        this.snowyIceSpirit = null;
        this.snowyIceSpiritNameText = null;
        this.snowyIceSpiritAbilities = null;
        this.snowyIceShards = null;
        this.campfire = null;
        this.campfireHint = null;

        if (frozen) {
            this._spawnSnowyVillageCamps();
            this._spawnSnowyVillageChests();
            this._spawnSnowyCampfire();
        } else if (!this.villageRestored) {
            this._spawnVillageCamps();
            this._spawnVillageDecor();
            this._spawnVillageChests();
        } else {
            this._spawnVillageDecor();
            this._showVillageClearedDecor();
        }

        this.physics.add.overlap(this.player, this.enemies, (p, e) => {
            if (e.active && e.stats && !this.menuOpen && !this.transitioning) {
                this.takeDamage(e.stats.damage);
            }
        }, null, this);

        this.physics.add.overlap(this.player, this.villageZombies, (p, e) => {
            if (e.active && e.stats && !this.menuOpen && !this.transitioning) {
                this.takeDamage(e.stats.damage);
            }
        }, null, this);

        this.zone = 'village';
        if (!frozen) this._spawnNPCs();
        this.hintText.setText('SPACE=attack | I=inventory | TAB=stats | T=talents | C=craft | Q=quests | P=pause');
        startMusic();
    }

    _clearVillage() {
        this.physics.world.colliders.destroy();
        if (this.fireballs) {
            this.fireballs.forEach(fb => { if (fb.glow) fb.glow.destroy(); fb.destroy(); });
            this.fireballs = [];
        }
        if (this.shieldActive) {
            this.shieldActive = false;
            this.shieldHP = 0;
            if (this.shieldVfx) { this.shieldVfx.destroy(); this.shieldVfx = null; }
        }
        if (this.enemies && this.enemies.getLength && this.enemies.getLength() > 0) {
            this.enemies.getChildren().forEach(e => {
                if (e.hpBg) e.hpBg.destroy();
                if (e.hpFill) e.hpFill.destroy();
                if (e.nameText) e.nameText.destroy();
            });
            this.enemies.clear(true, true);
        }
        if (this.enemies) { this.enemies.destroy(); this.enemies = null; }
        if (this.villageChests && this.villageChests.getLength && this.villageChests.getLength() > 0) {
            this.villageChests.getChildren().forEach(ch => {
                if (ch.hintText) ch.hintText.destroy();
                if (ch.hpBg) ch.hpBg.destroy();
                if (ch.hpFill) ch.hpFill.destroy();
            });
            this.villageChests.clear(true, true);
        }
        if (this.villageChests) { this.villageChests.destroy(); this.villageChests = null; }
        if (this.villageCorpses) { this.villageCorpses.clear(true, true); this.villageCorpses.destroy(); this.villageCorpses = null; }
        if (this.villageZombies && this.villageZombies.getLength && this.villageZombies.getLength() > 0) {
            this.villageZombies.getChildren().forEach(e => {
                if (e.hpBg) e.hpBg.destroy();
                if (e.hpFill) e.hpFill.destroy();
            });
            this.villageZombies.clear(true, true);
        }
        if (this.villageZombies) { this.villageZombies.destroy(); this.villageZombies = null; }
        if (this.villageDecor) {
            this.villageDecor.forEach(d => { if (d && d.destroy) d.destroy(); });
            this.villageDecor = null;
        }
        if (this.villageBg) { this.villageBg.destroy(); this.villageBg = null; }
        if (this.villageChildNPC) { if (this.villageChildNPC.destroy) this.villageChildNPC.destroy(); this.villageChildNPC = null; }
        if (this.villageChildHint) { this.villageChildHint.destroy(); this.villageChildHint = null; }
        if (this.villageBoss) {
            if (this.villageBoss.hpBg) this.villageBoss.hpBg.destroy();
            if (this.villageBoss.hpFill) this.villageBoss.hpFill.destroy();
            if (this.villageBossNameText) this.villageBossNameText.destroy();
            this.villageBoss.destroy();
            this.villageBoss = null;
        }
        this.villageBossClones = null;
        if (this.villageCemeteryGate) { this.villageCemeteryGate.destroy(); this.villageCemeteryGate = null; }
        if (this.hellPortal) { if (this.hellPortal.destroy) this.hellPortal.destroy(); this.hellPortal = null; }
        if (this.hellPortalHint) { if (this.hellPortalHint.destroy) this.hellPortalHint.destroy(); this.hellPortalHint = null; }
        if (this.campfire) { if (this.campfire.destroy) this.campfire.destroy(); this.campfire = null; }
        if (this.campfireHint) { if (this.campfireHint.destroy) this.campfireHint.destroy(); this.campfireHint = null; }
        if (this.snowyIceSpirit) {
            if (this.snowyIceSpirit.hpBg) this.snowyIceSpirit.hpBg.destroy();
            if (this.snowyIceSpirit.hpFill) this.snowyIceSpirit.hpFill.destroy();
            if (this.snowyIceSpiritNameText) this.snowyIceSpiritNameText.destroy();
            this.snowyIceSpirit.destroy();
            this.snowyIceSpirit = null;
        }
        if (this.snowyIceShards) {
            this.snowyIceShards.getChildren().forEach(s => {
                if (s.hpBg) s.hpBg.destroy();
                if (s.hpFill) s.hpFill.destroy();
            });
            this.snowyIceShards.clear(true, true);
            this.snowyIceShards.destroy();
            this.snowyIceShards = null;
        }
        this.snowyVillageAllCleared = false;
        this.villageFrozen = false;
        if (this.defeatedText) { this.defeatedText.destroy(); this.defeatedText = null; }
        if (this.defeatedLoot) {
            this.defeatedLoot.forEach(t => { if (t && t.destroy) t.destroy(); });
            this.defeatedLoot = null;
        }
    }

    _spawnVillageCamps() {
        const ox = this.villageOffsetX;
        const roleOrder = ['tank', 'assassin', 'archer', 'healer'];
        for (let i = 0; i < VILLAGE_CAMP_COUNT; i++) {
            const cp = VILLAGE_CAMP_POSITIONS[i];
            for (let j = 0; j < VILLAGE_MOBS_PER_CAMP; j++) {
                const role = roleOrder[j];
                const t = VILLAGE_ENEMY_TYPES[role];
                const angle = (j / VILLAGE_MOBS_PER_CAMP) * Math.PI * 2;
                const ex = ox + cp.x + Math.cos(angle) * 30;
                const ey = cp.y + Math.sin(angle) * 25;
                this._makeVillageEnemy(t, ex, ey, i);
            }
        }
    }

    _makeVillageEnemy(t, x, y, campIndex) {
        const walkTex = t.key + '_walk';
        const animKey = t.key + '_walk_anim';
        const e = this.add.sprite(x, y, walkTex).setDepth(5);
        this.physics.add.existing(e, false);
        e.body.setSize(t.bw, t.bh);
        e.body.setCollideWorldBounds(true);
        if (this.anims.exists(animKey)) e.play(animKey);

        e.stats = {
            key: t.key, name: t.name,
            hp: Math.floor(t.hp * this.diffMulti.hp),
            maxHp: Math.floor(t.hp * this.diffMulti.hp),
            damage: Math.floor(t.dmg * this.diffMulti.dmg),
            exp: Math.floor(t.exp * this.diffMulti.exp),
            bw: t.bw, bh: t.bh, role: t.role,
            campIndex: campIndex,
            wTimer: 0, wDir: 0
        };

        const hw = t.bw + 4;
        e.hpBg = this.add.rectangle(x, y - t.bh / 2 - 8, hw, 3, 0x333333).setOrigin(0.5).setDepth(11);
        e.hpFill = this.add.rectangle(x, y - t.bh / 2 - 8, hw, 3, 0xe74c3c).setOrigin(0.5).setDepth(11);
        this.enemies.add(e);
        return e;
    }

    _spawnVillageDecor() {
        const ox = this.villageOffsetX;
        this.villageDecor = [];

        VILLAGE_HOUSE_POSITIONS.forEach(hp => {
            const h = this.add.image(ox + hp.x, hp.y, 'village_house').setDepth(2);
            this.villageDecor.push(h);
        });

        const ch = this.add.image(ox + VILLAGE_CHILD_HOUSE.x, VILLAGE_CHILD_HOUSE.y, 'village_house').setDepth(2);
        this.villageDecor.push(ch);

        VILLAGE_CORPSE_POSITIONS.forEach(cp => {
            const c = this.add.image(ox + cp.x, cp.y, 'village_corpse').setDepth(1).setAlpha(0.8);
            this.villageDecor.push(c);
        });

        VILLAGE_GARDEN_POSITIONS.forEach(gp => {
            const g = this.add.image(ox + gp.x, gp.y, 'village_garden').setDepth(1);
            this.villageDecor.push(g);
        });

        for (let y = 1980; y < 2010; y += 12) {
            const f = this.add.image(ox + 100, y, 'village_fence').setDepth(1);
            this.villageDecor.push(f);
            const f2 = this.add.image(ox + 600, y, 'village_fence').setDepth(1);
            this.villageDecor.push(f2);
        }
        this.villageCemeteryGate = this.add.rectangle(ox + VILLAGE_WIDTH / 2, 2000, 60, 12, 0x8a30a0, 0.35).setDepth(2);

        this._villageClearedDecor = false;
    }

    _showVillageClearedDecor() {
        if (this._villageClearedDecor) return;
        this._villageClearedDecor = true;
        const ox = this.villageOffsetX;
        VILLAGE_CORPSE_POSITIONS.forEach(cp => {
            const c = this.add.image(ox + cp.x, cp.y, 'village_corpse').setDepth(1).setAlpha(0.4).setTint(0x555555);
            this.villageDecor.push(c);
        });
    }

    _spawnVillageChests() {
        const ox = this.villageOffsetX;
        const count = VILLAGE_CHEST_COUNT_MIN + Math.floor(Math.random() * (VILLAGE_CHEST_COUNT_MAX - VILLAGE_CHEST_COUNT_MIN + 1));
        for (let i = 0; i < count; i++) {
            const cy = 100 + Math.random() * (VILLAGE_HEIGHT - 200);
            const cx = ox + 50 + Math.random() * (VILLAGE_WIDTH - 100);
            this._createVillageChest(cx, cy);
        }
    }

    _createVillageChest(x, y) {
        const ch = this.add.sprite(x, y, VILLAGE_CHEST_CLOSED_KEY).setDepth(6);
        this.physics.add.existing(ch, false);
        ch.body.setSize(VILLAGE_CHEST_W, VILLAGE_CHEST_H);
        ch.body.setCollideWorldBounds(true);
        ch.stats = { hp: 60, maxHp: 60 };
        ch.hpBg = this.add.rectangle(x, y - 16, VILLAGE_CHEST_W + 4, 3, 0x333333).setOrigin(0.5).setDepth(11);
        ch.hpFill = this.add.rectangle(x, y - 16, VILLAGE_CHEST_W + 4, 3, 0xf39c12).setOrigin(0.5).setDepth(11);
        ch.loot = [];
        const count = 1 + Math.floor(Math.random() * 2);
        for (let i = 0; i < count; i++) {
            if (Math.random() < VILLAGE_CHEST_DROP_CHANCE) {
                ch.loot.push(rollVillageEquip());
            }
        }
        if (Math.random() < VILLAGE_CHEST_EQUIP_DROP_CHANCE) {
            ch.loot.push(rollEquip());
        }
        ch.hintText = this.add.text(x, y - 20, '', {
            fontSize: '10px', fill: '#f1c40f', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 2
        }).setOrigin(0.5).setDepth(12);
        ch.broken = false;
        this.villageChests.add(ch);
        return ch;
    }

    breakVillageChest(ch) {
        if (!ch || ch.broken) return;
        ch.broken = true;
        ch.setTexture(VILLAGE_CHEST_OPEN_KEY);
        ch.hpBg.destroy();
        ch.hpFill.destroy();
        playBreak();

        ch.loot.forEach((item, i) => {
            const rc = '#' + RARITY_COLORS[item.rarity].toString(16).padStart(6, '0');
            const lt = this.add.text(ch.x, ch.y - 20 - i * 16, '+' + item.name, {
                fontSize: '11px', fill: rc, fontFamily: 'Arial', fontStyle: 'bold',
                stroke: '#000', strokeThickness: 2
            }).setOrigin(0.5).setDepth(13);
            this.tweens.add({
                targets: lt, y: lt.y - 20, alpha: 0, duration: 2000,
                onComplete: () => lt.destroy()
            });
            if (item.type === 'equip') this.addEquip(item);
            else if (item.type === 'accountEquip') this.addAccountEquip(item);
            playLoot();
        });

        this.time.delayedCall(2500, () => { if (ch.active) ch.destroy(); });
    }

    _spawnSnowyVillageCamps() {
        const ox = this.villageOffsetX;
        const roleOrder = ['tank', 'assassin', 'archer', 'healer'];
        for (let i = 0; i < SNOWY_VILLAGE_CAMP_POSITIONS.length; i++) {
            const cp = SNOWY_VILLAGE_CAMP_POSITIONS[i];
            for (let j = 0; j < 4; j++) {
                const role = roleOrder[j % roleOrder.length];
                const t = SNOWY_VILLAGE_ENEMY_TYPES[role];
                const angle = (j / 4) * Math.PI * 2;
                const ex = ox + cp.x + Math.cos(angle) * 30;
                const ey = cp.y + Math.sin(angle) * 25;
                this._makeSnowyVillageEnemy(t, ex, ey, i);
            }
        }
    }

    _makeSnowyVillageEnemy(t, x, y, campIndex) {
        const walkTex = t.key + '_walk';
        const animKey = t.key + '_walk_anim';
        const e = this.add.sprite(x, y, walkTex).setDepth(5);
        this.physics.add.existing(e, false);
        e.body.setSize(t.bw, t.bh);
        e.body.setCollideWorldBounds(true);
        if (this.anims.exists(animKey)) e.play(animKey);

        e.stats = {
            key: t.key, name: t.name,
            hp: Math.floor(t.hp * this.diffMulti.hp),
            maxHp: Math.floor(t.hp * this.diffMulti.hp),
            damage: Math.floor(t.dmg * this.diffMulti.dmg),
            exp: Math.floor(t.exp * this.diffMulti.exp),
            bw: t.bw, bh: t.bh, role: t.role,
            campIndex: campIndex,
            wTimer: 0, wDir: 0
        };

        const hw = t.bw + 4;
        e.hpBg = this.add.rectangle(x, y - t.bh / 2 - 8, hw, 3, 0x333333).setOrigin(0.5).setDepth(11);
        e.hpFill = this.add.rectangle(x, y - t.bh / 2 - 8, hw, 3, 0x3498db).setOrigin(0.5).setDepth(11);
        this.enemies.add(e);
        return e;
    }

    _spawnSnowyVillageChests() {
        const ox = this.villageOffsetX;
        for (let i = 0; i < SNOWY_VILLAGE_CHEST_COUNT; i++) {
            const cy = 100 + Math.random() * (VILLAGE_HEIGHT - 200);
            const cx = ox + 50 + Math.random() * (VILLAGE_WIDTH - 100);
            this._createSnowyVillageChest(cx, cy);
        }
    }

    _createSnowyVillageChest(x, y) {
        const ch = this.add.sprite(x, y, 'snowy_barrel').setDepth(6);
        this.physics.add.existing(ch, false);
        ch.body.setSize(18, 22);
        ch.body.setCollideWorldBounds(true);
        ch.stats = { hp: 60, maxHp: 60 };
        ch.hpBg = this.add.rectangle(x, y - 16, 22, 3, 0x333333).setOrigin(0.5).setDepth(11);
        ch.hpFill = this.add.rectangle(x, y - 16, 22, 3, 0x3498db).setOrigin(0.5).setDepth(11);
        ch.loot = [];
        const count = 1 + Math.floor(Math.random() * 2);
        for (let i = 0; i < count; i++) {
            if (Math.random() < SNOWY_VILLAGE_CHEST_DROP_CHANCE) {
                ch.loot.push(rollVillageEquip());
            }
        }
        if (Math.random() < VILLAGE_CHEST_EQUIP_DROP_CHANCE) {
            ch.loot.push(rollEquip());
        }
        ch.hintText = this.add.text(x, y - 20, '', {
            fontSize: '10px', fill: '#3498db', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 2
        }).setOrigin(0.5).setDepth(12);
        ch.broken = false;
        this.villageChests.add(ch);
        return ch;
    }

    _spawnSnowyCampfire() {
        const ox = this.villageOffsetX;
        const cf = this.add.image(ox + VILLAGE_WIDTH / 2, 100, 'campfire').setDepth(6);
        this.physics.add.existing(cf, false);
        cf.body.setSize(24, 30);
        cf.body.setCollideWorldBounds(true);
        this.campfire = cf;
        this.campfireHint = this.add.text(ox + VILLAGE_WIDTH / 2, 70, '', {
            fontSize: '11px', fill: '#f1c40f', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 2
        }).setOrigin(0.5).setDepth(12);
    }

    _spawnSnowyVillageBoss() {
        if (this.snowyIceSpirit) return;
        const ox = this.villageOffsetX;
        const x = ox + VILLAGE_WIDTH / 2;
        const y = VILLAGE_HEIGHT - 100;

        const walkTex = SNOWY_VILLAGE_BOSS_TYPE.key + '_walk';
        const animKey = SNOWY_VILLAGE_BOSS_TYPE.key + '_walk_anim';
        const e = this.add.sprite(x, y, walkTex).setDepth(6);
        this.physics.add.existing(e, false);
        e.body.setSize(SNOWY_VILLAGE_BOSS_TYPE.bw, SNOWY_VILLAGE_BOSS_TYPE.bh);
        e.body.setCollideWorldBounds(true);
        if (this.anims.exists(animKey)) e.play(animKey);

        const bt = SNOWY_VILLAGE_BOSS_TYPE;
        const diffKey = this.difficulty || 'Normal';
        e.stats = {
            key: bt.key, name: bt.name,
            hp: Math.floor((bt.hp[diffKey] || bt.hp.Normal)),
            maxHp: Math.floor((bt.hp[diffKey] || bt.hp.Normal)),
            damage: Math.floor((bt.dmg[diffKey] || bt.dmg.Normal)),
            exp: Math.floor((bt.exp[diffKey] || bt.exp.Normal)),
            bw: bt.bw, bh: bt.bh
        };

        const hpW = 80;
        e.hpBg = this.add.rectangle(400, 56, hpW, 6, 0x333333).setOrigin(0.5).setScrollFactor(0).setDepth(20);
        e.hpFill = this.add.rectangle(400 - hpW / 2, 56, hpW, 6, 0x3498db).setOrigin(0, 0.5).setScrollFactor(0).setDepth(20);
        this.snowyIceSpiritNameText = this.add.text(400, 44, bt.name, {
            fontSize: '13px', fill: '#3498db', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 2
        }).setOrigin(0.5).setScrollFactor(0).setDepth(20);

        this.snowyIceSpirit = e;
        this.snowyIceSpiritAbilities = { frostWaveTimer: 0, blizzardTimer: 0, summonTimer: 0 };
        this.snowyIceShards = this.physics.add.group();
    }

    _updateSnowyVillageBoss() {
        if (!this.snowyIceSpirit || !this.snowyIceSpirit.active) return;
        const b = this.snowyIceSpirit;
        const s = b.stats;

        b.hpBg.x = 400;
        b.hpBg.y = 56;
        b.hpFill.x = 400 - b.hpBg.width / 2;
        b.hpFill.y = 56;
        b.hpFill.width = b.hpBg.width * (s.hp / s.maxHp);

        if (b.hp <= 0) {
            this._snowyIceSpiritDied();
            return;
        }

        const dx = this.player.x - b.x;
        const dy = this.player.y - b.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist > 40) {
            b.body.setVelocity((dx / dist) * 60, (dy / dist) * 60);
            b.setFlipX(dx < 0);
        } else {
            b.body.setVelocity(0);
        }

        const ab = this.snowyIceSpiritAbilities;
        ab.frostWaveTimer += this.game.loop.delta;
        ab.blizzardTimer += this.game.loop.delta;
        ab.summonTimer += this.game.loop.delta;

        if (ab.frostWaveTimer >= 5000) {
            ab.frostWaveTimer = 0;
            this._snowyFrostWave(b);
        }
        if (ab.blizzardTimer >= 8000) {
            ab.blizzardTimer = 0;
            this._snowyBlizzard(b);
        }
        if (ab.summonTimer >= 12000) {
            ab.summonTimer = 0;
            this._snowySummonShards(b);
        }

        if (this.snowyIceShards && this.snowyIceShards.getLength() > 0) {
            this.snowyIceShards.getChildren().forEach(s => {
                if (!s.active || !s.stats) return;
                const sdx = this.player.x - s.x;
                const sdy = this.player.y - s.y;
                const sd = Math.sqrt(sdx * sdx + sdy * sdy);
                if (sd < 200) {
                    if (sd > 15) {
                        s.body.setVelocity((sdx / sd) * 90, (sdy / sd) * 90);
                        s.setFlipX(sdx < 0);
                    } else {
                        s.body.setVelocity(0);
                    }
                } else {
                    s.body.setVelocity(0);
                }
                if (s.hpBg) { s.hpBg.x = s.x; s.hpBg.y = s.y - s.stats.bh / 2 - 6; }
                if (s.hpFill) { s.hpFill.x = s.x; s.hpFill.y = s.y - s.stats.bh / 2 - 6; }
            });
        }
    }

    _snowyFrostWave(boss) {
        if (!boss || !boss.active) return;
        const ox = this.villageOffsetX;
        const px = this.player.x;
        const py = this.player.y;
        const dx = px - boss.x;
        const dy = py - boss.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist > 250) return;
        if (dist < 100) {
            this.takeDamage(Math.floor(boss.stats.damage * 0.6));
        }
        const vfx = this.add.image(boss.x + dx * 0.5, boss.y + dy * 0.5, 'frost_wave_vfx').setDepth(10).setAlpha(0.7);
        this.tweens.add({ targets: vfx, alpha: 0, scale: 1.5, duration: 600, onComplete: () => vfx.destroy() });
    }

    _snowyBlizzard(boss) {
        if (!boss || !boss.active) return;
        const dist = Phaser.Math.Distance.Between(this.player.x, this.player.y, boss.x, boss.y);
        if (dist < 150) {
            this.takeDamage(Math.floor(boss.stats.damage * 0.8));
        }
        const vfx = this.add.image(boss.x, boss.y, 'blizzard_vfx').setDepth(10).setAlpha(0.7).setScale(1.5);
        this.tweens.add({ targets: vfx, alpha: 0, scale: 2, duration: 800, onComplete: () => vfx.destroy() });
    }

    _snowySummonShards(boss) {
        if (!boss || !boss.active || !this.snowyIceShards) return;
        for (let i = 0; i < 3; i++) {
            const angle = (i / 3) * Math.PI * 2;
            const sx = boss.x + Math.cos(angle) * 50;
            const sy = boss.y + Math.sin(angle) * 40;
            const shard = this.add.sprite(sx, sy, 'ice_shard').setDepth(5);
            this.physics.add.existing(shard, false);
            shard.body.setSize(10, 12);
            shard.body.setCollideWorldBounds(true);
            const dm = this.diffMulti || { hp: 1, dmg: 1 };
            shard.stats = { hp: Math.floor(SNOWY_BOSS_MINION.hp * dm.hp), maxHp: Math.floor(SNOWY_BOSS_MINION.hp * dm.hp), damage: Math.floor(SNOWY_BOSS_MINION.dmg * dm.dmg), bh: 12 };
            shard.hpBg = this.add.rectangle(sx, sy - 12, 14, 3, 0x333333).setOrigin(0.5).setDepth(11);
            shard.hpFill = this.add.rectangle(sx, sy - 12, 14, 3, 0x3498db).setOrigin(0.5).setDepth(11);
            this.snowyIceShards.add(shard);
        }
    }

    _snowyIceSpiritDied() {
        if (!this.snowyIceSpirit) return;
        playBossDeath();
        const ox = this.villageOffsetX;

        if (this.snowyIceSpirit.hpBg) this.snowyIceSpirit.hpBg.destroy();
        if (this.snowyIceSpirit.hpFill) this.snowyIceSpirit.hpFill.destroy();
        if (this.snowyIceSpiritNameText) this.snowyIceSpiritNameText.destroy();
        this.snowyIceSpirit.destroy();
        this.snowyIceSpirit = null;

        if (this.snowyIceShards) {
            this.snowyIceShards.getChildren().forEach(s => {
                if (s.hpBg) s.hpBg.destroy();
                if (s.hpFill) s.hpFill.destroy();
            });
            this.snowyIceShards.clear(true, true);
        }

        this.defeatedText = this.add.text(ox + VILLAGE_WIDTH / 2, 200, 'ICE SPIRIT DEFEATED!', {
            fontSize: '22px', fill: '#3498db', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 4
        }).setOrigin(0.5).setScrollFactor(0);
        this.tweens.add({
            targets: this.defeatedText, alpha: 0, duration: 5000,
            onComplete: () => { if (this.defeatedText) this.defeatedText.destroy(); this.defeatedText = null; }
        });

        const warmCore = { ...WARMTH_CORE, type: 'equip' };
        if (this.addEquip(warmCore)) {
            this.floatingText(ox + VILLAGE_WIDTH / 2, 230, '+' + warmCore.name, '#ff6600');
            playLoot();
        }

        this.villageBossDefeated = true;
        this.checkLevelUp();
        this._checkAccountLevelUp();
        this.updateUI();

        this.time.delayedCall(2000, () => {
            this.floatingText(ox + VILLAGE_WIDTH / 2, 260, 'Use Warmth Core at the campfire!', '#f1c40f');
        });
    }

    _updateSnowyVillageMobs() {
        if (this.zone !== 'village' || !this.villageFrozen || this.menuOpen || this.transitioning) return;
        if (!this.enemies) return;

        this.enemies.getChildren().forEach(e => {
            if (!e.active || !e.stats) return;
            const dx = this.player.x - e.x;
            const dy = this.player.y - e.y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 220) {
                let speed = 55;
                if (e.stats.role === 'assassin') speed = 85;
                else if (e.stats.role === 'tank') speed = 38;
                else if (e.stats.role === 'healer') speed = 50;
                if (dist > 30) {
                    e.body.setVelocity((dx / dist) * speed, (dy / dist) * speed);
                    e.setFlipX(dx < 0);
                } else {
                    e.body.setVelocity(0);
                }
                if (e.stats.role === 'healer' && dist < 150) {
                    this.enemies.getChildren().forEach(ally => {
                        if (ally !== e && ally.active && ally.stats && ally.stats.hp < ally.stats.maxHp) {
                            const ad = Phaser.Math.Distance.Between(e.x, e.y, ally.x, ally.y);
                            if (ad < 80) {
                                ally.stats.hp = Math.min(ally.stats.maxHp, ally.stats.hp + 2);
                                if (ally.hpFill) ally.hpFill.width = (ally.hpBg.width) * (ally.stats.hp / ally.stats.maxHp);
                            }
                        }
                    });
                }
            } else {
                e.body.setVelocity(0);
            }
            e.hpBg.x = e.x;
            e.hpBg.y = e.y - e.stats.bh / 2 - 8;
            e.hpFill.x = e.x;
            e.hpFill.y = e.y - e.stats.bh / 2 - 8;
        });
    }

    _checkSnowyVillageProgress() {
        if (this.zone !== 'village' || !this.villageFrozen || this.snowyVillageAllCleared) return;
        if (!this.enemies || this.enemies.getLength() === 0) {
            this.snowyVillageAllCleared = true;
            this.floatingText(this.villageOffsetX + VILLAGE_WIDTH / 2, 180, 'All winter spirits vanquished!', '#3498db');
            this.time.delayedCall(2000, () => {
                this._spawnSnowyVillageBoss();
                this.floatingText(this.villageOffsetX + VILLAGE_WIDTH / 2, 200, 'ICE SPIRIT has appeared!', '#ff4444');
            });
        }
    }

    _activateCampfire() {
        if (!this.villageFrozen || !this.campfire) return;
        const dist = Phaser.Math.Distance.Between(this.player.x, this.player.y, this.campfire.x, this.campfire.y);
        if (dist >= 60) return;

        let hasWarmthCore = false;
        const bag = this.equipBag || [];
        for (let i = 0; i < bag.length; i++) {
            if (bag[i] && (bag[i].id === 'warmth_core' || bag[i].key === 'warmth_core')) {
                bag.splice(i, 1);
                hasWarmthCore = true;
                break;
            }
        }
        if (!hasWarmthCore) {
            if (this.campfireHint) this.campfireHint.setText('Need Warmth Core!');
            return;
        }

        this.transitioning = true;
        if (this.campfireHint) this.campfireHint.setText('');
        this.cameras.main.fadeOut(1500, 255, 200, 100);

        this.time.delayedCall(1500, () => {
            this.villageRestored = true;
            this._clearVillage();
            this._setupVillage(false);
            this.cameras.main.fadeIn(1000, 255, 200, 100);
            this.transitioning = false;

            this.time.delayedCall(500, () => {
                this.floatingText(this.villageOffsetX + VILLAGE_WIDTH / 2, 200, 'The village is restored!', '#ff6600');
            });
        });
    }

    _updateVillageMobs() {
        if (this.zone !== 'village' || this.menuOpen || this.transitioning) return;
        if (!this.enemies) return;

        this.enemies.getChildren().forEach(e => {
            if (!e.active || !e.stats) return;

            const dx = this.player.x - e.x;
            const dy = this.player.y - e.y;
            const dist = Math.sqrt(dx * dx + dy * dy);

            if (dist < 220) {
                let speed = 50;
                if (e.stats.role === 'assassin') speed = 80;
                else if (e.stats.role === 'tank') speed = 35;
                else if (e.stats.role === 'healer') speed = 45;

                if (dist > 30) {
                    e.body.setVelocity((dx / dist) * speed, (dy / dist) * speed);
                    e.setFlipX(dx < 0);
                } else {
                    e.body.setVelocity(0);
                }

                if (e.stats.role === 'healer' && dist < 150) {
                    this.enemies.getChildren().forEach(ally => {
                        if (ally !== e && ally.active && ally.stats && ally.stats.hp < ally.stats.maxHp) {
                            const ad = Phaser.Math.Distance.Between(e.x, e.y, ally.x, ally.y);
                            if (ad < 80) {
                                ally.stats.hp = Math.min(ally.stats.maxHp, ally.stats.hp + 2);
                                if (ally.hpFill) ally.hpFill.width = (ally.hpBg.width) * (ally.stats.hp / ally.stats.maxHp);
                            }
                        }
                    });
                }
            } else {
                e.body.setVelocity(0);
            }

            e.hpBg.x = e.x;
            e.hpBg.y = e.y - e.stats.bh / 2 - 8;
            e.hpFill.x = e.x;
            e.hpFill.y = e.y - e.stats.bh / 2 - 8;
        });

        if (this.villageZombies && this.villageZombies.getLength() > 0) {
            this.villageZombies.getChildren().forEach(e => {
                if (!e.active || !e.stats) return;
                const dx = this.player.x - e.x;
                const dy = this.player.y - e.y;
                const dist = Math.sqrt(dx * dx + dy * dy);
                if (dist < 200) {
                    if (dist > 20) {
                        e.body.setVelocity((dx / dist) * 60, (dy / dist) * 60);
                        e.setFlipX(dx < 0);
                    } else {
                        e.body.setVelocity(0);
                    }
                } else {
                    e.body.setVelocity(0);
                }
                e.hpBg.x = e.x;
                e.hpBg.y = e.y - e.stats.bh / 2 - 6;
                e.hpFill.x = e.x;
                e.hpFill.y = e.y - e.stats.bh / 2 - 6;
            });
        }
    }

    _checkVillageProgress() {
        if (this.zone !== 'village' || this.villageAllCleared) return;
        if (!this.enemies || this.enemies.getLength() === 0) {
            this.villageAllCleared = true;
            this._spawnChildNPC();
            this._showVillageClearedDecor();
        }
    }

    _spawnChildNPC() {
        if (this.childSpawned) return;
        this.childSpawned = true;
        const ox = this.villageOffsetX;
        const x = ox + VILLAGE_CHILD_HOUSE.x + 35;
        const y = VILLAGE_CHILD_HOUSE.y + 10;

        this.villageChildNPC = this.add.sprite(x, y, 'child_npc').setDepth(6);
        this.villageChildHint = this.add.text(x, y - 20, '', {
            fontSize: '11px', fill: '#f1c40f', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 2
        }).setOrigin(0.5).setDepth(12);

        this.tweens.add({
            targets: this.villageChildNPC,
            y: y - 3, duration: 1500, yoyo: true, repeat: -1, ease: 'Sine.easeInOut'
        });

        this.time.delayedCall(1000, () => {
            if (this.villageChildHint && this.villageChildHint.active) {
                this.villageChildHint.setText('SPACE to talk');
            }
        });
    }

    _talkToChild() {
        if (!this.villageChildNPC || !this.villageChildHint) return;
        const dist = Phaser.Math.Distance.Between(
            this.player.x, this.player.y, this.villageChildNPC.x, this.villageChildNPC.y
        );
        if (dist >= 50) return;

        this.villageChildHint.setText('');

        const msgText = this.add.text(GAME_WIDTH / 2, GAME_HEIGHT / 2 - 60, 'It all came from the cemetery...', {
            fontSize: '18px', fill: '#e74c3c', fontFamily: 'Georgia', fontStyle: 'italic',
            stroke: '#000', strokeThickness: 3, wordWrap: { width: 500 }, align: 'center'
        }).setOrigin(0.5).setDepth(20).setScrollFactor(0);

        const box = this.add.rectangle(GAME_WIDTH / 2, GAME_HEIGHT / 2 - 50, 520, 60, 0x000000, 0.7)
            .setDepth(19).setScrollFactor(0);

        this.time.delayedCall(3500, () => {
            if (msgText) msgText.destroy();
            if (box) box.destroy();
        });

        this.time.delayedCall(4000, () => {
            if (this.villageChildNPC && this.villageChildNPC.active) {
                this.villageChildNPC.destroy();
                this.villageChildNPC = null;
            }
        });
    }

    _checkVillageCemeteryGate() {
        if (this.zone !== 'village' || this.villageAllCleared) return;
        if (!this.player) return;
        if (this.player.y >= 1980) {
            this.player.y = 1970;
        }
    }

    _enterCemetery() {
        if (this.transitioning || this.menuOpen) return;
        if (this.zone !== 'village' || !this.villageAllCleared) return;
        const ox = this.villageOffsetX;
        const dist = Phaser.Math.Distance.Between(
            this.player.x, this.player.y, ox + VILLAGE_WIDTH / 2, 2000
        );
        if (dist >= 50) return;

        this.transitioning = true;
        playPortal();
        this.cameras.main.fadeOut(800, 0, 0, 0);
        this.time.delayedCall(800, () => {
            this._clearVillage();
            this._setupCemetery();
            this.cameras.main.fadeIn(500, 0, 0, 0);
            this.transitioning = false;
        });
    }

    _setupCemetery() {
        const ox = (GAME_WIDTH - VILLAGE_WIDTH) / 2;
        this.cameras.main.setBackgroundColor('#1a1a1a');
        this.physics.world.setBounds(ox, 0, VILLAGE_WIDTH, CEMETERY_HEIGHT);
        this.cameras.main.setBounds(ox, 0, VILLAGE_WIDTH, CEMETERY_HEIGHT);
        this.villageOffsetX = ox;

        this.villageBg = this.add.tileSprite(ox, 0, VILLAGE_WIDTH, CEMETERY_HEIGHT, 'village_ground')
            .setOrigin(0, 0).setDepth(0);

        this.player.x = ox + VILLAGE_WIDTH / 2;
        this.player.y = 30;
        this.player.body.setCollideWorldBounds(true);
        this.cameras.main.startFollow(this.player, true, 0.08, 0.08);
        this.cameras.main.setDeadzone(50, 40);

        this.enemies = this.physics.add.group();
        this.villageChests = this.physics.add.group();
        this.villageCorpses = this.physics.add.group();
        this.villageZombies = this.physics.add.group();
        this.villageBossClones = null;
        this.villageBossAlive = false;
        this.villageBossDefeated = false;
        this.villageBossSpawned = false;

        this.villageDecor = [];
        for (let y = 10; y < CEMETERY_HEIGHT; y += 40) {
            const f1 = this.add.image(ox + 30, y, 'village_fence').setDepth(1).setAlpha(0.6);
            const f2 = this.add.image(ox + VILLAGE_WIDTH - 30, y, 'village_fence').setDepth(1).setAlpha(0.6);
            this.villageDecor.push(f1, f2);
        }

        for (let i = 0; i < 8; i++) {
            const gx = ox + 80 + Math.random() * (VILLAGE_WIDTH - 160);
            const gy = 60 + Math.random() * (CEMETERY_HEIGHT - 120);
            const gravestone = this.add.rectangle(gx, gy, 8, 14, 0x666666).setDepth(2);
            this.villageDecor.push(gravestone);
        }

        this.physics.add.overlap(this.player, this.enemies, (p, e) => {
            if (e.active && e.stats && !this.menuOpen && !this.transitioning) {
                this.takeDamage(e.stats.damage);
            }
        }, null, this);

        this.physics.add.overlap(this.player, this.villageZombies, (p, e) => {
            if (e.active && e.stats && !this.menuOpen && !this.transitioning) {
                this.takeDamage(e.stats.damage);
            }
        }, null, this);

        this.zone = 'cemetery';
        this.hintText.setText('SPACE=attack | I=inventory | TAB=stats | T=talents | C=craft | Q=quests | P=pause');

        this.time.delayedCall(1200, () => {
            if (this.zone === 'cemetery' && !this.villageBossSpawned && !this.villageBossDefeated) {
                this._spawnVillageBoss();
            }
        });
    }

    _clearCemetery() {
        this._clearVillage();
    }

    _spawnVillageBoss() {
        if (this.villageBossSpawned) return;
        try {
            const bt = VILLAGE_BOSS_TYPE;
            const hp = Math.floor(bt.hp[this.difficulty] || bt.hp.Normal);
            const dmg = Math.floor(bt.dmg[this.difficulty] || bt.dmg.Normal);
            const exp = Math.floor(bt.exp[this.difficulty] || bt.exp.Normal);
            const spd = bt.speeds[this.difficulty] || bt.speeds.Normal;
            const ox = this.villageOffsetX;

            this.villageBossSpawned = true;
            this.villageBossAlive = true;

            this.villageBoss = this.add.sprite(ox + VILLAGE_WIDTH / 2, CEMETERY_HEIGHT - 80, 'purple_demon_walk').setDepth(5);
            this.physics.add.existing(this.villageBoss, false);
            this.villageBoss.body.setSize(bt.bw, bt.bh);
            this.villageBoss.body.setCollideWorldBounds(true);
            if (this.anims.exists('purple_demon_walk_anim')) this.villageBoss.play('purple_demon_walk_anim');

            this.villageBoss.stats = {
                name: bt.name, hp: hp, maxHp: hp,
                damage: dmg, exp: exp, speed: spd,
                bw: bt.bw, bh: bt.bh,
                meteorTimer: 0, meteorInterval: bt.meteorInterval,
                meteorRadius: bt.meteorRadius, meteorDmgMul: bt.meteorDmgMul,
                corpseTimer: 0, corpseInterval: bt.corpseInterval,
                corpseCount: bt.corpseCount,
                splitThreshold: bt.splitThreshold,
                splitDone: false
            };

            const hw = bt.bw + 20;
            this.villageBoss.hpBg = this.add.rectangle(ox + VILLAGE_WIDTH / 2, 100, hw, 5, 0x333333).setOrigin(0.5).setDepth(15).setScrollFactor(0);
            this.villageBoss.hpFill = this.add.rectangle(ox + VILLAGE_WIDTH / 2, 100, hw, 5, 0x8a30a0).setOrigin(0.5).setDepth(15).setScrollFactor(0);
            this.villageBossNameText = this.add.text(ox + VILLAGE_WIDTH / 2, 85, bt.name, {
                fontSize: '12px', fill: '#bf77f6', fontFamily: 'Arial', fontStyle: 'bold',
                stroke: '#000', strokeThickness: 2
            }).setOrigin(0.5).setDepth(15).setScrollFactor(0);

            if (this.enemies) this.enemies.add(this.villageBoss);

            try { playBossAoE(); } catch(e) {}
            this.floatingText(ox + VILLAGE_WIDTH / 2, CEMETERY_HEIGHT / 2, 'PURPLE DEMON AWAKENS!', '#8a30a0');
        } catch(e) {
            console.error('[Cemetery] Boss spawn error:', e);
            this.villageBossSpawned = false;
            this.villageBossAlive = false;
        }
    }

    _updateVillageBoss() {
        if (!this.villageBossAlive || !this.villageBoss || !this.villageBoss.active) return;
        const b = this.villageBoss;
        const s = b.stats;
        const ox = this.villageOffsetX;

        b.hpBg.x = ox + VILLAGE_WIDTH / 2;
        b.hpBg.y = 100;
        b.hpFill.x = ox + VILLAGE_WIDTH / 2;
        b.hpFill.y = 100;

        if (this.menuOpen || this.transitioning) {
            b.body.setVelocity(0);
            return;
        }

        const dx = this.player.x - b.x;
        const dy = this.player.y - b.y;
        const dist = Math.sqrt(dx * dx + dy * dy);

        if (dist > 40) {
            b.body.setVelocity((dx / dist) * s.speed, (dy / dist) * s.speed);
            b.setFlipX(dx < 0);
        } else {
            b.body.setVelocity(0);
        }

        s.meteorTimer += this.game.loop.delta;
        if (s.meteorTimer >= s.meteorInterval) {
            s.meteorTimer = 0;
            this._villageBossMeteor(b);
        }

        s.corpseTimer += this.game.loop.delta;
        if (s.corpseTimer >= s.corpseInterval) {
            s.corpseTimer = 0;
            this._villageBossSummonCorpses(b);
        }

        if (!s.splitDone && s.hp / s.maxHp <= s.splitThreshold) {
            s.splitDone = true;
            this._villageBossSplit(b);
        }
    }

    _villageBossMeteor(boss) {
        const ox = this.villageOffsetX;
        const dmg = Math.floor(boss.stats.damage * boss.stats.meteorDmgMul);
        playBossAoE();

        const meteorCount = 3;
        for (let i = 0; i < meteorCount; i++) {
            const mx = ox + 80 + Math.random() * (VILLAGE_WIDTH - 160);
            const my = this.player.y - 20 + Math.random() * 40;

            const warning = this.add.circle(mx, my, 15, 0xff4400, 0.4).setDepth(12);
            this.tweens.add({
                targets: warning, alpha: 0, duration: 600,
                onComplete: () => warning.destroy()
            });

            this.time.delayedCall(600, () => {
                const meteor = this.add.sprite(mx, my - 100, 'meteor_vfx').setDepth(10);
                this.tweens.add({
                    targets: meteor, y: my, duration: 300, ease: 'Quad.easeIn',
                    onComplete: () => {
                        meteor.destroy();
                        const dist = Phaser.Math.Distance.Between(mx, my, this.player.x, this.player.y);
                        if (dist < boss.stats.meteorRadius) {
                            this.takeDamage(dmg);
                            this.floatingText(this.player.x, this.player.y - 30, 'METEOR!', '#ff4400');
                        }
                        const ring = this.add.circle(mx, my, 5, 0xff4400, 0.6).setDepth(12);
                        this.tweens.add({
                            targets: ring, scaleX: 5, scaleY: 5, alpha: 0, duration: 400,
                            onComplete: () => ring.destroy()
                        });
                    }
                });
            });
        }
    }

    _villageBossSummonCorpses(boss) {
        const ox = this.villageOffsetX;
        playBossAoE();
        this.floatingText(boss.x, boss.y - 40, 'RISE!', '#5a6a4a');

        for (let i = 0; i < boss.stats.corpseCount; i++) {
            const angle = (i / boss.stats.corpseCount) * Math.PI * 2;
            const sx = boss.x + Math.cos(angle) * 60;
            const sy = boss.y + Math.sin(angle) * 50;
            const clampedX = Phaser.Math.Clamp(sx, ox + 20, ox + VILLAGE_WIDTH - 20);
            const clampedY = Phaser.Math.Clamp(sy, 20, CEMETERY_HEIGHT - 20);
            this._spawnVillageZombie(clampedX, clampedY);
        }
    }

    _spawnVillageZombie(x, y) {
        const bt = VILLAGE_CORPSE_MINION;
        const e = this.add.sprite(x, y, 'zombie_walk').setDepth(5);
        this.physics.add.existing(e, false);
        e.body.setSize(bt.bw, bt.bh);
        e.body.setCollideWorldBounds(true);
        if (this.anims.exists('zombie_walk_anim')) e.play('zombie_walk_anim');

        e.stats = {
            key: bt.key, name: bt.name,
            hp: Math.floor(bt.hp * this.diffMulti.hp),
            maxHp: Math.floor(bt.hp * this.diffMulti.hp),
            damage: Math.floor(bt.dmg * this.diffMulti.dmg),
            exp: Math.floor(bt.exp * this.diffMulti.exp),
            bw: bt.bw, bh: bt.bh
        };

        const hw = bt.bw + 4;
        e.hpBg = this.add.rectangle(x, y - bt.bh / 2 - 6, hw, 3, 0x333333).setOrigin(0.5).setDepth(11);
        e.hpFill = this.add.rectangle(x, y - bt.bh / 2 - 6, hw, 3, 0x5a6a4a).setOrigin(0.5).setDepth(11);
        this.villageZombies.add(e);
    }

    _villageBossSplit(boss) {
        this.floatingText(boss.x, boss.y - 40, 'SPLIT!', '#ff0000');
        playBossAoE();

        this.villageBossClones = [];
        const ox = this.villageOffsetX;
        const bt = VILLAGE_BOSS_TYPE;
        const fullHp = Math.floor(bt.hp[this.difficulty] || bt.hp.Normal);
        const fullDmg = Math.floor(bt.dmg[this.difficulty] || bt.dmg.Normal);
        const fullSpd = bt.speeds[this.difficulty] || bt.speeds.Normal;

        for (let i = 0; i < 2; i++) {
            const angle = (i / 2) * Math.PI * 2;
            const sx = boss.x + Math.cos(angle) * 70;
            const sy = boss.y + Math.sin(angle) * 60;
            const clampX = Phaser.Math.Clamp(sx, ox + 20, ox + VILLAGE_WIDTH - 20);
            const clampY = Phaser.Math.Clamp(sy, 20, CEMETERY_HEIGHT - 20);

            const clone = this.add.sprite(clampX, clampY, 'purple_demon_walk').setDepth(5).setAlpha(1);
            this.physics.add.existing(clone, false);
            clone.body.setSize(bt.bw, bt.bh);
            clone.body.setCollideWorldBounds(true);
            if (this.anims.exists('purple_demon_walk_anim')) clone.play('purple_demon_walk_anim');

            clone.stats = {
                key: 'purple_demon_clone_' + i, name: bt.name,
                hp: fullHp, maxHp: fullHp, damage: fullDmg,
                exp: Math.floor(bt.exp[this.difficulty] || bt.exp.Normal) * 0.5 | 0,
                speed: fullSpd, bw: bt.bw, bh: bt.bh,
                isBossClone: true,
                meteorTimer: 0, meteorInterval: bt.meteorInterval,
                meteorRadius: bt.meteorRadius, meteorDmgMul: bt.meteorDmgMul,
                corpseTimer: 0, corpseInterval: bt.corpseInterval,
                corpseCount: bt.corpseCount,
                wTimer: 0, wDir: 0
            };

            const hw = bt.bw + 10;
            clone.hpBg = this.add.rectangle(clampX, clampY - bt.bh / 2 - 8, hw, 4, 0x333333).setOrigin(0.5).setDepth(11);
            clone.hpFill = this.add.rectangle(clampX, clampY - bt.bh / 2 - 8, hw, 4, 0x8a30a0).setOrigin(0.5).setDepth(11);

            this.enemies.add(clone);
            this.villageBossClones.push(clone);
        }

        boss.body.setVelocity(0);
        this.tweens.add({
            targets: boss, alpha: 0, scaleX: 0.5, scaleY: 0.5, duration: 500,
            onComplete: () => {
                if (boss.hpBg) boss.hpBg.destroy();
                if (boss.hpFill) boss.hpFill.destroy();
                if (boss.active) boss.destroy();
            }
        });
        if (this.villageBossNameText) this.villageBossNameText.destroy();
        this.villageBoss = null;
        this.villageBossAlive = false;

        this.floatingText(ox + VILLAGE_WIDTH / 2, CEMETERY_HEIGHT / 2, 'DEMON CLONES APPEAR!', '#ff4444');
    }

    _killBossClone(clone) {
        if (clone._killed) return;
        clone._killed = true;
        clone.body.setVelocity(0);
        clone.setTint(0xff0000);
        const exp = clone.stats.exp;
        if (exp > 0) {
            const expBonus = 1 + (this.accountEffects ? (this.accountEffects.expPercent || 0) / 100 : 0);
            this.playerExp += exp;
            this.accountExp += Math.floor(exp * expBonus);
            this.floatingText(clone.x, clone.y - 30, '+' + exp + ' EXP', '#f1c40f');
        }

        this.tweens.add({
            targets: clone, alpha: 0, scaleX: 1.5, scaleY: 1.5, duration: 800,
            onComplete: () => {
                if (clone.hpBg) clone.hpBg.destroy();
                if (clone.hpFill) clone.hpFill.destroy();
                clone.destroy();
            }
        });

        if (clone.stats && clone.stats.key) {
            recordKill(clone.stats.key);
            recordSoulCollect(clone.stats.key);
            onKill(clone.stats.key);
        }
        this.kills++;
        this._updateQuestIcons();

        if (this.villageBossClones) {
            const idx = this.villageBossClones.indexOf(clone);
            if (idx !== -1) this.villageBossClones.splice(idx, 1);
        }

        if (!this.villageBossClones || this.villageBossClones.length === 0) {
            this.time.delayedCall(800, () => {
                this._victoryBossClone();
            });
        }
    }

    _victoryBossClone() {
        const ox = this.villageOffsetX;
        this.villageBossDefeated = true;
        playBossDeath();

        this.defeatedText = this.add.text(ox + VILLAGE_WIDTH / 2, 250, 'PURPLE DEMON DEFEATED!', {
            fontSize: '26px', fill: '#8a30a0', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 4
        }).setOrigin(0.5).setScrollFactor(0);
        this.tweens.add({
            targets: this.defeatedText, alpha: 0, duration: 5000,
            onComplete: () => { if (this.defeatedText) this.defeatedText.destroy(); this.defeatedText = null; }
        });

        this.defeatedLoot = [];
        const lootItems = [];

        const magmaArmor = { ...MAGMA_ARMOR, type: 'equip' };
        if (this.addEquip(magmaArmor)) {
            lootItems.push(magmaArmor);
            playLoot();
        }

        if (Math.random() < 0.6) {
            const item = rollEquip();
            if (this.addEquip(item)) {
                lootItems.push(item);
                playLoot();
            }
        }

        if (Math.random() < BOSS_DROP_CHANCE) {
            const accItem = rollVillageAccountEquip();
            if (this.addAccountEquip(accItem)) {
                lootItems.push({ ...accItem, name: accItem.name + ' [ACCOUNT]' });
                playLoot();
            }
        }

        if (Math.random() < 0.3) {
            const accItem2 = rollAccountEquip();
            if (this.addAccountEquip(accItem2)) {
                lootItems.push({ ...accItem2, name: accItem2.name + ' [ACCOUNT]' });
                playLoot();
            }
        }

        lootItems.forEach((item, i) => {
            const rc = '#' + RARITY_COLORS[item.rarity].toString(16).padStart(6, '0');
            const lt = this.add.text(this.villageOffsetX + VILLAGE_WIDTH / 2, 280 + i * 22, '+' + item.name, {
                fontSize: '14px', fill: rc, fontFamily: 'Arial', fontStyle: 'bold',
                stroke: '#000', strokeThickness: 2
            }).setOrigin(0.5).setScrollFactor(0);
            this.defeatedLoot.push(lt);
            this.tweens.add({
                targets: lt, alpha: 0, duration: 5000,
                onComplete: () => { if (lt.active) lt.destroy(); }
            });
        });

        this.time.delayedCall(6000, () => {
            if (this.zone === 'cemetery') {
                this.floatingText(this.villageOffsetX + VILLAGE_WIDTH / 2, CEMETERY_HEIGHT / 2,
                    'Village saved... for now.', '#2ecc71');
            }
        });

        this.hellPortal = this.add.rectangle(this.villageOffsetX + VILLAGE_WIDTH / 2, CEMETERY_HEIGHT - 40, 60, 12, 0xff2200, 0.5).setDepth(2);
        this.hellPortalHint = this.add.text(this.villageOffsetX + VILLAGE_WIDTH / 2, CEMETERY_HEIGHT - 55, '', {
            fontSize: '11px', fill: '#f1c40f', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 2
        }).setOrigin(0.5).setDepth(12);

        this.checkLevelUp();
        this._checkAccountLevelUp();
        this.updateUI();
    }

    // ===== HELL ZONE =====
    _setupHell() {
        this._destroyOrphanedCaveStairs();
        const ox = (GAME_WIDTH - HELL_WIDTH) / 2;
        this.cameras.main.setBackgroundColor('#1a0000');
        this.physics.world.setBounds(ox, 0, HELL_WIDTH, HELL_HEIGHT);
        this.cameras.main.setBounds(ox, 0, HELL_WIDTH, HELL_HEIGHT);
        this.hellOffsetX = ox;

        this.hellBg = this.add.tileSprite(ox, 0, HELL_WIDTH, HELL_HEIGHT, 'hell_ground')
            .setOrigin(0, 0).setDepth(0);

        this.player.x = ox + HELL_WIDTH / 2;
        this.player.y = 50;
        this.player.body.setCollideWorldBounds(true);
        this.cameras.main.startFollow(this.player, true, 0.08, 0.08);
        this.cameras.main.setDeadzone(50, 40);

        this.enemies = this.physics.add.group();
        this.hellImps = this.physics.add.group();
        this.hellLavaCircles = [];
        this.hellBoss = null;
        this.hellBossDefeated = false;
        this.hellBossSpawned = false;
        this.hellHeatTimer = 0;
        this.hellLavaCooldown = false;
        this.hellReturnPortal = null;

        this._spawnHellCamps();
        this._spawnHellLavaCircles();

        this.physics.add.overlap(this.player, this.enemies, (p, e) => {
            if (e.active && e.stats && !this.menuOpen && !this.transitioning) {
                this.takeDamage(e.stats.damage);
            }
        }, null, this);

        this.physics.add.overlap(this.player, this.hellImps, (p, e) => {
            if (e.active && e.stats && !this.menuOpen && !this.transitioning) {
                this.takeDamage(e.stats.damage);
            }
        }, null, this);

        this.zone = 'hell';
        this.hintText.setText('SPACE=attack | I=inventory | TAB=stats | T=talents | C=craft | Q=quests | P=pause');
    }

    _clearHell() {
        this.physics.world.colliders.destroy();
        if (this.fireballs) {
            this.fireballs.forEach(fb => { if (fb.glow) fb.glow.destroy(); fb.destroy(); });
            this.fireballs = [];
        }
        if (this.shieldActive) {
            this.shieldActive = false;
            this.shieldHP = 0;
            if (this.shieldVfx) { this.shieldVfx.destroy(); this.shieldVfx = null; }
        }
        if (this.enemies && this.enemies.getLength && this.enemies.getLength() > 0) {
            this.enemies.getChildren().forEach(e => {
                if (e.hpBg) e.hpBg.destroy();
                if (e.hpFill) e.hpFill.destroy();
                if (e.nameText) e.nameText.destroy();
            });
            this.enemies.clear(true, true);
        }
        if (this.enemies) { this.enemies.destroy(); this.enemies = null; }
        if (this.hellImps && this.hellImps.getLength && this.hellImps.getLength() > 0) {
            this.hellImps.getChildren().forEach(e => {
                if (e.hpBg) e.hpBg.destroy();
                if (e.hpFill) e.hpFill.destroy();
            });
            this.hellImps.clear(true, true);
        }
        if (this.hellImps) { this.hellImps.destroy(); this.hellImps = null; }
        if (this.hellLavaCircles) {
            this.hellLavaCircles.forEach(lc => {
                if (lc.gfx) lc.gfx.destroy();
                if (lc.vfx) lc.vfx.destroy();
            });
            this.hellLavaCircles = null;
        }
        if (this.hellBoss) {
            if (this.hellBoss.hpBg) this.hellBoss.hpBg.destroy();
            if (this.hellBoss.hpFill) this.hellBoss.hpFill.destroy();
            if (this.hellBossNameText) this.hellBossNameText.destroy();
            this.hellBoss.destroy();
            this.hellBoss = null;
        }
        if (this.hellBossFireWaveVfx) {
            this.hellBossFireWaveVfx.forEach(v => { if (v && v.destroy) v.destroy(); });
            this.hellBossFireWaveVfx = null;
        }
        if (this.hellBg) { this.hellBg.destroy(); this.hellBg = null; }
        if (this.hellReturnPortal) { if (this.hellReturnPortal.destroy) this.hellReturnPortal.destroy(); this.hellReturnPortal = null; }
        if (this.hellReturnPortalHint) { this.hellReturnPortalHint.destroy(); this.hellReturnPortalHint = null; }
        if (this.defeatedText) { this.defeatedText.destroy(); this.defeatedText = null; }
        if (this.defeatedLoot) {
            this.defeatedLoot.forEach(t => { if (t && t.destroy) t.destroy(); });
            this.defeatedLoot = null;
        }
    }

    _spawnHellCamps() {
        const ox = this.hellOffsetX;
        const roleOrder = ['tank', 'assassin', 'archer', 'mage', 'healer'];
        for (let i = 0; i < HELL_CAMP_COUNT; i++) {
            const cp = HELL_CAMP_POSITIONS[i];
            for (let j = 0; j < HELL_MOBS_PER_CAMP; j++) {
                const role = roleOrder[j];
                const t = HELL_ENEMY_TYPES[role];
                const angle = (j / HELL_MOBS_PER_CAMP) * Math.PI * 2;
                const ex = ox + cp.x + Math.cos(angle) * 35;
                const ey = cp.y + Math.sin(angle) * 30;
                this._makeHellEnemy(t, ex, ey, i);
            }
        }
    }

    _makeHellEnemy(t, x, y, campIndex) {
        const walkTex = t.key + '_walk';
        const animKey = t.key + '_walk_anim';
        const e = this.add.sprite(x, y, walkTex).setDepth(5);
        this.physics.add.existing(e, false);
        e.body.setSize(t.bw, t.bh);
        e.body.setCollideWorldBounds(true);
        if (this.anims.exists(animKey)) e.play(animKey);

        e.stats = {
            key: t.key, name: t.name,
            hp: Math.floor(t.hp * this.diffMulti.hp),
            maxHp: Math.floor(t.hp * this.diffMulti.hp),
            damage: Math.floor(t.dmg * this.diffMulti.dmg),
            exp: Math.floor(t.exp * this.diffMulti.exp),
            bw: t.bw, bh: t.bh, role: t.role,
            campIndex: campIndex
        };

        const hpW = t.bw + 10;
        e.hpBg = this.add.rectangle(x, y - t.bh / 2 - 8, hpW, 4, 0x000000).setOrigin(0.5).setDepth(6);
        e.hpFill = this.add.rectangle(x, y - t.bh / 2 - 8, hpW, 4, 0xff0000).setOrigin(0.5).setDepth(6);

        this.enemies.add(e);
        return e;
    }

    _spawnHellLavaCircles() {
        const ox = this.hellOffsetX;
        HELL_LAVA_POSITIONS.forEach(lp => {
            const gfx = this.add.sprite(ox + lp.x, lp.y, 'hell_lava_circle').setDepth(1).setAlpha(0.4);
            const vfx = this.add.sprite(ox + lp.x, lp.y, 'hell_lava_circle').setDepth(1).setAlpha(0).setScale(1);
            this.hellLavaCircles.push({ x: ox + lp.x, y: lp.y, r: lp.r, gfx, vfx, timer: 0 });
        });
    }

    _updateHellLava(time, delta) {
        if (!this.hellLavaCircles || this.zone !== 'hell' || this.menuOpen || this.transitioning) return;
        this.hellLavaCircles.forEach(lc => {
            lc.timer += delta;
            if (lc.timer >= 4000) {
                lc.timer = 0;
                lc.vfx.setAlpha(0.6).setScale(1);
                this.tweens.add({
                    targets: lc.vfx, scaleX: 1.5, scaleY: 1.5, alpha: 0, duration: 1000,
                    ease: 'Quad.easeOut'
                });
            }
            const dist = Phaser.Math.Distance.Between(this.player.x, this.player.y, lc.x, lc.y);
            if (dist < lc.r && !this.hellLavaCooldown) {
                this.takeDamage(HELL_LAVA_DAMAGE);
                this.hellLavaCooldown = true;
                this.time.delayedCall(HELL_LAVA_INTERVAL, () => { this.hellLavaCooldown = false; });
            }
        });
    }

    _updateHellMobs() {
        if (this.zone !== 'hell' || this.menuOpen || this.transitioning) return;
        if (!this.enemies) return;

        if (this.enemies.getLength() === 0 && !this.hellBossSpawned && !this.hellBossDefeated) {
            this._spawnHellBoss();
        }

        this.hellHeatTimer += this.game.loop.delta;
        if (this.hellHeatTimer >= 1000) {
            this.hellHeatTimer = 0;
            if (!this.equipment.armor || this.equipment.armor.id !== 'magma_armor') {
                this.takeDamage(HELL_HEAT_DAMAGE);
                this.cameras.main.flash(200, 255, 0, 0, true);
            }
        }

        this.enemies.getChildren().forEach(e => {
            if (!e.active || !e.stats) return;

            const dx = this.player.x - e.x;
            const dy = this.player.y - e.y;
            const dist = Math.sqrt(dx * dx + dy * dy);

            if (dist < 250) {
                let speed = 50;
                let engageDist = 30;

                switch (e.stats.role) {
                    case 'tank':     speed = 40; engageDist = 25; break;
                    case 'assassin': speed = 90; engageDist = 20; break;
                    case 'archer':   speed = 45; engageDist = 150; break;
                    case 'mage':     speed = 40; engageDist = 180; break;
                    case 'healer':   speed = 45; engageDist = 120; break;
                }

                if (dist > engageDist) {
                    if (e.stats.role === 'tank' || e.stats.role === 'assassin') {
                        e.body.setVelocity((dx / dist) * speed, (dy / dist) * speed);
                    } else if (e.stats.role === 'archer' || e.stats.role === 'mage') {
                        e.body.setVelocity((dx / dist) * speed * 0.3, (dy / dist) * speed * 0.3);
                    } else {
                        e.body.setVelocity((dx / dist) * speed, (dy / dist) * speed);
                    }
                    e.setFlipX(dx < 0);
                } else {
                    e.body.setVelocity(0);
                }

                if (e.stats.role === 'healer' && dist < 180) {
                    this.enemies.getChildren().forEach(ally => {
                        if (ally !== e && ally.active && ally.stats && ally.stats.hp < ally.stats.maxHp) {
                            const ad = Phaser.Math.Distance.Between(e.x, e.y, ally.x, ally.y);
                            if (ad < 100) {
                                ally.stats.hp = Math.min(ally.stats.maxHp, ally.stats.hp + 3);
                                if (ally.hpFill) ally.hpFill.width = ally.hpBg.width * (ally.stats.hp / ally.stats.maxHp);
                            }
                        }
                    });
                }
            } else {
                e.body.setVelocity(0);
            }

            if (e.hpBg) { e.hpBg.x = e.x; e.hpBg.y = e.y - e.stats.bh / 2 - 8; }
            if (e.hpFill) { e.hpFill.x = e.x; e.hpFill.y = e.y - e.stats.bh / 2 - 8; }
        });
    }

    _spawnHellBoss() {
        if (this.hellBossSpawned) return;
        this.hellBossSpawned = true;
        const bt = HELL_BOSS_TYPE;
        const ox = this.hellOffsetX;
        const hp = Math.floor(bt.hp[this.difficulty] || bt.hp.Normal);
        const dmg = Math.floor(bt.dmg[this.difficulty] || bt.dmg.Normal);
        const exp = Math.floor(bt.exp[this.difficulty] || bt.exp.Normal);
        const spd = bt.speeds[this.difficulty] || bt.speeds.Normal;

        const bx = ox + HELL_WIDTH / 2;
        const by = HELL_HEIGHT / 2;
        const b = this.add.sprite(bx, by, 'red_demon_walk').setDepth(5);
        this.physics.add.existing(b, false);
        b.body.setSize(bt.bw, bt.bh);
        b.body.setCollideWorldBounds(true);
        if (this.anims.exists('red_demon_walk_anim')) b.play('red_demon_walk_anim');

        b.stats = {
            key: bt.key, name: bt.name,
            hp, maxHp: hp, damage: dmg, exp,
            speed: spd, bw: bt.bw, bh: bt.bh,
            aoeTimer: 0, aoeInterval: bt.fireWaveInterval,
            meteorTimer: 0, meteorInterval: bt.meteorInterval,
            summonTimer: 0, summonInterval: bt.summonInterval
        };

        const hpW = 80;
        b.hpBg = this.add.rectangle(400, 110, hpW, 6, 0x000000).setDepth(12).setScrollFactor(0);
        b.hpFill = this.add.rectangle(400 - hpW / 2, 110, hpW, 6, 0xff2200).setOrigin(0, 0.5).setDepth(12).setScrollFactor(0);
        b.hpBg.setVisible(false);
        b.hpFill.setVisible(false);
        this.hellBossNameText = this.add.text(400, 95, bt.name, {
            fontSize: '14px', fill: '#ff4400', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 3
        }).setOrigin(0.5).setDepth(12).setScrollFactor(0).setVisible(false);

        this.hellBoss = b;
        this.hellBossFireWaveVfx = [];
        this.enemies.add(b);

        this.floatingText(bx, by - 60, 'RED DEMON APPEARS!', '#ff2200');
    }

    _updateHellBoss() {
        if (!this.hellBoss || !this.hellBoss.active) return;
        const b = this.hellBoss;
        const s = b.stats;

        if (this.menuOpen || this.transitioning) {
            b.body.setVelocity(0);
            return;
        }

        if (s.hp > 0) {
            b.hpBg.setVisible(true);
            b.hpFill.setVisible(true);
            this.hellBossNameText.setVisible(true);
            b.hpBg.x = 400;
            b.hpBg.y = 110;
            b.hpFill.x = 400 - 40;
            b.hpFill.y = 110;
            b.hpFill.width = 80 * (s.hp / s.maxHp);
        }

        const dx = this.player.x - b.x;
        const dy = this.player.y - b.y;
        const dist = Math.sqrt(dx * dx + dy * dy);

        if (dist > 30) {
            const nx = dx / dist;
            const ny = dy / dist;
            b.body.setVelocity(nx * s.speed, ny * s.speed);
            if (this.anims.exists('red_demon_walk_anim') && !b.anims.isPlaying) b.play('red_demon_walk_anim');
            b.setFlipX(dx < 0);
        } else {
            b.body.setVelocity(0);
        }

        const delta = this.game.loop.delta;

        s.aoeTimer += delta;
        if (s.aoeTimer >= s.aoeInterval) {
            s.aoeTimer = 0;
            this._hellBossFireWave(b);
        }

        s.meteorTimer += delta;
        if (s.meteorTimer >= s.meteorInterval) {
            s.meteorTimer = 0;
            this._hellBossMeteor(b);
        }

        s.summonTimer += delta;
        if (s.summonTimer >= s.summonInterval) {
            s.summonTimer = 0;
            this._hellBossSummon(b);
        }
    }

    _hellBossFireWave(boss) {
        if (!boss || !boss.active) return;
        const dx = this.player.x - boss.x;
        const dy = this.player.y - boss.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist > 200) return;

        const dmg = Math.floor(boss.stats.damage * HELL_BOSS_TYPE.fireWaveDmgMul);
        const radius = HELL_BOSS_TYPE.fireWaveRadius;

        const vfx = this.add.sprite(boss.x, boss.y, 'fire_wave_vfx').setDepth(8).setScale(2).setAlpha(0.7);
        this.hellBossFireWaveVfx.push(vfx);
        this.tweens.add({
            targets: vfx, x: this.player.x, y: this.player.y, alpha: 0, duration: 500,
            onComplete: () => { if (vfx.active) vfx.destroy(); }
        });

        this.time.delayedCall(500, () => {
            const pd = Phaser.Math.Distance.Between(boss.x, boss.y, this.player.x, this.player.y);
            if (pd < radius) {
                this.takeDamage(dmg);
                this.floatingText(this.player.x, this.player.y - 20, '-' + dmg + ' FIRE WAVE', '#ff4400');
            }
        });
    }

    _hellBossMeteor(boss) {
        if (!boss || !boss.active) return;
        const ox = this.hellOffsetX;
        for (let i = 0; i < 3; i++) {
            const mx = this.player.x + Phaser.Math.Between(-80, 80);
            const my = this.player.y + Phaser.Math.Between(-80, 80);
            const clampedX = Phaser.Math.Clamp(mx, ox + 20, ox + HELL_WIDTH - 20);
            const clampedY = Phaser.Math.Clamp(my, 20, HELL_HEIGHT - 20);

            const meteor = this.add.sprite(clampedX, clampedY - 200, 'meteor_vfx').setDepth(8).setAlpha(0.8);
            this.tweens.add({
                targets: meteor, y: clampedY, alpha: 1, duration: 800, delay: i * 200,
                ease: 'Quad.easeIn',
                onComplete: () => {
                    if (meteor.active) meteor.destroy();
                    const pd = Phaser.Math.Distance.Between(clampedX, clampedY, this.player.x, this.player.y);
                    if (pd < HELL_BOSS_TYPE.meteorRadius) {
                        const dmg = Math.floor(boss.stats.damage * HELL_BOSS_TYPE.meteorDmgMul);
                        this.takeDamage(dmg);
                        this.floatingText(this.player.x, this.player.y - 20, '-' + dmg + ' METEOR', '#ff6600');
                    }
                }
            });
        }
    }

    _hellBossSummon(boss) {
        if (!boss || !boss.active) return;
        const bt = HELL_BOSS_MINION;
        const ox = this.hellOffsetX;
        for (let i = 0; i < HELL_BOSS_TYPE.summonCount; i++) {
            const angle = (i / HELL_BOSS_TYPE.summonCount) * Math.PI * 2;
            const ix = boss.x + Math.cos(angle) * 60;
            const iy = boss.y + Math.sin(angle) * 60;
            const clampedX = Phaser.Math.Clamp(ix, ox + 10, ox + HELL_WIDTH - 10);
            const clampedY = Phaser.Math.Clamp(iy, 10, HELL_HEIGHT - 10);

            const imp = this.add.sprite(clampedX, clampedY, 'hell_imp_walk').setDepth(5);
            this.physics.add.existing(imp, false);
            imp.body.setSize(bt.bw, bt.bh);
            imp.body.setCollideWorldBounds(true);
            if (this.anims.exists('hell_imp_walk_anim')) imp.play('hell_imp_walk_anim');

            const hp = Math.floor(bt.hp * this.diffMulti.hp);
            imp.stats = {
                key: bt.key, name: bt.name,
                hp, maxHp: hp,
                damage: Math.floor(bt.dmg * this.diffMulti.dmg),
                exp: Math.floor(bt.exp * this.diffMulti.exp),
                bw: bt.bw, bh: bt.bh, speed: 80
            };

            const hpW = bt.bw + 6;
            imp.hpBg = this.add.rectangle(clampedX, clampedY - bt.bh / 2 - 6, hpW, 3, 0x000000).setDepth(6);
            imp.hpFill = this.add.rectangle(clampedX - hpW / 2, clampedY - bt.bh / 2 - 6, hpW, 3, 0xff0000).setOrigin(0, 0.5).setDepth(6);

            this.hellImps.add(imp);
        }
        this.floatingText(boss.x, boss.y - 50, 'SUMMONED ' + HELL_BOSS_TYPE.summonCount + ' IMPS!', '#ff4400');
    }

    _victoryHellBoss() {
        if (this.hellBossDefeated) return;
        this.hellBossDefeated = true;
        playBossDeath();
        const ox = this.hellOffsetX;

        if (this.hellBoss) {
            if (this.hellBoss.hpBg) this.hellBoss.hpBg.destroy();
            if (this.hellBoss.hpFill) this.hellBoss.hpFill.destroy();
            if (this.hellBossNameText) this.hellBossNameText.destroy();
            this.hellBoss.destroy();
            this.hellBoss = null;
        }

        this.defeatedText = this.add.text(ox + HELL_WIDTH / 2, 250, 'RED DEMON DEFEATED!', {
            fontSize: '26px', fill: '#ff2200', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 4
        }).setOrigin(0.5).setScrollFactor(0);
        this.tweens.add({
            targets: this.defeatedText, alpha: 0, duration: 5000,
            onComplete: () => { if (this.defeatedText) this.defeatedText.destroy(); this.defeatedText = null; }
        });

        this.defeatedLoot = [];
        const lootItems = [];

        const crystal = { ...HEAT_CRYSTAL, type: 'equip' };
        if (this.addEquip(crystal)) {
            lootItems.push(crystal);
            playLoot();
        }

        if (Math.random() < 0.6) {
            const item = rollEquip();
            if (this.addEquip(item)) {
                lootItems.push(item);
                playLoot();
            }
        }

        if (Math.random() < BOSS_DROP_CHANCE) {
            const accItem = rollAccountEquip();
            if (this.addAccountEquip(accItem)) {
                lootItems.push({ ...accItem, name: accItem.name + ' [ACCOUNT]' });
                playLoot();
            }
        }

        lootItems.forEach((item, i) => {
            const rc = '#' + RARITY_COLORS[item.rarity].toString(16).padStart(6, '0');
            const lt = this.add.text(ox + HELL_WIDTH / 2, 280 + i * 22, '+' + item.name, {
                fontSize: '14px', fill: rc, fontFamily: 'Arial', fontStyle: 'bold',
                stroke: '#000', strokeThickness: 2
            }).setOrigin(0.5).setScrollFactor(0);
            this.defeatedLoot.push(lt);
            this.tweens.add({
                targets: lt, alpha: 0, duration: 5000,
                onComplete: () => { if (lt.active) lt.destroy(); }
            });
        });

        this.hellReturnPortal = this.add.rectangle(ox + HELL_WIDTH / 2, HELL_HEIGHT / 2 + 60, 60, 12, 0xff2200, 0.5).setDepth(2);
        this.hellReturnPortalHint = this.add.text(ox + HELL_WIDTH / 2, HELL_HEIGHT / 2 + 45, '', {
            fontSize: '11px', fill: '#f1c40f', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 2
        }).setOrigin(0.5).setDepth(12);

        this.time.delayedCall(3000, () => {
            if (this.zone === 'hell') {
                this.floatingText(ox + HELL_WIDTH / 2, HELL_HEIGHT / 2,
                    'Portal to Village appeared!', '#2ecc71');
            }
        });

        this.checkLevelUp();
        this._checkAccountLevelUp();
        this.updateUI();
    }

    _enterHell() {
        if (this.transitioning || this.menuOpen) return;
        if (this.zone !== 'cemetery' || !this.villageBossDefeated) return;
        const ox = this.villageOffsetX;
        const dist = Phaser.Math.Distance.Between(
            this.player.x, this.player.y, ox + VILLAGE_WIDTH / 2, CEMETERY_HEIGHT - 40
        );
        if (dist >= 60) return;

        this.transitioning = true;
        playPortal();
        this.cameras.main.fadeOut(800, 255, 0, 0);
        this.time.delayedCall(800, () => {
            this._clearVillage();
            this._setupHell();
            this.cameras.main.fadeIn(500, 0, 0, 0);
            this.transitioning = false;
        });
    }

    _exitHell() {
        if (this.transitioning || this.menuOpen) return;
        if (this.zone !== 'hell' || !this.hellBossDefeated) return;
        const ox = this.hellOffsetX;
        const dist = Phaser.Math.Distance.Between(
            this.player.x, this.player.y, ox + HELL_WIDTH / 2, HELL_HEIGHT / 2 + 60
        );
        if (dist >= 60) return;

        this.transitioning = true;
        playPortal();
        this.cameras.main.fadeOut(800, 0, 0, 0);
        this.time.delayedCall(800, () => {
            this._clearHell();
            this._setupVillage(!this.villageRestored);
            this.cameras.main.fadeIn(500, 0, 0, 0);
            this.transitioning = false;
        });
    }

    _updateHellImps() {
        if (this.zone !== 'hell' || this.menuOpen || this.transitioning) return;
        if (!this.hellImps) return;
        this.hellImps.getChildren().forEach(e => {
            if (!e.active || !e.stats) return;
            const dx = this.player.x - e.x;
            const dy = this.player.y - e.y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 250) {
                const spd = e.stats.speed || 80;
                if (dist > 20) {
                    e.body.setVelocity((dx / dist) * spd, (dy / dist) * spd);
                    e.setFlipX(dx < 0);
                } else {
                    e.body.setVelocity(0);
                }
            } else {
                e.body.setVelocity(0);
            }
            if (e.hpBg) { e.hpBg.x = e.x; e.hpBg.y = e.y - e.stats.bh / 2 - 6; }
            if (e.hpFill) { e.hpFill.x = e.x; e.hpFill.y = e.y - e.stats.bh / 2 - 6; }
        });
    }

    _updateBoss() {
        if (!this.bossAlive || !this.boss || !this.boss.active) return;
        const b = this.boss;
        const s = b.stats;

        b.hpBg.x = 400;
        b.hpBg.y = 100;
        b.hpFill.x = 400;
        b.hpFill.y = 100;

        if (this.menuOpen || this.transitioning) {
            b.body.setVelocity(0);
            return;
        }

        const dx = this.player.x - b.x;
        const dy = this.player.y - b.y;
        const dist = Math.sqrt(dx * dx + dy * dy);

        if (dist > 30) {
            const nx = dx / dist;
            const ny = dy / dist;
            b.body.setVelocity(nx * s.speed, ny * s.speed);
            if (!b.anims.isPlaying || b.anims.currentAnim.key !== 'treant_walk') {
                b.play('treant_walk');
            }
            b.setFlipX(dx < 0);
        } else {
            b.body.setVelocity(0);
            b.stop();
            b.setFrame(0);
        }

        s.aoeTimer += this.game.loop.delta;
        if (s.aoeTimer >= s.aoeInterval) {
            s.aoeTimer = 0;
            this._bossAoE(b);
        }
    }

    _bossAoE(boss) {
        const aoeDmg = Math.floor(boss.stats.damage * boss.stats.aoeDmgMul);
        const radius = boss.stats.aoeRadius;
        playBossAoE();

        const ring = this.add.sprite(boss.x, boss.y, 'boss_aoe')
            .setAlpha(0.9)
            .setScale(0.3);
        this.tweens.add({
            targets: ring, scaleX: 1.8, scaleY: 1.8, alpha: 0, duration: 500,
            onComplete: () => ring.destroy()
        });

        const ring2 = this.add.sprite(boss.x, boss.y, 'boss_aoe')
            .setAlpha(0.5)
            .setScale(0.1);
        this.tweens.add({
            targets: ring2, scaleX: 1.2, scaleY: 1.2, alpha: 0, duration: 400, delay: 100,
            onComplete: () => ring2.destroy()
        });

        this.time.delayedCall(300, () => {
            const dist = Phaser.Math.Distance.Between(
                this.player.x, this.player.y, boss.x, boss.y
            );
            if (dist < radius) {
                this.takeDamage(aoeDmg);
                const pushX = this.player.x - boss.x;
                const pushY = this.player.y - boss.y;
                const pushDist = Math.sqrt(pushX * pushX + pushY * pushY) || 1;
                this.player.x += (pushX / pushDist) * 40;
                this.player.y += (pushY / pushDist) * 40;
            }
        });
    }

    /* ===== COMBAT ===== */

    takeDamage(amount) {
        if (this.invincible) return;
        amount = Math.floor(amount) || 0;
        if (amount <= 0) return;
        if (this.shieldActive && this.shieldHP > 0) {
            if (this.lifeLinkActive) {
                amount = Math.floor(amount * 0.7);
            }
            const absorbed = Math.min(this.shieldHP, amount);
            this.shieldHP -= absorbed;
            amount -= absorbed;
            if (absorbed > 0) this.floatingText(this.player.x, this.player.y - 20, absorbed + ' blocked', '#3498db');
            if (this.shieldHP <= 0) {
                this.shieldActive = false;
                this.lifeLinkActive = false;
                if (this.shieldVfx) { this.shieldVfx.destroy(); this.shieldVfx = null; }
            }
            if (amount <= 0) return;
        }
        this.playerHP -= amount;
        this.invincible = true;
        this.player.setTint(0xff4444).setAlpha(0.5);
        this.time.delayedCall(500, () => {
            this.player.clearTint();
            this.player.setAlpha(1);
            this.invincible = false;
        });
        if (this.playerHP <= 0) {
            this.playerHP = 0;
            this.respawnPlayer();
        }
        this.updateUI();
    }

    respawnPlayer() {
        if (this.zone === 'arena') {
            this.player.x = 400;
            this.player.y = 500;
        } else if (this.zone === 'mine') {
            this.player.x = MINE_RETURN_POS.x;
            this.player.y = MINE_RETURN_POS.y;
        } else if (this.zone === 'mine_boss') {
            this.player.x = 400;
            this.player.y = 500;
        } else {
            this.player.x = FOREST_RETURN_POS.x;
            this.player.y = FOREST_RETURN_POS.y;
        }
        this.recalcStats();
        this.playerHP = this.playerMaxHP;
        this.cameras.main.shake(200, 0.01);
        this.updateUI();
    }

    attack() {
        if (this.attackCooldown || this.menuOpen || this.transitioning) return;
        if (this.zone === 'arena' && this.bossDefeated) return;
        this.attackCooldown = true;
        this.playerAttacking = true;

        const cls = this.classData || getClassData(this.classKey);
        this.player.play(cls.attackAnim || 'sage_attack');
        this.player.once('animationcomplete', () => {
            this.playerAttacking = false;
        });

        const range = 55;
        let ax = this.player.x, ay = this.player.y;
        if (this.facing === 'right') ax += range;
        else if (this.facing === 'left') ax -= range;
        else if (this.facing === 'up') ay -= range;
        else if (this.facing === 'down') ay += range;

        this._showSlash(ax, ay);
        this._dealAttackDamage(ax, ay);

        this.time.delayedCall(280, () => {
            this.attackCooldown = false;
        });
    }

    _showSlash(ax, ay) {
        const s = this.add.sprite(ax, ay, 'slash').setAlpha(0.9);
        this.tweens.add({
            targets: s, alpha: 0, scaleX: 1.4, scaleY: 1.4, angle: 90,
            duration: 180, onComplete: () => s.destroy()
        });
        this.player.setTint(0xaaddff);
        this.time.delayedCall(100, () => {
            if (this.player.active) this.player.clearTint();
        });
    }

    _dealAttackDamage(ax, ay) {
        if (this.enemies) {
            this.enemies.getChildren().forEach(e => {
                if (!e.active || !e.stats) return;
                if (Phaser.Math.Distance.Between(ax, ay, e.x, e.y) < 35) {
                    this.hitEnemy(e, this.playerDamage);
                }
            });
        }
        if (this.stumps) {
            this.stumps.getChildren().forEach(st => {
                if (!st.active || !st.stats) return;
                if (Phaser.Math.Distance.Between(ax, ay, st.x, st.y) < 35) {
                    this.hitStump(st, this.playerDamage);
                }
            });
        }
        if (this.mineChests) {
            this.mineChests.getChildren().forEach(ch => {
                if (!ch.active || !ch.stats || ch.broken) return;
                if (Phaser.Math.Distance.Between(ax, ay, ch.x, ch.y) < 35) {
                    this.hitChest(ch, this.playerDamage);
                }
            });
        }
        if (this.caveChests) {
            this.caveChests.getChildren().forEach(ch => {
                if (!ch.active || !ch.stats || ch.broken) return;
                if (Phaser.Math.Distance.Between(ax, ay, ch.x, ch.y) < 35) {
                    this.hitChest(ch, this.playerDamage);
                }
            });
        }
        if (this.villageChests) {
            this.villageChests.getChildren().forEach(ch => {
                if (!ch.active || !ch.stats || ch.broken) return;
                if (Phaser.Math.Distance.Between(ax, ay, ch.x, ch.y) < 35) {
                    ch.stats.hp -= this.playerDamage;
                    if (ch.hpFill) ch.hpFill.width = ch.hpBg.width * (ch.stats.hp / ch.stats.maxHp);
                    if (ch.stats.hp <= 0) this.breakVillageChest(ch);
                }
            });
        }
        if (this.villageZombies) {
            this.villageZombies.getChildren().forEach(e => {
                if (!e.active || !e.stats) return;
                if (Phaser.Math.Distance.Between(ax, ay, e.x, e.y) < 35) {
                    this.hitEnemy(e, this.playerDamage);
                }
            });
        }
        if (this.hellImps) {
            this.hellImps.getChildren().forEach(e => {
                if (!e.active || !e.stats) return;
                if (Phaser.Math.Distance.Between(ax, ay, e.x, e.y) < 35) {
                    this.hitEnemy(e, this.playerDamage);
                }
            });
        }
        if (this.snowyIceSpirit && this.snowyIceSpirit.active && this.snowyIceSpirit.stats) {
            if (Phaser.Math.Distance.Between(ax, ay, this.snowyIceSpirit.x, this.snowyIceSpirit.y) < 45) {
                this.hitEnemy(this.snowyIceSpirit, this.playerDamage);
            }
        }
        if (this.snowyIceShards) {
            this.snowyIceShards.getChildren().forEach(s => {
                if (!s.active || !s.stats) return;
                if (Phaser.Math.Distance.Between(ax, ay, s.x, s.y) < 35) {
                    s.stats.hp -= this.playerDamage;
                    this.floatingText(s.x, s.y - 15, '-' + this.playerDamage, '#3498db');
                    if (s.stats.hp <= 0) {
                        if (s.hpBg) s.hpBg.destroy();
                        if (s.hpFill) s.hpFill.destroy();
                        s.destroy();
                    }
                }
            });
        }
    }

    hitEnemy(enemy, damage) {
        let finalDamage = damage;
        const te = this.talentEffects || {};
        const ae = this.accountEffects || {};
        if (te.damagePercentVs && enemy.stats && enemy.stats.key) {
            const bonus = te.damagePercentVs[enemy.stats.key] || 0;
            if (bonus > 0) {
                finalDamage = Math.floor(damage * (1 + bonus / 100));
            }
        }
        if (enemy.stats && enemy.stats.key && this.bestiaryBonuses && this.bestiaryBonuses[enemy.stats.key]) {
            const bb = this.bestiaryBonuses[enemy.stats.key];
            if (bb.dmgBonus > 0) {
                finalDamage = Math.floor(finalDamage * (1 + bb.dmgBonus / 100));
            }
        }
        if (this.computedBossDamage && enemy.stats && (enemy === this.boss || enemy === this.mineBoss || enemy === this.caveBoss || enemy === this.villageBoss || enemy === this.hellBoss || enemy === this.snowyIceSpirit)) {
            finalDamage = Math.floor(finalDamage * (1 + this.computedBossDamage / 100));
        }
        if (this.playerHP <= this.playerMaxHP * 0.3 && (te.damagePercentLowHp || ae.damagePercentLowHp)) {
            finalDamage = Math.floor(finalDamage * (1 + ((te.damagePercentLowHp || 0) + (ae.damagePercentLowHp || 0)) / 100));
        }
        if (this.playerHP === this.playerMaxHP && (te.damagePercentFullHp || ae.damagePercentFullHp)) {
            finalDamage = Math.floor(finalDamage * (1 + ((te.damagePercentFullHp || 0) + (ae.damagePercentFullHp || 0)) / 100));
        }
        if (this.computedCritChance && Math.random() * 100 < this.computedCritChance) {
            finalDamage = Math.floor(finalDamage * this.computedCritDamage);
            this.floatingText(enemy.x, enemy.y - 30, 'CRIT!', '#f1c40f');
        }

        enemy.stats.hp -= finalDamage;
        enemy.setTint(0xffffff);
        this.tweens.add({
            targets: enemy, scaleX: 1.2, scaleY: 1.2, duration: 60, yoyo: true,
            onComplete: () => {
                if (enemy.active) {
                    enemy.clearTint();
                    enemy.setScale(1);
                }
            }
        });
        this.floatingText(enemy.x, enemy.y - 20, '-' + finalDamage, '#e74c3c');

        if (this.computedLifeSteal > 0) {
            const healAmount = Math.floor(finalDamage * this.computedLifeSteal / 100);
            if (healAmount > 0) {
                this.playerHP = Math.min(this.playerMaxHP, this.playerHP + healAmount);
                this.floatingText(this.player.x, this.player.y - 40, '+' + healAmount, '#2ecc71');
            }
        }

        if (enemy.stats.hp <= 0) {
            if (enemy === this.boss) {
                this.killBoss();
            } else if (enemy === this.mineBoss) {
                this.killMineBoss();
            } else if (enemy === this.caveBoss) {
                this.killCaveBoss();
            } else if (enemy === this.villageBoss) {
                const bs = this.villageBoss.stats;
                if (!bs.splitDone && bs.hp / bs.maxHp <= VILLAGE_BOSS_TYPE.splitThreshold) {
                    bs.splitDone = true;
                    this._villageBossSplit(this.villageBoss);
                } else if (bs.hp <= 0 && !bs.splitDone) {
                    bs.splitDone = true;
                    this._villageBossSplit(this.villageBoss);
                }
            } else if (enemy === this.hellBoss) {
                this._victoryHellBoss();
            } else if (enemy === this.snowyIceSpirit) {
                this._snowyIceSpiritDied();
            } else if (enemy.stats && enemy.stats.isBossClone) {
                this._killBossClone(enemy);
            } else {
                this.killEnemy(enemy);
            }
        } else {
            enemy.hpFill.width = enemy.hpBg.width * (enemy.stats.hp / enemy.stats.maxHp);
        }
    }

    hitStump(stump, damage) {
        stump.stats.hp -= damage;
        stump.setTint(0xffffff);
        this.tweens.add({
            targets: stump, scaleX: 1.15, scaleY: 1.15, duration: 60, yoyo: true,
            onComplete: () => {
                if (stump.active) {
                    stump.clearTint();
                    stump.setScale(1);
                }
            }
        });
        this.floatingText(stump.x, stump.y - 20, '-' + damage, '#f39c12');
        if (stump.stats.hp <= 0) {
            this.breakStump(stump);
        } else {
            stump.hpFill.width = stump.hpBg.width * (stump.stats.hp / stump.stats.maxHp);
        }
    }

    killBoss() {
        const b = this.boss;
        const exp = b.stats.exp;
        const expBonus = 1 + (this.accountEffects ? (this.accountEffects.expPercent || 0) / 100 : 0);
        this.playerExp += exp;
        this.accountExp += Math.floor(exp * expBonus);
        this.kills++;
        this.bossAlive = false;
        this.bossDefeated = true;
        playBossDeath();
        recordKill('ancient_treant');
        recordSoulCollect('ancient_treant');
        onKill('ancient_treant');
        this._updateQuestIcons();

        b.body.setVelocity(0);
        b.setTint(0xff0000);
        this.tweens.add({
            targets: b, alpha: 0, scaleX: 1.5, scaleY: 1.5, duration: 800,
            onComplete: () => {
                b.hpBg.destroy();
                b.hpFill.destroy();
                b.destroy();
                this.boss = null;
            }
        });

        if (b.aoeRing) { b.aoeRing.destroy(); b.aoeRing = null; }
        if (b.aoeRing2) { b.aoeRing2.destroy(); b.aoeRing2 = null; }
        if (this.bossNameText) this.bossNameText.destroy();

        this.floatingText(400, 200, '+' + exp + ' EXP', '#f1c40f');

        this.defeatedText = this.add.text(400, 250, 'BOSS DEFEATED!', {
            fontSize: '32px', fill: '#f1c40f', fontFamily: 'Arial', fontStyle: 'bold',
            stroke: '#000', strokeThickness: 4
        }).setOrigin(0.5).setScrollFactor(0);
        this.tweens.add({
            targets: this.defeatedText, alpha: 0, duration: 5000,
            onComplete: () => { if (this.defeatedText) this.defeatedText.destroy(); this.defeatedText = null; }
        });

        this.mineUnlocked = true;

        this.exitPortal.setTexture('mine_ladder');
        this.exitPortal.setScale(1);
        this.exitHint.setText('SPACE to enter the Mine');

        this.defeatedLoot = [];
        const lootItems = [];
        if (Math.random() < BOSS_DROP_CHANCE) {
            const item = rollEquip();
            if (this.addEquip(item)) {
                lootItems.push(item);
                playLoot();
            }
        }
        if (Math.random() < 0.5) {
            const item2 = rollEquip();
            if (this.addEquip(item2)) {
                lootItems.push(item2);
                playLoot();
            }
        }

        // Account equipment drop from boss
        if (Math.random() < BOSS_DROP_CHANCE) {
            const accItem = rollAccountEquip();
            if (this.addAccountEquip(accItem)) {
                lootItems.push({ ...accItem, name: accItem.name + ' [ACCOUNT]' });
                playLoot();
            }
        }

        lootItems.forEach((item, i) => {
            const rc = '#' + RARITY_COLORS[item.rarity].toString(16).padStart(6, '0');
            const lt = this.add.text(400, 300 + i * 24, '+' + item.name, {
                fontSize: '16px', fill: rc, fontFamily: 'Arial', fontStyle: 'bold',
                stroke: '#000', strokeThickness: 2
            }).setOrigin(0.5).setScrollFactor(0);
            this.defeatedLoot.push(lt);
            this.tweens.add({
                targets: lt, alpha: 0, duration: 5000,
                onComplete: () => { if (lt.active) lt.destroy(); }
            });
        });

        if (lootItems.length === 0) {
            const noLoot = this.add.text(400, 300, 'No drops...', {
                fontSize: '14px', fill: '#95a5a6', fontFamily: 'Arial',
                stroke: '#000', strokeThickness: 2
            }).setOrigin(0.5).setScrollFactor(0);
            this.defeatedLoot.push(noLoot);
            this.tweens.add({
                targets: noLoot, alpha: 0, duration: 5000,
                onComplete: () => { if (noLoot.active) noLoot.destroy(); }
            });
        }

        this.checkLevelUp();
        this._checkAccountLevelUp();
        this.updateUI();
    }

    killEnemy(enemy) {
        const exp = enemy.stats.exp;
        const expBonus = 1 + (this.accountEffects ? (this.accountEffects.expPercent || 0) / 100 : 0);
        this.playerExp += exp;
        this.accountExp += Math.floor(exp * expBonus);
        this.kills++;
        playEnemyDeath();

        if (enemy.stats.key) {
            recordKill(enemy.stats.key);
            recordSoulCollect(enemy.stats.key);
            onKill(enemy.stats.key);
            this._updateQuestIcons();
        }

        for (let i = 0; i < 3; i++) {
            const c = this.add.sprite(
                enemy.x + Phaser.Math.Between(-12, 12),
                enemy.y + Phaser.Math.Between(-8, 8),
                'coin'
            );
            this.tweens.add({
                targets: c, y: c.y - 25, alpha: 0,
                duration: 500 + i * 100, delay: i * 80,
                onComplete: () => c.destroy()
            });
        }

        this.floatingText(enemy.x, enemy.y - 30, '+' + exp + ' EXP', '#f1c40f');

        if (Math.random() < EQUIP_DROP_CHANCE) {
            const item = rollEquip();
            if (this.addEquip(item)) {
                const rc = '#' + RARITY_COLORS[item.rarity].toString(16).padStart(6, '0');
                this.floatingText(enemy.x, enemy.y - 45, '+' + item.name, rc);
                playLoot();
            }
        }

        if (Math.random() < ACCOUNT_EQUIP_DROP_CHANCE) {
            const accItem = rollAccountEquip();
            if (this.addAccountEquip(accItem)) {
                const rc = '#' + RARITY_COLORS[accItem.rarity].toString(16).padStart(6, '0');
                this.floatingText(enemy.x, enemy.y - 60, '+' + accItem.name + ' [ACCOUNT]', rc);
                playLoot();
            }
        }

        this.checkLevelUp();
        this._checkAccountLevelUp();
        this.updateUI();

        enemy.hpBg.destroy();
        enemy.hpFill.destroy();
        enemy.destroy();

        this.time.delayedCall(3000, () => {
            if (this.zone === 'forest') {
                const t = ENEMY_TYPES[Math.floor(Math.random() * ENEMY_TYPES.length)];
                this._makeEnemy(t, 80 + Math.random() * 640, 350 + Math.random() * 400);
            } else if (this.zone === 'mine') {
                const t = MINE_ENEMY_TYPES[Math.floor(Math.random() * MINE_ENEMY_TYPES.length)];
                this._makeMineEnemy(t, 80 + Math.random() * 640, 200 + Math.random() * 500);
            }
        });
    }

    breakStump(stump) {
        this.stumpsBroken++;
        playBreak();
        const count = 1 + Math.floor(Math.random() * 2);
        for (let i = 0; i < count; i++) {
            const item = rollMaterial(this.zone);
            if (this.addMaterial(item)) {
                const rc = '#' + RARITY_COLORS[item.rarity].toString(16).padStart(6, '0');
                this.floatingText(stump.x + (i * 20 - 10), stump.y - 15, '+' + item.name, rc);
            } else {
                this.floatingText(stump.x, stump.y - 15, 'Bag full!', '#e74c3c');
            }
        }
        stump.hpBg.destroy();
        stump.hpFill.destroy();
        stump.setTexture('stump_broken');
        this.time.delayedCall(8000, () => {
            if (stump.active) stump.setTexture('stump');
            stump.stats.hp = stump.stats.maxHp;
        });
        this.updateUI();
    }

    checkLevelUp() {
        const req = Math.floor(100 * Math.pow(this.playerLevel, 1.5));
        if (this.playerExp >= req) {
            this.playerExp -= req;
            this.playerLevel++;
            this.talentPoints++;
            this.classStats = getClassStats(this.classKey, this.playerLevel);
            this.recalcStats();
            this.playerHP = this.playerMaxHP;
            playLevelUp();
            this.cameras.main.flash(300, 241, 196, 15);
            const lt = this.add.text(400, 250, 'LEVEL UP! Lv.' + this.playerLevel + ' [+1 Talent]', {
                fontSize: '24px', fill: '#f1c40f', fontFamily: 'Arial',
                fontStyle: 'bold', stroke: '#000', strokeThickness: 3
            }).setOrigin(0.5);
            this.tweens.add({
                targets: lt, y: lt.y - 50, alpha: 0, duration: 1500,
                onComplete: () => lt.destroy()
            });
        }
    }

    _checkAccountLevelUp() {
        const req = getAccountLevelUpReq(this.accountLevel);
        if (this.accountExp >= req) {
            this.accountExp -= req;
            this.accountLevel++;
            this.accountTalentPoints++;
            this.cameras.main.flash(300, 155, 89, 182);
            const lt = this.add.text(400, 220, 'ACCOUNT LEVEL UP! Lv.' + this.accountLevel + ' [+1 Talent]', {
                fontSize: '20px', fill: '#e67e22', fontFamily: 'Arial',
                fontStyle: 'bold', stroke: '#000', strokeThickness: 3
            }).setOrigin(0.5);
            this.tweens.add({
                targets: lt, y: lt.y - 50, alpha: 0, duration: 2000,
                onComplete: () => lt.destroy()
            });
        }
    }

    /* ===== INVENTORY UI ===== */

    toggleInventory() {
        this.invOpen ? this.closeInventory() : this.openInventory();
    }

    _showItemTooltip(x, y, item) {
        this._hideItemTooltip();
        if (!item) return;

        const ttGroup = [];
        const mk = (el) => { el.setScrollFactor(0).setDepth(200); return el; };

        const lines = [];
        const rc = RARITY_COLORS[item.rarity] || 0xaaaaaa;
        const hex = '#' + rc.toString(16).padStart(6, '0');
        const rarityName = (item.rarity || 'common').charAt(0).toUpperCase() + (item.rarity || 'common').slice(1);

        lines.push({ text: item.name || 'Unknown', color: hex, size: '13px', bold: true });
        lines.push({ text: rarityName, color: '#888', size: '10px', bold: false });

        if (item.slot) {
            const slotName = item.slot.charAt(0).toUpperCase() + item.slot.slice(1);
            lines.push({ text: 'Slot: ' + slotName, color: '#95a5a6', size: '10px', bold: false });
        }

        if (item.type === 'material' || item.type === 'equip') {
            const s = item.stats || {};
            const statMap = { hp: '+{0} HP', dmg: '+{0} DMG', speed: '+{0} SPD', crit: '+{0}% Crit' };
            Object.entries(statMap).forEach(([k, fmt]) => {
                if (s[k]) lines.push({ text: fmt.replace('{0}', s[k]), color: '#2ecc71', size: '11px', bold: false });
            });
        }

        if (item.type === 'accountEquip') {
            const s = item.stats || {};
            const statMap = {
                hpPercent: '+{0}% HP', damagePercent: '+{0}% DMG', speedPercent: '+{0}% SPD',
                spellPercent: '+{0}% Spell', critPercent: '+{0}% Crit', dodgePercent: '+{0}% Dodge',
                expPercent: '+{0}% EXP', lootPercent: '+{0}% Loot', regenPercent: '+{0}% Regen',
                corruptionMax: '+{0} CorrMax'
            };
            Object.entries(statMap).forEach(([k, fmt]) => {
                if (s[k]) lines.push({ text: fmt.replace('{0}', s[k]), color: '#2ecc71', size: '11px', bold: false });
            });
        }

        if (item.effect) {
            lines.push({ text: 'Effect: ' + item.effect, color: '#f39c12', size: '10px', bold: false });
        }

        const maxW = 180;
        const lineH = 16;
        const padX = 10;
        const padY = 8;
        const totalH = lines.length * lineH + padY * 2;

        let tx = x + 20;
        let ty = y - totalH / 2;
        if (tx + maxW > 780) tx = x - maxW - 20;
        if (ty < 10) ty = 10;
        if (ty + totalH > 590) ty = 590 - totalH;

        ttGroup.push(mk(this.add.rectangle(tx + maxW / 2, ty + totalH / 2, maxW, totalH, 0x0a0a1a, 0.95)
            .setStrokeStyle(1, rc)));

        lines.forEach((l, i) => {
            const fontWeight = l.bold ? ', fontStyle: ' + "'bold'" : '';
            const t = mk(this.add.text(tx + padX, ty + padY + i * lineH, l.text, {
                fontSize: l.size, fill: l.color, fontFamily: 'Arial' + fontWeight
            }));
            ttGroup.push(t);
        });

        this._tooltipGroup = ttGroup;
    }

    _hideItemTooltip() {
        if (this._tooltipGroup) {
            this._tooltipGroup.forEach(e => e.destroy());
        }
        this._tooltipGroup = [];
    }

    openInventory() {
        if (this.menuOpen) return;
        this.invOpen = true;
        this.menuOpen = true;
        this.physics.pause();
        if (this.enemies) this.enemies.getChildren().forEach(e => { if (e.body) e.body.setVelocity(0); });
        if (this.stumps) this.stumps.getChildren().forEach(s => { if (s.body) s.body.setVelocity(0); });
        this.invGroup = [];

        this._drawEquippedPanel();
        this._drawMaterialsPanel();
        this._drawEquipmentBagPanel();
        this._drawCloseButton();
    }

    _drawEquippedPanel() {
        const equipX = 150;

        const mkInv = (el) => { el.setScrollFactor(0).setDepth(100); return el; };

        this.invGroup.push(mkInv(this.add.rectangle(400, 300, 620, 500, 0x0a0a1a, 0.95)
            .setStrokeStyle(2, 0xf1c40f).setInteractive()));
        this.invGroup.push(mkInv(this.add.text(400, 55, 'INVENTORY', {
            fontSize: '22px', fill: '#f1c40f', fontFamily: 'Arial', fontStyle: 'bold'
        }).setOrigin(0.5)));
        this.invGroup.push(mkInv(this.add.text(equipX, 85, 'EQUIPPED', {
            fontSize: '13px', fill: '#e74c3c', fontFamily: 'Arial', fontStyle: 'bold'
        }).setOrigin(0.5)));

        const slots = [
            { key: 'weapon', label: 'Weapon', y: 140 },
            { key: 'armor', label: 'Armor', y: 210 },
            { key: 'accessory', label: 'Accessory', y: 280 }
        ];

        slots.forEach(sl => {
            this.invGroup.push(mkInv(this.add.text(equipX - 55, sl.y - 8, sl.label + ':', {
                fontSize: '11px', fill: '#95a5a6', fontFamily: 'Arial'
            })));

            const bg = mkInv(this.add.rectangle(equipX + 20, sl.y + 10, 44, 44, 0x1a1a2e)
                .setStrokeStyle(1, 0x444));
            this.invGroup.push(bg);

            if (this.equipment[sl.key]) {
                const item = this.equipment[sl.key];
                this.invGroup.push(mkInv(this.add.sprite(equipX + 20, sl.y + 10, item.texKey)));
                const rc = '#' + RARITY_COLORS[item.rarity].toString(16).padStart(6, '0');
                this.invGroup.push(mkInv(this.add.text(equipX - 55, sl.y + 18, item.name, {
                    fontSize: '10px', fill: rc, fontFamily: 'Arial'
                })));
                bg.setStrokeStyle(2, RARITY_COLORS[item.rarity]);
                bg.setInteractive({ useHandCursor: true });
                bg.on('pointerover', () => this._showItemTooltip(equipX + 50, sl.y, item));
                bg.on('pointerout', () => this._hideItemTooltip());
                bg.on('pointerdown', () => {
                    this._hideItemTooltip();
                    this.unequipItem(sl.key);
                    this.closeInventory();
                    this.openInventory();
                });
            } else {
                this.invGroup.push(mkInv(this.add.text(equipX + 20, sl.y + 10, 'Empty', {
                    fontSize: '9px', fill: '#555', fontFamily: 'Arial'
                }).setOrigin(0.5)));
            }
        });
    }

    _drawMaterialsPanel() {
        const matX = 350, matY = 85;
        const mkInv = (el) => { el.setScrollFactor(0).setDepth(100); return el; };

        this.invGroup.push(mkInv(this.add.text(matX, matY, 'MATERIALS (session)', {
            fontSize: '12px', fill: '#27ae60', fontFamily: 'Arial', fontStyle: 'bold'
        }).setOrigin(0.5)));
        this.invGroup.push(mkInv(this.add.text(matX, matY + 16,
            this.materials.length + '/' + this.maxMaterials, {
            fontSize: '10px', fill: '#555', fontFamily: 'Arial'
        }).setOrigin(0.5)));
        this.invGroup.push(mkInv(this.add.text(matX, matY + 30, this.getMaterialStatsText(), {
            fontSize: '10px', fill: '#27ae60', fontFamily: 'Arial'
        }).setOrigin(0.5)));

        const cols = 3, slotSize = 40, gap = 4;
        for (let i = 0; i < 6; i++) {
            const col = i % cols;
            const row = Math.floor(i / cols);
            const sx = matX - (cols * (slotSize + gap)) / 2 + col * (slotSize + gap) + slotSize / 2;
            const sy = matY + 42 + row * (slotSize + gap) + slotSize / 2;

            const bg = mkInv(this.add.rectangle(sx, sy, slotSize, slotSize, 0x1a1a2e).setStrokeStyle(1, 0x333));
            this.invGroup.push(bg);

            if (i < this.materials.length) {
                const item = this.materials[i];
                this.invGroup.push(mkInv(this.add.sprite(sx, sy, item.texKey).setScale(1.3)));
                bg.setStrokeStyle(2, RARITY_COLORS[item.rarity]);
                bg.setInteractive({ useHandCursor: true });

                const idx = i;
                bg.on('pointerdown', () => {
                    if (this.input.keyboard.checkDown(this.input.keyboard.addKey('SHIFT'))) {
                        const expGain = this.deleteItem('material', idx);
                        if (expGain > 0) {
                            this.floatingText(sx, sy - 20, '+' + expGain + ' EXP', '#2ecc71');
                        }
                        this.closeInventory();
                        this.openInventory();
                    }
                });
                bg.on('pointerover', () => { bg.setScale(1.1); this._showItemTooltip(sx + 30, sy, item); });
                bg.on('pointerout', () => { bg.setScale(1); this._hideItemTooltip(); });

                const statParts = [];
                if (item.stats) {
                    if (item.stats.hp) statParts.push('+' + item.stats.hp + 'HP');
                    if (item.stats.dmg) statParts.push('+' + item.stats.dmg + 'DMG');
                    if (item.stats.speed) statParts.push('+' + item.stats.speed + 'SPD');
                }
                if (statParts.length > 0) {
                    this.invGroup.push(mkInv(this.add.text(sx, sy + slotSize / 2 + 8, statParts.join(' '), {
                        fontSize: '8px', fill: '#27ae60', fontFamily: 'Arial'
                    }).setOrigin(0.5)));
                }

                // Delete indicator
                this.invGroup.push(mkInv(this.add.text(sx + slotSize / 2 - 2, sy - slotSize / 2 + 2, 'x', {
                    fontSize: '8px', fill: '#c0392b', fontFamily: 'Arial', fontStyle: 'bold'
                }).setOrigin(1, 0)));
            }
        }
    }

    _drawEquipmentBagPanel() {
        const eqX = 350, eqY = 310;
        const mkInv = (el) => { el.setScrollFactor(0).setDepth(100); return el; };

        this.invGroup.push(mkInv(this.add.text(eqX, eqY, 'EQUIPMENT BAG', {
            fontSize: '12px', fill: '#3498db', fontFamily: 'Arial', fontStyle: 'bold'
        }).setOrigin(0.5)));
        this.invGroup.push(mkInv(this.add.text(eqX, eqY + 16,
            this.equipBag.length + '/' + this.maxEquipBag + '  (click to equip)', {
            fontSize: '10px', fill: '#555', fontFamily: 'Arial'
        }).setOrigin(0.5)));

        const cols = 4, slotSize = 40, gap = 4;
        for (let i = 0; i < this.maxEquipBag; i++) {
            const col = i % cols;
            const row = Math.floor(i / cols);
            const sx = eqX - (cols * (slotSize + gap)) / 2 + col * (slotSize + gap) + slotSize / 2;
            const sy = eqY + 32 + row * (slotSize + gap) + slotSize / 2;

            const bg = mkInv(this.add.rectangle(sx, sy, slotSize, slotSize, 0x1a1a2e).setStrokeStyle(1, 0x333));
            this.invGroup.push(bg);

            if (i < this.equipBag.length) {
                const item = this.equipBag[i];
                this.invGroup.push(mkInv(this.add.sprite(sx, sy, item.texKey).setScale(1.4)));
                bg.setStrokeStyle(2, RARITY_COLORS[item.rarity]);
                bg.setInteractive({ useHandCursor: true });

                const idx = i;
                bg.on('pointerdown', () => {
                    if (this.input.keyboard.checkDown(this.input.keyboard.addKey('SHIFT'))) {
                        const expGain = this.deleteItem('equip', idx);
                        if (expGain > 0) {
                            this.floatingText(sx, sy - 20, '+' + expGain + ' EXP', '#2ecc71');
                        }
                        this.closeInventory();
                        this.openInventory();
                    } else {
                        this.equipFromBag(idx);
                        this.closeInventory();
                        this.openInventory();
                    }
                });
                bg.on('pointerover', () => { bg.setScale(1.1); this._showItemTooltip(sx + 30, sy, item); });
                bg.on('pointerout', () => { bg.setScale(1); this._hideItemTooltip(); });

                // Delete indicator
                this.invGroup.push(mkInv(this.add.text(sx + slotSize / 2 - 2, sy - slotSize / 2 + 2, 'x', {
                    fontSize: '8px', fill: '#c0392b', fontFamily: 'Arial', fontStyle: 'bold'
                }).setOrigin(1, 0)));
            }
        }
    }

    _drawCloseButton() {
        const mkInv = (el) => { el.setScrollFactor(0).setDepth(100); return el; };
        const bg = mkInv(this.add.rectangle(400, 520, 100, 30, 0x34495e)
            .setStrokeStyle(1, 0x5a6c7d)
            .setInteractive({ useHandCursor: true }));
        const lbl = mkInv(this.add.text(400, 520, 'CLOSE', {
            fontSize: '12px', fill: '#fff', fontFamily: 'Arial', fontStyle: 'bold'
        }).setOrigin(0.5));
        bg.on('pointerdown', () => this.closeInventory());
        this.invGroup.push(bg, lbl);
    }

    closeInventory() {
        this.invOpen = false;
        this._hideItemTooltip();
        this.menuOpen = false;
        this.physics.resume();
        this.invGroup.forEach(e => e.destroy());
        this.invGroup = [];
    }

    /* ===== PAUSE ===== */

    togglePause() {
        this.menuOpen ? this.closePause() : this.openPause();
    }

    openPause() {
        this.menuOpen = true;
        this.physics.pause();
        if (this.enemies) this.enemies.getChildren().forEach(e => { if (e.body) e.body.setVelocity(0); });
        if (this.stumps) this.stumps.getChildren().forEach(s => { if (s.body) s.body.setVelocity(0); });

        this.pauseGroup = [];
        const mkPause = (el) => { el.setScrollFactor(0).setDepth(100); return el; };

        this.pauseGroup.push(mkPause(this.add.rectangle(400, 300, 400, 260, 0x000000, 0.92)
            .setStrokeStyle(2, 0xf1c40f)));
        this.pauseGroup.push(mkPause(this.add.text(400, 200, t('pause.title'), {
            fontSize: '28px', fill: '#f1c40f', fontFamily: 'Arial', fontStyle: 'bold'
        }).setOrigin(0.5)));

        const buttons = [
            { t: t('pause.resume'), c: 0x27ae60, cb: () => this.closePause() },
            { t: t('pause.menu'), c: 0x2980b9, cb: () => {
                this.doSave();
                this.closePause();
                this.scene.start('Menu');
            }},
            { t: t('adv.title'), c: 0x555577, cb: () => {
                this.closePause();
                this._openPauseAdvanced();
            }}
        ];

        buttons.forEach((b, i) => {
            const y = 245 + i * 42;
            const bg = mkPause(this.add.rectangle(400, y, 200, 32, b.c)
                .setStrokeStyle(1, lighten(b.c, 0.3))
                .setInteractive({ useHandCursor: true }));
            const lbl = mkPause(this.add.text(400, y, b.t, {
                fontSize: '13px', fill: '#fff', fontFamily: 'Arial', fontStyle: 'bold'
            }).setOrigin(0.5));
            bg.on('pointerdown', b.cb);
            this.pauseGroup.push(bg, lbl);
        });
    }

    _openPauseAdvanced() {
        this.menuOpen = true;
        this.physics.pause();
        if (this.enemies) this.enemies.getChildren().forEach(e => { if (e.body) e.body.setVelocity(0); });
        if (this.stumps) this.stumps.getChildren().forEach(s => { if (s.body) s.body.setVelocity(0); });

        this.pauseGroup = [];
        const mkPause = (el) => { el.setScrollFactor(0).setDepth(100); return el; };

        this.pauseGroup.push(mkPause(this.add.rectangle(400, 300, 400, 360, 0x000000, 0.92)
            .setStrokeStyle(2, 0x555577)));
        this.pauseGroup.push(mkPause(this.add.text(400, 155, t('adv.title'), {
            fontSize: '20px', fill: '#aaa', fontFamily: 'Arial', fontStyle: 'bold'
        }).setOrigin(0.5)));

        const buttons = [
            { t: t('adv.talents'), c: 0x9b59b6, cb: () => {
                this.closePause();
                this._openTalentTree();
            }},
            { t: t('adv.accountEquip'), c: 0xf39c12, cb: () => {
                this.closePause();
                this._openAccountEquipOverlay();
            }},
            { t: t('pause.changeClass'), c: 0x1abc9c, cb: () => {
                this.doSave();
                this.closePause();
                this.scene.start('ClassSelect');
            }},
            { t: t('pause.save'), c: 0x8e44ad, cb: () => { this.doSave(); this.closePause(); }},
            { t: t('pause.restart'), c: 0xe67e22, cb: () => {
                this.doSave();
                this.closePause();
                this.scene.restart({ difficulty: this.difficulty, classKey: this.classKey });
            }},
            { t: t('pause.back'), c: 0x34495e, cb: () => {
                this.closePause();
                this.openPause();
            }}
        ];

        buttons.forEach((b, i) => {
            const y = 190 + i * 38;
            const bg = mkPause(this.add.rectangle(400, y, 200, 30, b.c)
                .setStrokeStyle(1, lighten(b.c, 0.3))
                .setInteractive({ useHandCursor: true }));
            const lbl = mkPause(this.add.text(400, y, b.t, {
                fontSize: '12px', fill: '#fff', fontFamily: 'Arial', fontStyle: 'bold'
            }).setOrigin(0.5));
            bg.on('pointerdown', b.cb);
            this.pauseGroup.push(bg, lbl);
        });
    }

    closePause() {
        this.menuOpen = false;
        this.physics.resume();
        if (this.pauseGroup) {
            this.pauseGroup.forEach(e => e.destroy());
            this.pauseGroup = [];
        }
    }

    _openAccountEquipOverlay() {
        this.menuOpen = true;
        this.physics.pause();
        this.accountEquipGroup = [];
        const mk = (el) => { el.setScrollFactor(0).setDepth(100); return el; };

        // Background (fit within 600px screen)
        this.accountEquipGroup.push(mk(this.add.rectangle(400, 300, 620, 560, 0x000000, 0.94)
            .setStrokeStyle(2, 0xf39c12)));

        // Title
        this.accountEquipGroup.push(mk(this.add.text(400, 35, t('accEquip.title'), {
            fontSize: '20px', fill: '#f39c12', fontFamily: 'Arial', fontStyle: 'bold'
        }).setOrigin(0.5)));

        // Stats summary
        const statsText = this.getAccountEquipStatsText();
        this.accountEquipGroup.push(mk(this.add.text(400, 55, statsText, {
            fontSize: '12px', fill: '#2ecc71', fontFamily: 'Arial'
        }).setOrigin(0.5)));

        // === 6 EQUIPPED SLOTS ===
        const slots = ['hat', 'mantle', 'legs', 'weapon', 'accessory', 'relic'];
        const slotLabels = [t('accEquip.hat'), t('accEquip.mantle'), t('accEquip.legs'), t('accEquip.weapon'), t('accEquip.acc'), 'Relic'];
        const slotY = [85, 120, 155, 190, 225, 260];

        slots.forEach((slot, i) => {
            const item = this.accountEquipment[slot];
            const y = slotY[i];

            this.accountEquipGroup.push(mk(this.add.text(120, y, slotLabels[i] + ':', {
                fontSize: '13px', fill: '#aaa', fontFamily: 'Arial', fontStyle: 'bold'
            }).setOrigin(0, 0.5)));

            const bg = mk(this.add.rectangle(210, y, 36, 36, 0x1a1a2e)
                .setStrokeStyle(1, 0x444));
            this.accountEquipGroup.push(bg);

            if (item) {
                const spr = mk(this.add.sprite(210, y, item.texKey).setScale(1.6));
                this.accountEquipGroup.push(spr);
                const rc = RARITY_COLORS[item.rarity] || 0xaaaaaa;
                bg.setStrokeStyle(2, rc);

                const hex = '#' + rc.toString(16).padStart(6, '0');
                this.accountEquipGroup.push(mk(this.add.text(235, y - 6, item.name, {
                    fontSize: '12px', fill: hex, fontFamily: 'Arial', fontStyle: 'bold'
                }).setOrigin(0, 0.5)));

                const st = this._getAccountItemStatsText(item);
                this.accountEquipGroup.push(mk(this.add.text(235, y + 6, st, {
                    fontSize: '10px', fill: '#2ecc71', fontFamily: 'Arial'
                }).setOrigin(0, 0.5)));

                bg.setInteractive({ useHandCursor: true });
                bg.on('pointerover', () => this._showItemTooltip(560, y, item));
                bg.on('pointerout', () => this._hideItemTooltip());

                const ub = mk(this.add.rectangle(520, y, 50, 18, 0xc0392b)
                    .setStrokeStyle(1, 0xe74c3c)
                    .setInteractive({ useHandCursor: true }));
                const ut = mk(this.add.text(520, y, 'REMOVE', {
                    fontSize: '10px', fill: '#fff', fontFamily: 'Arial'
                }).setOrigin(0.5));
                ub.on('pointerdown', () => {
                    this.unequipAccountItem(slot);
                    this._closeAccountEquipOverlay();
                    this._openAccountEquipOverlay();
                });
                ub.on('pointerover', () => ub.setFillStyle(0xe74c3c));
                ub.on('pointerout', () => ub.setFillStyle(0xc0392b));
                this.accountEquipGroup.push(ub, ut);
            } else {
                this.accountEquipGroup.push(mk(this.add.text(210, y, 'Empty', {
                    fontSize: '11px', fill: '#555', fontFamily: 'Arial'
                }).setOrigin(0.5)));
            }
        });

        // === SEPARATOR ===
        this.accountEquipGroup.push(mk(this.add.rectangle(400, 300, 560, 1, 0x444)));

        // === INVENTORY SECTION ===
        this.accountEquipGroup.push(mk(this.add.text(400, 315, 'INVENTORY', {
            fontSize: '15px', fill: '#f39c12', fontFamily: 'Arial', fontStyle: 'bold'
        }).setOrigin(0.5)));

        this.accountEquipGroup.push(mk(this.add.text(400, 332, this.accountEquipBag.length + '/' + this.maxAccountEquipBag + '  (SHIFT+click = sell for Account EXP)', {
            fontSize: '11px', fill: '#888', fontFamily: 'Arial'
        }).setOrigin(0.5)));

        const bagSlotsPerRow = 5;
        const bagSlotSize = 38;
        const bagSpacing = 48;
        const bagStartX = 400 - (bagSlotsPerRow * bagSpacing) / 2 + bagSpacing / 2;
        const bagStartY = 370;

        for (let i = 0; i < this.maxAccountEquipBag; i++) {
            const row = Math.floor(i / bagSlotsPerRow);
            const col = i % bagSlotsPerRow;
            const sx = bagStartX + col * bagSpacing;
            const sy = bagStartY + row * bagSpacing;

            const bg = mk(this.add.rectangle(sx, sy, bagSlotSize, bagSlotSize, 0x1a1a2e)
                .setStrokeStyle(1, 0x444));
            this.accountEquipGroup.push(bg);

            if (i < this.accountEquipBag.length) {
                const item = this.accountEquipBag[i];
                const spr = mk(this.add.sprite(sx, sy, item.texKey).setScale(1.6));
                this.accountEquipGroup.push(spr);
                const rc = RARITY_COLORS[item.rarity] || 0xaaaaaa;
                bg.setStrokeStyle(2, rc);

                // Delete indicator
                this.accountEquipGroup.push(mk(this.add.text(sx + bagSlotSize / 2 - 2, sy - bagSlotSize / 2 + 2, 'x', {
                    fontSize: '9px', fill: '#c0392b', fontFamily: 'Arial', fontStyle: 'bold'
                }).setOrigin(1, 0)));

                bg.setInteractive({ useHandCursor: true });
                bg.on('pointerdown', (pointer) => {
                    if (this.input.keyboard.checkDown(this.input.keyboard.addKey('SHIFT'))) {
                        const expGain = this.deleteItem('accountEquipBag', i);
                        if (expGain > 0) {
                            this.floatingText(sx, sy - 20, '+' + expGain + ' Account EXP', '#f39c12');
                        }
                        this._closeAccountEquipOverlay();
                        this._openAccountEquipOverlay();
                    } else {
                        const emptySlot = slots.find(s => !this.accountEquipment[s]);
                        if (emptySlot) {
                            this.accountEquipBag.splice(i, 1);
                            this.accountEquipment[emptySlot] = item;
                            this.recalcStats();
                            this._closeAccountEquipOverlay();
                            this._openAccountEquipOverlay();
                        }
                    }
                });
            } else {
                this.accountEquipGroup.push(mk(this.add.text(sx, sy, 'Empty', {
                    fontSize: '10px', fill: '#333', fontFamily: 'Arial'
                }).setOrigin(0.5)));
            }
        }

        // === CLOSE BUTTON ===
        const closeBg = mk(this.add.rectangle(400, 530, 100, 26, 0x34495e)
            .setStrokeStyle(1, 0x555)
            .setInteractive({ useHandCursor: true }));
        const closeTxt = mk(this.add.text(400, 530, 'CLOSE', {
            fontSize: '14px', fill: '#fff', fontFamily: 'Arial'
        }).setOrigin(0.5));
        closeBg.on('pointerdown', () => this._closeAccountEquipOverlay());
        closeBg.on('pointerover', () => closeBg.setFillStyle(0x4a6a8e));
        closeBg.on('pointerout', () => closeBg.setFillStyle(0x34495e));
        this.accountEquipGroup.push(closeBg, closeTxt);
    }

    _closeAccountEquipOverlay() {
        this._hideItemTooltip();
        if (this.accountEquipGroup) {
            this.accountEquipGroup.forEach(e => e.destroy());
            this.accountEquipGroup = [];
        }
        this.menuOpen = false;
        this.physics.resume();
    }

    _getAccountItemStatsText(item) {
        if (!item || !item.stats) return '';
        const s = item.stats;
        const parts = [];
        if (s.hpPercent) parts.push('+' + s.hpPercent + '% HP');
        if (s.damagePercent) parts.push('+' + s.damagePercent + '% DMG');
        if (s.speedPercent) parts.push('+' + s.speedPercent + '% SPD');
        if (s.spellPercent) parts.push('+' + s.spellPercent + '% Spell');
        if (s.critPercent) parts.push('+' + s.critPercent + '% Crit');
        if (s.dodgePercent) parts.push('+' + s.dodgePercent + '% Dodge');
        if (s.expPercent) parts.push('+' + s.expPercent + '% EXP');
        if (s.lootPercent) parts.push('+' + s.lootPercent + '% Loot');
        if (s.regenPercent) parts.push('+' + s.regenPercent + '% Regen');
        if (s.corruptionMax) parts.push('+' + s.corruptionMax + ' CorrMax');
        return parts.join(' ');
    }

    /* ===== GAME LOOP ===== */

    update(time, delta) {
        this._handleInput();
        this._updateEnemies();
        this._updateBoss();
        this._updateMineBoss();
        this._updateCorruption();
        this._updateSpells(delta);
        this._updateCaveMobs();
        this._updateCaveBoss();
        this._updateVillageMobs();
        this._updateVillageBoss();
        this._updateSnowyVillageMobs();
        this._updateSnowyVillageBoss();
        this._updateHellMobs();
        this._updateHellImps();
        this._updateHellBoss();
        this._updateHellLava(time, delta);

        if (this.zone === 'forest') {
            this._checkPortalProximity();
        } else if (this.zone === 'arena') {
            this._checkExitProximity();
        } else if (this.zone === 'mine') {
            this._checkMineExitProximity();
        } else if (this.zone === 'mine_boss') {
            this._checkMineBossArenaExitProximity();
        } else if (this.zone === 'meadow') {
            this._checkMeadowGate();
        } else if (this.zone === 'cave') {
            this._checkCaveProximity();
            this._caveBossSpawnCheck();
        } else if (this.zone === 'village') {
            if (this.villageFrozen) {
                this._checkSnowyVillageProgress();
                if (this.campfire && !this.villageBossDefeated) {
                    const cd = Phaser.Math.Distance.Between(
                        this.player.x, this.player.y, this.campfire.x, this.campfire.y
                    );
                    if (cd < 80) {
                        this.campfireHint.setText('SPACE = activate');
                    } else if (this.campfireHint) {
                        this.campfireHint.setText('');
                    }
                }
                if (this.villageBossDefeated && this.campfire) {
                    const cd = Phaser.Math.Distance.Between(
                        this.player.x, this.player.y, this.campfire.x, this.campfire.y
                    );
                    if (cd < 80) {
                        this.campfireHint.setText('SPACE = restore village');
                    } else if (this.campfireHint) {
                        this.campfireHint.setText('');
                    }
                }
            } else {
                this._checkVillageProgress();
                this._checkVillageCemeteryGate();
            }
        } else if (this.zone === 'cemetery') {
            this._checkVillageProgress();
            if (!this.villageBossSpawned && !this.villageBossDefeated) {
                this._spawnVillageBoss();
            }
            if (this.villageBossDefeated && this.hellPortal) {
                const pd = Phaser.Math.Distance.Between(
                    this.player.x, this.player.y, this.hellPortal.x, this.hellPortal.y
                );
                if (pd < 80) {
                    this.hellPortalHint.setText('SPACE = enter Hell');
                } else if (this.hellPortalHint) {
                    this.hellPortalHint.setText('');
                }
            }
        } else if (this.zone === 'hell') {
            if (this.hellBossDefeated && this.hellReturnPortal) {
                const pd = Phaser.Math.Distance.Between(
                    this.player.x, this.player.y, this.hellReturnPortal.x, this.hellReturnPortal.y
                );
                if (pd < 80) {
                    this.hellReturnPortalHint.setText('SPACE = return to Village');
                } else if (this.hellReturnPortalHint) {
                    this.hellReturnPortalHint.setText('');
                }
            }
        }

        this.updateUI();
        this._checkNpcProximity();
    }

    _handleInput() {
        const body = this.player.body;
        body.setVelocity(0);
        let isMoving = false;

        if (!this.menuOpen && !this.transitioning) {
            if (this.cursors.left.isDown) {
                body.setVelocityX(-this.playerSpeed);
                this.facing = 'left';
                isMoving = true;
            } else if (this.cursors.right.isDown) {
                body.setVelocityX(this.playerSpeed);
                this.facing = 'right';
                isMoving = true;
            }
            if (this.cursors.up.isDown) {
                body.setVelocityY(-this.playerSpeed);
                this.facing = 'up';
                isMoving = true;
            } else if (this.cursors.down.isDown) {
                body.setVelocityY(this.playerSpeed);
                this.facing = 'down';
                isMoving = true;
            }

            if (isMoving && !this.playerAttacking) {
                const cls = this.classData || getClassData(this.classKey);
                const walkAnim = cls.walkAnim || 'sage_walk_right';
                if (!this.player.anims.isPlaying || this.player.anims.currentAnim.key !== walkAnim) {
                    this.player.play(walkAnim);
                }
                this.player.setFlipX(this.facing === 'left');
            } else if (!isMoving && !this.playerAttacking) {
                this.player.stop();
                this.player.setFrame(0);
            }

            if (Phaser.Input.Keyboard.JustDown(this.spaceKey)) {
                if (this.nearbyNpc) {
                    this._interactWithNpc();
                } else if (this.zone === 'forest') {
                    if (this.player.y < 100) {
                        this._enterPortal();
                    } else {
                        this.attack();
                    }
                } else if (this.zone === 'arena') {
                    if (this.player.y > 500) {
                        this._exitArena();
                    } else if (!this.bossDefeated) {
                        this.attack();
                    }
                } else if (this.zone === 'mine') {
                    if (this.player.y < 100) {
                        this._exitMine();
                    } else if (this.mineBossPortal && !this.mineBossDefeated && Phaser.Math.Distance.Between(
                        this.player.x, this.player.y, MINE_BOSS_PORTAL_POS.x, MINE_BOSS_PORTAL_POS.y
                    ) < 50) {
                        this._enterMineBossArena();
                    } else {
                        this.attack();
                    }
                } else if (this.zone === 'mine_boss') {
                    if (this.player.y > 500) {
                        this._exitMineBossArena();
                    } else if (!this.mineBossDefeated) {
                        this.attack();
                    }
                } else if (this.zone === 'meadow') {
                    if (this.meadowGate && Phaser.Math.Distance.Between(
                        this.player.x, this.player.y, MEADOW_GATE_POS.x, MEADOW_GATE_POS.y
                    ) < 70) {
                        this._unlockMeadowGate();
                    } else {
                        this.attack();
                    }
                } else if (this.zone === 'cave') {
                    if (this.caveBossDefeated && this.caveStairs && Phaser.Math.Distance.Between(
                        this.player.x, this.player.y, this.caveStairs.x, this.caveStairs.y
                    ) < 50) {
                        this._enterCaveVillage();
                    } else {
                        this.attack();
                    }
                } else if (this.zone === 'village') {
                    if (this.villageFrozen && this.campfire && Phaser.Math.Distance.Between(
                        this.player.x, this.player.y, this.campfire.x, this.campfire.y
                    ) < 60) {
                        this._activateCampfire();
                    } else if (this.villageFrozen && this.snowyIceSpirit && Phaser.Math.Distance.Between(
                        this.player.x, this.player.y, this.snowyIceSpirit.x, this.snowyIceSpirit.y
                    ) < 80) {
                        this.attack();
                    } else if (!this.villageFrozen && this.villageAllCleared && this.villageChildNPC && Phaser.Math.Distance.Between(
                        this.player.x, this.player.y, this.villageChildNPC.x, this.villageChildNPC.y
                    ) < 50) {
                        this._talkToChild();
                    } else if (!this.villageFrozen && this.villageAllCleared && this.villageCemeteryGate && Phaser.Math.Distance.Between(
                        this.player.x, this.player.y, this.villageCemeteryGate.x, this.villageCemeteryGate.y
                    ) < 50) {
                        this._enterCemetery();
                    } else {
                        this.attack();
                    }
                } else if (this.zone === 'cemetery') {
                    if (this.villageBossDefeated && this.hellPortal && Phaser.Math.Distance.Between(
                        this.player.x, this.player.y, this.hellPortal.x, this.hellPortal.y
                    ) < 60) {
                        this._enterHell();
                    } else {
                        this.attack();
                    }
                } else if (this.zone === 'hell') {
                    if (this.hellBossDefeated && this.hellReturnPortal && Phaser.Math.Distance.Between(
                        this.player.x, this.player.y, this.hellReturnPortal.x, this.hellReturnPortal.y
                    ) < 60) {
                        this._exitHell();
                    } else {
                        this.attack();
                    }
                }
            }
            if (Phaser.Input.Keyboard.JustDown(this.iKey)) this.toggleInventory();
            if (Phaser.Input.Keyboard.JustDown(this.pKey)) this.togglePause();
            if (Phaser.Input.Keyboard.JustDown(this.tabKey)) this._toggleStats();
            if (Phaser.Input.Keyboard.JustDown(this.mKey)) this._toggleMute();
            if (Phaser.Input.Keyboard.JustDown(this.tKey)) this._openTalentTree();
            const spells = this._getClassSpells();
            if (Phaser.Input.Keyboard.JustDown(this.qKey)) this._castSpell(spells.q);
            if (Phaser.Input.Keyboard.JustDown(this.wKey)) this._castSpell(spells.w);
            if (Phaser.Input.Keyboard.JustDown(this.eKey)) this._castSpell(spells.e);
            if (Phaser.Input.Keyboard.JustDown(this.bKey)) this._openBestiary();
            if (Phaser.Input.Keyboard.JustDown(this.nKey)) this._openQuestLog();
            if (Phaser.Input.Keyboard.JustDown(this.cKey)) this._openCrafting();
        } else if (this.invOpen) {
            if (Phaser.Input.Keyboard.JustDown(this.iKey)) this.closeInventory();
            if (Phaser.Input.Keyboard.JustDown(this.pKey)) this.closeInventory();
        }
    }

    _updateEnemies() {
        if (!this.enemies) return;
        this.enemies.getChildren().forEach(e => {
            if (!e.active || !e.stats) return;
            if (e === this.villageBoss) return;

            if (!this.bestiarySeen[e.stats.key]) {
                recordEncounter(e.stats.key);
                this.bestiarySeen[e.stats.key] = true;
            }

            e.hpBg.x = e.x;
            e.hpBg.y = e.y - e.stats.bh / 2 - 8;
            e.hpFill.x = e.x;
            e.hpFill.y = e.hpBg.y;

            if (this.menuOpen || this.transitioning) {
                e.body.setVelocity(0);
                return;
            }

            if (e.stats.isBossClone) {
                const dx = this.player.x - e.x;
                const dy = this.player.y - e.y;
                const dist = Math.sqrt(dx * dx + dy * dy);
                const spd = e.stats.speed || 60;
                if (dist > 40) {
                    e.body.setVelocity((dx / dist) * spd, (dy / dist) * spd);
                    e.setFlipX(dx < 0);
                } else {
                    e.body.setVelocity(0);
                }

                if (this.anims.exists('purple_demon_walk_anim') && !e.anims.isPlaying) {
                    e.play('purple_demon_walk_anim');
                }

                e.stats.meteorTimer += this.game.loop.delta;
                if (e.stats.meteorTimer >= e.stats.meteorInterval) {
                    e.stats.meteorTimer = 0;
                    this._villageBossMeteor(e);
                }

                e.stats.corpseTimer += this.game.loop.delta;
                if (e.stats.corpseTimer >= e.stats.corpseInterval) {
                    e.stats.corpseTimer = 0;
                    this._villageBossSummonCorpses(e);
                }

                if (e.hpFill) {
                    e.hpFill.width = e.hpBg.width * (e.stats.hp / e.stats.maxHp);
                }
            } else {
                e.stats.wTimer++;
                if (e.stats.wTimer > 60) {
                    e.stats.wTimer = 0;
                    e.stats.wDir = Math.floor(Math.random() * 5);
                }
                const sp = 50;
                if (e.stats.wDir === 1) e.body.setVelocityX(-sp);
                else if (e.stats.wDir === 2) e.body.setVelocityX(sp);
                else if (e.stats.wDir === 3) e.body.setVelocityY(-sp);
                else if (e.stats.wDir === 4) e.body.setVelocityY(sp);
                else e.body.setVelocity(0);

                const isMoving = e.stats.wDir !== 0;
                if (isMoving && e.walkAnimKey) {
                    if (!e.anims.isPlaying || e.anims.currentAnim.key !== e.walkAnimKey) {
                        e.play(e.walkAnimKey);
                    }
                    e.setFlipX(e.body.velocity.x < 0);
                } else if (!isMoving) {
                    e.stop();
                    e.setFrame(0);
                }
            }
        });
    }
}
