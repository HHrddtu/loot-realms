import Phaser from 'phaser';
import {
    DIFF_MULT, ENEMY_TYPES, RARITY_COLORS,
    STUMP_COUNT, ENEMY_COUNT, EQUIP_DROP_CHANCE, BOSS_DROP_CHANCE, ACCOUNT_EQUIP_DROP_CHANCE,
    MATERIAL_SLOTS, EQUIP_BAG_SLOTS, ACCOUNT_EQUIP_BAG_SLOTS,
    GAME_WIDTH, GAME_HEIGHT, FOREST_HEIGHT,
    PORTAL_POS, PORTAL_ENTER_DIST, BOSS_TYPE,
    ARENA_EXIT_POS, FOREST_RETURN_POS, CORRUPTION,
    MINE_ENEMY_TYPES, MINE_ENEMY_COUNT, MINE_BOSS_TYPE,
    MINE_ROCK_COUNT, MINE_CRYSTAL_COUNT, MINE_EXIT_POS, MINE_RETURN_POS,
    MINE_BOSS_PORTAL_POS, MINE_CHEST_COUNT, MINE_CHEST_DROP_CHANCE, MINE_EQUIP_DROP_CHANCE,
    SPELLS, SECRET_KEY_ITEM, CART_DRIVER_NPC,
    MEADOW_POS, MEADOW_GATE_POS, MEADOW_WIDTH, MEADOW_HEIGHT,
    CAVE_ENEMY_TYPES, CAVE_ENEMY_COUNT, CAVE_BOSS_TYPE, CAVE_CHEST_COUNT,
    CAVE_CHEST_DROP_CHANCE, CAVE_EQUIP_DROP_CHANCE, CAVE_SMALL_BAT, CAVE_MATERIALS,
    CAVE_CHEST_OPEN_KEY, CAVE_CHEST_CLOSED_KEY, CAVE_CHEST_W, CAVE_CHEST_H,
    CAVE_WIDTH, CAVE_HEIGHT, CAVE_RELIC_CLASSES,
    VILLAGE_WIDTH, VILLAGE_HEIGHT, CEMETERY_HEIGHT, VILLAGE_TOTAL_HEIGHT,
    VILLAGE_CAMP_COUNT, VILLAGE_MOBS_PER_CAMP, VILLAGE_ENEMY_TYPES, VILLAGE_CAMP_POSITIONS,
    VILLAGE_HOUSE_POSITIONS, VILLAGE_CHILD_HOUSE, VILLAGE_CORPSE_POSITIONS, VILLAGE_GARDEN_POSITIONS,
    VILLAGE_CHEST_COUNT_MIN, VILLAGE_CHEST_COUNT_MAX, VILLAGE_CHEST_DROP_CHANCE, VILLAGE_CHEST_EQUIP_DROP_CHANCE,
    VILLAGE_CHEST_OPEN_KEY, VILLAGE_CHEST_CLOSED_KEY, VILLAGE_CHEST_W, VILLAGE_CHEST_H,
    VILLAGE_BOSS_TYPE, VILLAGE_CORPSE_MINION, MAGMA_ARMOR,
    HELL_WIDTH, HELL_HEIGHT, HELL_CAMP_COUNT, HELL_MOBS_PER_CAMP,
    HELL_LAVA_DAMAGE, HELL_LAVA_INTERVAL, HELL_HEAT_DAMAGE,
    HELL_ENEMY_TYPES, HELL_CAMP_POSITIONS, HELL_LAVA_POSITIONS,
    HELL_BOSS_TYPE, HELL_BOSS_MINION, HEAT_CRYSTAL,
    HELL_CHEST_COUNT, HELL_CHEST_DROP_CHANCE,
    SNOWY_VILLAGE_ENEMY_TYPES, SNOWY_VILLAGE_CAMP_POSITIONS, SNOWY_VILLAGE_BOSS_TYPE,
    SNOWY_BOSS_MINION, WARMTH_CORE, SNOWY_VILLAGE_CHEST_COUNT, SNOWY_VILLAGE_CHEST_DROP_CHANCE
} from '../config.js';
import { lighten, rollMaterial, rollEquip, rollAccountEquip, rollCaveRelic, rollVillageEquip, rollVillageAccountEquip } from '../utils.js';
import {
    playHit, playLevelUp, playLoot,
    playBossHit, playBossAoE, playBossDeath,
    playEnemyDeath, playPortal, playBreak, toggleMute, isMuted,
    startMusic, stopMusic
} from '../sound.js';
import { saveGame, loadGame, deleteSave, hasSave, saveAccount, loadAccount, getAccountLevelUpReq } from '../save.js';
import { getClassData, getClassStats } from '../classes.js';
import { SAGE_TALENTS, getTalentEffects, TALENT_SCOPE } from '../talents.js';
import { ACCOUNT_TALENTS, getAccountTalentEffects, canUnlockAccountTalent } from '../accountTalents.js';
import { initBestiary, recordEncounter, recordKill, getStudyBonus, getAllBestiaryBonuses, saveBestiary } from '../bestiary.js';
import { initMaterialBook, recordMaterialCollect, getMaterialBonuses, saveMaterialBook, getMaterialBookData } from '../materialBook.js';
import { initSoulBook, recordSoulCollect, getSoulBonuses, saveSoulBook } from '../soulBook.js';
import { initQuests, acceptQuest, onKill, onCollect, isQuestComplete, completeQuest, getActiveQuests, getNpcQuestStatus, getAvailableQuests, saveQuests, getQuestProgress } from '../quests.js';
import { NPC_DB, QUEST_DB } from '../config.js';
import { t, getLang, translateName } from '../i18n.js';
import { CombatSystem } from '../systems/CombatSystem.js';
import { PlayerSystem } from '../systems/PlayerSystem.js';
import { SpellSystem } from '../systems/SpellSystem.js';
import { UISystem } from '../systems/UISystem.js';
import { NpcSystem } from '../systems/NpcSystem.js';
import { ForestZone } from '../zones/ForestZone.js';
import { ArenaZone } from '../zones/ArenaZone.js';
import { MineZone } from '../zones/MineZone.js';
import { CaveZone } from '../zones/CaveZone.js';
import { VillageZone } from '../zones/VillageZone.js';
import { HellZone } from '../zones/HellZone.js';
import { SnowyZone } from '../zones/SnowyZone.js';

export default class GameScene extends Phaser.Scene {
    constructor() {
        super('Game');
    }

    init(data) {
        this.difficulty = data.difficulty || 'Normal';
        this.loadOnStart = data.load || false;
        this.classKey = data.classKey || 'sage';
    }

    create() {
        this.zone = 'forest';
        this.transitioning = false;

        this.enemies = null;
        this.stumps = null;
        this.boss = null;
        this.bossTimer = null;
        this.bossNameText = null;
        this.defeatedText = null;
        this.defeatedLoot = null;
        this.exitPortal = null;
        this.exitHint = null;
        this.mineRocks = null;
        this.mineCrystals = null;
        this.mineChests = null;
        this.mineTorches = null;
        this.mineDarkness = null;
        this.mineBoss = null;
        this.mineBossNameText = null;
        this.mineBossTimer = null;

        this._createAnimations();
        this._createPlayer();
        this._initInventory();
        this._initStats();
        this._createUI();
        this._bindKeys();

        this.invOpen = false;
        this.invGroup = [];
        this._tooltipGroup = [];
        this.bossDefeated = false;
        this.mineUnlocked = false;
        this.hasSecretKey = false;
        this.caveBossDefeated = false;
        this.cartDriverNpc = null;
        this.meadowGate = null;
        this.meadowBg = null;

        initBestiary();
        initMaterialBook();
        initSoulBook();
        initQuests();
        this.bestiarySeen = {};
        this.npcSprites = [];
        this.questIcons = [];
        this.nearbyNpc = null;
        this.questLogOpen = false;
        this.questLogGroup = [];

        this.unlockedTalents = [];
        this.talentPoints = 0;
        this._loadAccountTalents();

        this.corruption = 0;
        this.corruptionMax = this.classStats ? this.classStats.corruptionMax : CORRUPTION.max;

        this.spellCooldowns = { fireball: 0, shield: 0, heal: 0 };
        this.shieldActive = false;
        this.shieldHP = 0;
        this.shieldTimer = 0;
        this.lifeLinkActive = false;
        this.lifeLinkTimer = 0;
        this.lifeLinkHealPerSec = 0;
        this.fireballs = [];
        this.villageFrozen = false;
        this.villageRestored = false;

        this.combat = new CombatSystem(this);
        this.playerSys = new PlayerSystem(this);
        this.spellSys = new SpellSystem(this);
        this.ui = new UISystem(this);
        this.npc = new NpcSystem(this);

        this.zones = {
            forest: new ForestZone(this),
            arena: new ArenaZone(this),
            mine: new MineZone(this),
            cave: new CaveZone(this),
            village: new VillageZone(this),
            hell: new HellZone(this),
            snowy: new SnowyZone(this)
        };
        this.currentZone = null;

        const acc = loadAccount() || {};
        this.accountLevel = acc.accountLevel || 1;
        this.accountExp = acc.accountExp || 0;
        this.accountTalentPoints = acc.accountTalentPoints || 0;
        this.unlockedAccountTalents = acc.unlockedAccountTalents || [];
        const accEquipPerClass = acc.accountEquipment || {};
        const accBagPerClass = acc.accountEquipBag || {};
        this.accountEquipment = accEquipPerClass[this.classKey] || { hat: null, mantle: null, legs: null, weapon: null, accessory: null };
        this.accountEquipBag = accBagPerClass[this.classKey] || [];
        this.accountEffects = getAccountTalentEffects(this.unlockedAccountTalents);
        this.recalcStats();

        if (this.loadOnStart) this.doLoad();

        if (this.loadOnStart && this._savedZone) {
            if (this._savedZone === 'mine') {
                this._setupMine();
            } else if (this._savedZone === 'cave') {
                this._setupCave();
            } else {
                this._setupForest();
            }
            delete this._savedZone;
        } else {
            this._setupForest();
        }

        this.events.on('shutdown', () => {
            if (this._onBeforeUnload) {
                window.removeEventListener('beforeunload', this._onBeforeUnload);
                this._onBeforeUnload = null;
            }
            this.doSave();
            stopMusic();
        });

        this._onBeforeUnload = () => this.doSave();
        window.addEventListener('beforeunload', this._onBeforeUnload);

        this.autoSaveTimer = this.time.addEvent({
            delay: 300000,
            callback: () => this.doSave(),
            loop: true
        });

        this.events.on('resume', () => {
            const td = this.registry.get('talentData');
            if (td) {
                this.receiveTalentData(td);
                this.registry.remove('talentData');
            }
        });
    }

    /* ===== ANIMATIONS ===== */

    _createAnimations() {
        const anims = this.anims;

        // Player Sage walk
        if (!anims.exists('sage_walk_right')) {
            anims.create({ key: 'sage_walk_right', frames: anims.generateFrameNumbers('player_sage_walk', { start: 0, end: 3 }), frameRate: 8, repeat: -1 });
            anims.create({ key: 'sage_idle', frames: [{ key: 'player_sage', frame: 0 }], frameRate: 1 });
        }

        // Player Sage attack
        if (!anims.exists('sage_attack')) {
            anims.create({ key: 'sage_attack', frames: anims.generateFrameNumbers('player_sage_attack', { start: 0, end: 2 }), frameRate: 10, repeat: 0 });
        }

        // Player Alchemist walk + attack
        if (!anims.exists('alchemist_walk_right')) {
            anims.create({ key: 'alchemist_walk_right', frames: anims.generateFrameNumbers('player_alchemist_walk', { start: 0, end: 3 }), frameRate: 7, repeat: -1 });
        }
        if (!anims.exists('alchemist_attack')) {
            anims.create({ key: 'alchemist_attack', frames: anims.generateFrameNumbers('player_alchemist_attack', { start: 0, end: 2 }), frameRate: 10, repeat: 0 });
        }

        // Player Angel walk + attack
        if (!anims.exists('angel_walk_right')) {
            anims.create({ key: 'angel_walk_right', frames: anims.generateFrameNumbers('player_angel_walk', { start: 0, end: 3 }), frameRate: 7, repeat: -1 });
        }
        if (!anims.exists('angel_attack')) {
            anims.create({ key: 'angel_attack', frames: anims.generateFrameNumbers('player_angel_attack', { start: 0, end: 2 }), frameRate: 10, repeat: 0 });
        }

        // Goblin walk + attack
        if (!anims.exists('goblin_walk')) {
            anims.create({ key: 'goblin_walk', frames: anims.generateFrameNumbers('goblin_walk', { start: 0, end: 3 }), frameRate: 6, repeat: -1 });
            anims.create({ key: 'goblin_attack', frames: anims.generateFrameNumbers('goblin_attack', { start: 0, end: 2 }), frameRate: 10, repeat: 0 });
        }

        // Slime walk
        if (!anims.exists('slime_walk')) {
            anims.create({ key: 'slime_walk', frames: anims.generateFrameNumbers('slime_walk', { start: 0, end: 3 }), frameRate: 5, repeat: -1 });
        }

        // Rat walk
        if (!anims.exists('rat_walk')) {
            anims.create({ key: 'rat_walk', frames: anims.generateFrameNumbers('rat_walk', { start: 0, end: 3 }), frameRate: 8, repeat: -1 });
        }

        // Skeleton walk + attack
        if (!anims.exists('skeleton_walk')) {
            anims.create({ key: 'skeleton_walk', frames: anims.generateFrameNumbers('skeleton_walk', { start: 0, end: 3 }), frameRate: 5, repeat: -1 });
            anims.create({ key: 'skeleton_attack', frames: anims.generateFrameNumbers('skeleton_attack', { start: 0, end: 2 }), frameRate: 8, repeat: 0 });
        }

        // Mine skeleton variants
        if (!anims.exists('skeleton_archer_walk_anim')) {
            anims.create({ key: 'skeleton_archer_walk_anim', frames: anims.generateFrameNumbers('skeleton_archer_walk', { start: 0, end: 3 }), frameRate: 5, repeat: -1 });
        }
        if (!anims.exists('skeleton_shaman_walk_anim')) {
            anims.create({ key: 'skeleton_shaman_walk_anim', frames: anims.generateFrameNumbers('skeleton_shaman_walk', { start: 0, end: 3 }), frameRate: 4, repeat: -1 });
        }

        // Treant boss walk
        if (!anims.exists('treant_walk')) {
            anims.create({ key: 'treant_walk', frames: anims.generateFrameNumbers('treant_walk', { start: 0, end: 3 }), frameRate: 3, repeat: -1 });
        }

        // Skeleton lord walk + attack
        if (!anims.exists('skeleton_lord_walk')) {
            anims.create({ key: 'skeleton_lord_walk', frames: anims.generateFrameNumbers('skeleton_lord_walk', { start: 0, end: 3 }), frameRate: 4, repeat: -1 });
            anims.create({ key: 'skeleton_lord_attack', frames: anims.generateFrameNumbers('skeleton_lord_attack', { start: 0, end: 2 }), frameRate: 6, repeat: 0 });
        }

        // Cave mobs
        if (!anims.exists('cave_spider_walk_anim')) {
            anims.create({ key: 'cave_spider_walk_anim', frames: anims.generateFrameNumbers('cave_spider_walk', { start: 0, end: 3 }), frameRate: 8, repeat: -1 });
        }
        if (!anims.exists('cave_bat_walk_anim')) {
            anims.create({ key: 'cave_bat_walk_anim', frames: anims.generateFrameNumbers('cave_bat_walk', { start: 0, end: 3 }), frameRate: 7, repeat: -1 });
        }
        if (!anims.exists('stone_golem_walk_anim')) {
            anims.create({ key: 'stone_golem_walk_anim', frames: anims.generateFrameNumbers('stone_golem_walk', { start: 0, end: 3 }), frameRate: 3, repeat: -1 });
        }
        if (!anims.exists('earth_worm_walk_anim')) {
            anims.create({ key: 'earth_worm_walk_anim', frames: anims.generateFrameNumbers('earth_worm_walk', { start: 0, end: 3 }), frameRate: 4, repeat: -1 });
        }
        if (!anims.exists('giant_bat_walk_anim')) {
            anims.create({ key: 'giant_bat_walk_anim', frames: anims.generateFrameNumbers('giant_bat_walk', { start: 0, end: 3 }), frameRate: 5, repeat: -1 });
        }
        if (!anims.exists('small_bat_walk_anim')) {
            anims.create({ key: 'small_bat_walk_anim', frames: anims.generateFrameNumbers('small_bat_walk', { start: 0, end: 3 }), frameRate: 7, repeat: -1 });
        }

        // Village mobs
        if (!anims.exists('village_brute_walk_anim')) {
            anims.create({ key: 'village_brute_walk_anim', frames: anims.generateFrameNumbers('village_brute_walk', { start: 0, end: 3 }), frameRate: 4, repeat: -1 });
        }
        if (!anims.exists('village_stalker_walk_anim')) {
            anims.create({ key: 'village_stalker_walk_anim', frames: anims.generateFrameNumbers('village_stalker_walk', { start: 0, end: 3 }), frameRate: 9, repeat: -1 });
        }
        if (!anims.exists('village_spitter_walk_anim')) {
            anims.create({ key: 'village_spitter_walk_anim', frames: anims.generateFrameNumbers('village_spitter_walk', { start: 0, end: 3 }), frameRate: 6, repeat: -1 });
        }
        if (!anims.exists('village_curser_walk_anim')) {
            anims.create({ key: 'village_curser_walk_anim', frames: anims.generateFrameNumbers('village_curser_walk', { start: 0, end: 3 }), frameRate: 5, repeat: -1 });
        }
        if (!anims.exists('zombie_walk_anim')) {
            anims.create({ key: 'zombie_walk_anim', frames: anims.generateFrameNumbers('zombie_walk', { start: 0, end: 3 }), frameRate: 3, repeat: -1 });
        }
        if (!anims.exists('purple_demon_walk_anim')) {
            anims.create({ key: 'purple_demon_walk_anim', frames: anims.generateFrameNumbers('purple_demon_walk', { start: 0, end: 3 }), frameRate: 4, repeat: -1 });
        }

        // Hell mobs
        if (!anims.exists('hell_guard_walk_anim')) {
            anims.create({ key: 'hell_guard_walk_anim', frames: anims.generateFrameNumbers('hell_guard_walk', { start: 0, end: 3 }), frameRate: 4, repeat: -1 });
        }
        if (!anims.exists('hell_stalker_walk_anim')) {
            anims.create({ key: 'hell_stalker_walk_anim', frames: anims.generateFrameNumbers('hell_stalker_walk', { start: 0, end: 3 }), frameRate: 9, repeat: -1 });
        }
        if (!anims.exists('hell_archer_walk_anim')) {
            anims.create({ key: 'hell_archer_walk_anim', frames: anims.generateFrameNumbers('hell_archer_walk', { start: 0, end: 3 }), frameRate: 6, repeat: -1 });
        }
        if (!anims.exists('hell_mage_walk_anim')) {
            anims.create({ key: 'hell_mage_walk_anim', frames: anims.generateFrameNumbers('hell_mage_walk', { start: 0, end: 3 }), frameRate: 5, repeat: -1 });
        }
        if (!anims.exists('hell_priest_walk_anim')) {
            anims.create({ key: 'hell_priest_walk_anim', frames: anims.generateFrameNumbers('hell_priest_walk', { start: 0, end: 3 }), frameRate: 5, repeat: -1 });
        }
        if (!anims.exists('hell_imp_walk_anim')) {
            anims.create({ key: 'hell_imp_walk_anim', frames: anims.generateFrameNumbers('hell_imp_walk', { start: 0, end: 3 }), frameRate: 8, repeat: -1 });
        }
        if (!anims.exists('red_demon_walk_anim')) {
            anims.create({ key: 'red_demon_walk_anim', frames: anims.generateFrameNumbers('red_demon_walk', { start: 0, end: 3 }), frameRate: 4, repeat: -1 });
        }
    }

    /* ===== PLAYER ===== */

    _createPlayer() {
        const cls = getClassData(this.classKey);
        const walkKey = cls.walkTexKey || 'player_sage_walk';
        const animKey = cls.walkAnim || 'sage_walk_right';
        this.player = this.add.sprite(400, 400, walkKey).setDepth(10);
        this.physics.add.existing(this.player, false);
        this.player.body.setSize(18, 38);
        this.player.body.setOffset(7, 8);
        this.player.body.setCollideWorldBounds(true);
        this.player.play(animKey);
    }

    /* ===== STATS ===== */

    _initStats() {
        this.diffMulti = DIFF_MULT[this.difficulty] || DIFF_MULT.Normal;
        this.classData = getClassData(this.classKey);
        this.classStats = getClassStats(this.classKey, 1);
        this.playerHP = this.classStats.maxHp;
        this.playerMaxHP = this.classStats.maxHp;
        this.playerDamage = this.classStats.damage;
        this.playerSpeed = this.classStats.speed;
        this.playerExp = 0;
        this.playerLevel = 1;
        this.attackCooldown = false;
        this.playerAttacking = false;
        this.facing = 'right';
        this.invincible = false;
        this.menuOpen = false;
        this.kills = 0;
        this.stumpsBroken = 0;
        this.talentEffects = getTalentEffects([]);

        const acc = loadAccount() || {};
        this.accountLevel = acc.accountLevel || 1;
        this.accountExp = acc.accountExp || 0;
        this.accountTalentPoints = acc.accountTalentPoints || 0;
        this.unlockedAccountTalents = acc.unlockedAccountTalents || [];
        this.accountEffects = getAccountTalentEffects(this.unlockedAccountTalents);

        this.recalcStats();
    }

    recalcStats() {
        const cls = this.classData || getClassData(this.classKey);
        const growth = cls.growth;
        let bonusHP = 0, bonusDmg = 0, bonusSpeed = 0;

        this.materials.forEach(m => {
            if (m.stats) {
                bonusHP += m.stats.hp || 0;
                bonusDmg += m.stats.dmg || 0;
                bonusSpeed += m.stats.speed || 0;
            }
        });

        const diffMult = DIFF_MULT[this.difficulty] || DIFF_MULT.Normal;
        [this.equipment.weapon, this.equipment.armor, this.equipment.accessory].forEach(item => {
            if (item && item.stats) {
                bonusHP += (item.stats.hp || 0) * diffMult.hp;
                bonusDmg += (item.stats.dmg || 0) * diffMult.dmg;
                bonusSpeed += (item.stats.speed || 0) * diffMult.hp;
            }
        });

        const lvl = this.playerLevel || 1;
        const te = this.talentEffects || getTalentEffects(this.unlockedTalents || []);
        const ae = this.accountEffects || {};

        let accHpPercent = (ae.hpPercent || 0);
        let accDmgPercent = (ae.damagePercent || 0);
        let accSpdPercent = (ae.speedPercent || 0);
        let accSpellPercent = (ae.spellPercent || 0);
        let accCritPercent = (ae.critPercent || 0);
        let accDodgePercent = (ae.dodgePercent || 0);
        let accCorruptionMax = 0;

        const accScale = (1 + lvl * 0.1);
        const accDiffMult = diffMult.hp;

        Object.values(this.accountEquipment).forEach(item => {
            if (item && item.stats) {
                accHpPercent += (item.stats.hpPercent || 0) * accScale * accDiffMult;
                accDmgPercent += (item.stats.damagePercent || 0) * accScale * accDiffMult;
                accSpdPercent += (item.stats.speedPercent || 0) * accScale * accDiffMult;
                accSpellPercent += (item.stats.spellPercent || 0) * accScale * accDiffMult;
                accCritPercent += (item.stats.critPercent || 0) * accScale * accDiffMult;
                accDodgePercent += (item.stats.dodgePercent || 0) * accScale * accDiffMult;
                accCorruptionMax += (item.stats.corruptionMax || 0) * accScale * accDiffMult;
            }
        });

        const hpMult = 1 + (te.hpPercent || 0) / 100 + accHpPercent / 100;
        const dmgMult = 1 + (te.damagePercent || 0) / 100 + accDmgPercent / 100;
        const moveSpeedBonus = (ae.moveSpeedPercent || 0) + (te.moveSpeedPercent || 0);
        const spdMult = 1 + accSpdPercent / 100 + moveSpeedBonus / 100;

        this.playerMaxHP = Math.floor((cls.stats.hp + (lvl - 1) * growth.hpPerLevel + bonusHP) * hpMult);
        this.playerDamage = Math.floor((cls.stats.damage + (lvl - 1) * growth.dmgPerLevel + bonusDmg) * dmgMult);
        this.playerSpeed = Math.floor((cls.stats.speed + (lvl - 1) * growth.speedPerLevel + bonusSpeed) * spdMult);
        this.corruptionMax = cls.stats.corruptionMax + (te.corruptionMax || 0) + accCorruptionMax;
        if (this.playerHP > this.playerMaxHP) this.playerHP = this.playerMaxHP;

        this.bestiaryBonuses = getAllBestiaryBonuses(this.difficulty);
        this.materialBonuses = getMaterialBonuses(this.difficulty);
        this.soulBonuses = getSoulBonuses(this.difficulty);

        this.playerMaxHP += (this.materialBonuses.hp || 0) + (this.soulBonuses.hp || 0);
        this.playerDamage += (this.materialBonuses.dmg || 0) + (this.soulBonuses.dmg || 0);
        this.playerSpeed += (this.materialBonuses.speed || 0);
        this.corruptionDecay = (this.classData.decay || 0.08) + (this.soulBonuses.corDecay || 0);
        if (this.playerHP > this.playerMaxHP) this.playerHP = this.playerMaxHP;

        this.computedCritChance = (te.critChance || 0) + accCritPercent;
        this.computedCritDamage = 1.5 + (te.critDamagePercent || 0) / 100;
        this.computedDodgePercent = (te.dodgePercent || 0) + accDodgePercent;
        this.computedLifeSteal = (te.lifeSteal || 0) + (ae.lifeSteal || 0);
        this.computedDamageReduction = (te.damageReduction || 0) + (ae.damageReduction || 0);
        this.computedDamageReflection = (te.damageReflection || 0) + (ae.damageReflection || 0);
        this.computedCooldownReduction = (te.cooldownReduction || 0) + (ae.cooldownReduction || 0);
        this.computedAreaDamage = (te.areaDamage || 0) + (ae.areaDamage || 0);
        this.computedBossDamage = (te.bossDamagePercent || 0) + (ae.bossDamagePercent || 0);
        this.computedSpellDamage = (te.spellDamage || 0) + accSpellPercent;

        // Relic effects
        this.relicEffects = {};
        Object.values(this.accountEquipment).forEach(item => {
            if (item && item.effect) {
                this.relicEffects[item.effect] = true;
            }
        });
        this.computedHealPower = (te.healPower || 0) + (ae.healPower || 0);
        this.computedRegenPercent = (te.regenPercent || 0) + (ae.regenPercent || 0);
        this.computedDotPower = te.dotPower || 0;
        this.computedDotDuration = te.dotDuration || 0;
        this.computedShieldPercent = te.shieldPercent || 0;
        this.computedShieldReflect = te.shieldReflect || 0;
        this.computedShieldDuration = te.shieldDuration || 0;
        this.computedArmorReduction = te.armorReduction || 0;
        this.computedSpellSpeed = te.spellSpeed || 0;

        this.computedInventorySlots = (te.inventorySlots || 0) + (ae.inventorySlots || 0);
        this.maxMaterials = MATERIAL_SLOTS + this.computedInventorySlots;
        this.maxEquipBag = EQUIP_BAG_SLOTS + Math.floor(this.computedInventorySlots / 2);

        this.computedAccCritPercent = accCritPercent;
        this.computedAccDodgePercent = accDodgePercent;
        this.computedAccSpellPercent = accSpellPercent;
    }

    /* ===== INVENTORY DATA ===== */

    _initInventory() {
        this.materials = [];
        this.maxMaterials = MATERIAL_SLOTS;
        this.equipBag = [];
        this.maxEquipBag = EQUIP_BAG_SLOTS;
        this.equipment = { weapon: null, armor: null, accessory: null };
        this.accountEquipment = { hat: null, mantle: null, legs: null, weapon: null, accessory: null };
        this.accountEquipBag = [];
        this.maxAccountEquipBag = ACCOUNT_EQUIP_BAG_SLOTS;
    }

    addMaterial(item) {
        if (this.materials.length >= this.maxMaterials) return false;
        this.materials.push(item);
        if (item.id) recordMaterialCollect(item.id);
        if (item.id) onCollect(item.id);
        this.recalcStats();
        return true;
    }

    addEquip(item) {
        if (this.equipBag.length >= this.maxEquipBag) return false;
        this.equipBag.push(item);
        return true;
    }

    equipFromBag(idx) {
        const item = this.equipBag[idx];
        if (!item) return;
        const old = this.equipment[item.slot];
        this.equipment[item.slot] = item;
        this.equipBag.splice(idx, 1);
        if (old) this.equipBag.push(old);
    }

    unequipItem(slot) {
        if (!this.equipment[slot]) return;
        if (this.equipBag.length >= this.maxEquipBag) return;
        this.equipBag.push(this.equipment[slot]);
        this.equipment[slot] = null;
        this.recalcStats();
    }

    getMaterialStatsText() {
        let hp = 0, dmg = 0, spd = 0;
        this.materials.forEach(m => {
            if (m.stats) {
                hp += m.stats.hp || 0;
                dmg += m.stats.dmg || 0;
                spd += m.stats.speed || 0;
            }
        });
        const parts = [];
        if (hp > 0) parts.push('+' + hp + ' HP');
        if (dmg > 0) parts.push('+' + dmg + ' DMG');
        if (spd > 0) parts.push('+' + spd + ' SPD');
        return parts.length > 0 ? parts.join('  ') : 'No bonuses';
    }

    /* ===== ACCOUNT EQUIPMENT ===== */

    addAccountEquip(item) {
        if (!item || item.type !== 'accountEquip') return false;
        const slot = item.slot;
        if (!this.accountEquipment[slot]) {
            this.accountEquipment[slot] = item;
        } else {
            const old = this.accountEquipment[slot];
            this.accountEquipment[slot] = item;
            this._returnToAccountEquipBag(old);
        }
        this.recalcStats();
        return true;
    }

    _returnToAccountEquipBag(item) {
        if (this.accountEquipBag.length < this.maxAccountEquipBag) {
            this.accountEquipBag.push({ ...item });
        }
    }

    unequipAccountItem(slot) {
        if (!this.accountEquipment[slot]) return;
        if (this.accountEquipBag.length >= this.maxAccountEquipBag) return;
        this.accountEquipBag.push({ ...this.accountEquipment[slot] });
        this.accountEquipment[slot] = null;
        this.recalcStats();
    }

    deleteItem(type, idx) {
        let item = null;
        let expGain = 0;
        const rarityMult = { common: 1, uncommon: 2, rare: 3, epic: 4, legendary: 5 };
        const lvl = this.playerLevel || 1;

        if (type === 'material') {
            item = this.materials[idx];
            if (!item) return 0;
            this.materials.splice(idx, 1);
        } else if (type === 'equip') {
            item = this.equipBag[idx];
            if (!item) return 0;
            this.equipBag.splice(idx, 1);
        } else if (type === 'accountEquip') {
            const slot = idx;
            item = this.accountEquipment[slot];
            if (!item) return 0;
            this.accountEquipment[slot] = null;
        } else if (type === 'accountEquipBag') {
            item = this.accountEquipBag[idx];
            if (!item) return 0;
            this.accountEquipBag.splice(idx, 1);
        } else {
            return 0;
        }

        const rm = rarityMult[item.rarity] || 1;
        expGain = Math.floor(10 * rm * (1 + lvl * 0.05));
        if (type === 'accountEquipBag') {
            this.accountExp += expGain;
            this._checkAccountLevelUp();
        } else {
            this.playerExp += expGain;
            this.accountExp += Math.floor(expGain * 0.5);
        }
        this.recalcStats();
        return expGain;
    }

    getAccountEquipStatsText() {
        const ae = this.accountEffects || {};
        const parts = [];
        if (ae.hpPercent) parts.push('+' + ae.hpPercent.toFixed(1) + '% HP');
        if (ae.damagePercent) parts.push('+' + ae.damagePercent.toFixed(1) + '% DMG');
        if (ae.speedPercent) parts.push('+' + ae.speedPercent.toFixed(1) + '% SPD');
        if (ae.spellPercent) parts.push('+' + ae.spellPercent.toFixed(1) + '% Spell');
        if (ae.critPercent) parts.push('+' + ae.critPercent.toFixed(1) + '% Crit');
        if (ae.dodgePercent) parts.push('+' + ae.dodgePercent.toFixed(1) + '% Dodge');
        if (ae.expPercent) parts.push('+' + ae.expPercent.toFixed(1) + '% EXP');
        if (ae.lootPercent) parts.push('+' + ae.lootPercent.toFixed(1) + '% Loot');
        if (ae.regenPercent) parts.push('+' + ae.regenPercent.toFixed(1) + '% Regen');
        if (ae.corruptionMax) parts.push('+' + ae.corruptionMax + ' Corr Max');
        return parts.length > 0 ? parts.join('  ') : 'No bonuses';
    }

    /* ===== SAVE/LOAD ===== */

    _collectSaveData() {
        return {
            version: 4,
            difficulty: this.difficulty,
            classKey: this.classKey,
            playerLevel: this.playerLevel,
            playerExp: this.playerExp,
            playerHP: this.playerHP,
            playerMaxHP: this.playerMaxHP,
            equipment: this.equipment,
            materials: this.materials,
            equipBag: this.equipBag,
            kills: this.kills,
            stumpsBroken: this.stumpsBroken,
            corruption: this.corruption,
            mineUnlocked: this.mineUnlocked,
            mineBossDefeated: this.mineBossDefeated,
            hasSecretKey: this.hasSecretKey,
            caveBossDefeated: this.caveBossDefeated || false,
            zone: this.zone === 'mine_boss' ? 'mine' : this.zone,
            unlockedTalents: this.unlockedTalents || [],
            talentPoints: this.talentPoints || 0
        };
    }

    _collectAccountData() {
        const acc = loadAccount() || {};
        const prevEquip = acc.accountEquipment || {};
        const prevBag = acc.accountEquipBag || {};
        const mergedEquip = { ...prevEquip, [this.classKey]: this.accountEquipment };
        const mergedBag = { ...prevBag, [this.classKey]: this.accountEquipBag };
        return {
            classKey: this.classKey,
            accountLevel: this.accountLevel,
            accountExp: this.accountExp,
            accountTalentPoints: this.accountTalentPoints,
            unlockedAccountTalents: this.unlockedAccountTalents,
            totalKills: (acc).totalKills + this.kills,
            totalStumps: (acc).totalStumps + this.stumpsBroken,
            highestClassLevel: this._getHighestClassLevel(),
            accountEquipment: mergedEquip,
            accountEquipBag: mergedBag
        };
    }

    _getHighestClassLevel() {
        const acc = loadAccount() || {};
        const hi = acc.highestClassLevel || {};
        hi[this.classKey] = Math.max(hi[this.classKey] || 0, this.playerLevel);
        return hi;
    }

    doSave() {
        const data = this._collectSaveData();
        const ok = saveGame(data);
        const accData = this._collectAccountData();
        saveAccount(accData);
        saveBestiary();
        saveMaterialBook();
        saveSoulBook();
        saveQuests();
        if (ok) {
            this.floatingText(this.player.x, this.player.y - 30, 'Game Saved', '#27ae60');
        }
    }

    doLoad() {
        const data = loadGame();
        if (!data) return false;
        this.difficulty = data.difficulty || 'Normal';
        this.diffMulti = DIFF_MULT[this.difficulty] || DIFF_MULT.Normal;
        this.classKey = data.classKey || 'sage';
        this.classData = getClassData(this.classKey);
        this.playerLevel = data.playerLevel || 1;
        this.playerExp = data.playerExp || 0;
        this.playerHP = data.playerHP || 100;
        this.playerMaxHP = data.playerMaxHP || 100;
        this.equipment = data.equipment || { weapon: null, armor: null, accessory: null };
        this.materials = data.materials || [];
        this.equipBag = data.equipBag || [];
        this.kills = data.kills || 0;
        this.stumpsBroken = data.stumpsBroken || 0;
        this.corruption = data.corruption || 0;
        this.mineUnlocked = data.mineUnlocked || false;
        this.mineBossDefeated = data.mineBossDefeated || false;
        this.hasSecretKey = data.hasSecretKey || false;
        this.caveBossDefeated = data.caveBossDefeated || false;
        this._savedZone = data.zone || 'forest';
        this._loadAccountTalents();
        const acc = loadAccount() || {};
        this.accountLevel = acc.accountLevel || 1;
        this.accountExp = acc.accountExp || 0;
        this.accountTalentPoints = acc.accountTalentPoints || 0;
        this.unlockedAccountTalents = acc.unlockedAccountTalents || [];
        this.classStats = getClassStats(this.classKey, this.playerLevel);
        const accEquipPerClass2 = acc.accountEquipment || {};
        const accBagPerClass2 = acc.accountEquipBag || {};
        this.accountEquipment = accEquipPerClass2[this.classKey] || { hat: null, mantle: null, legs: null, weapon: null, accessory: null };
        this.accountEquipBag = accBagPerClass2[this.classKey] || [];
        this.accountEffects = getAccountTalentEffects(this.unlockedAccountTalents);
        this.classStats = getClassStats(this.classKey, this.playerLevel);
        this.talentEffects = getTalentEffects(this.unlockedTalents);
        this.corruptionMax = this.classStats.corruptionMax + (this.talentEffects.corruptionMax || 0);
        this.recalcStats();
        return true;
    }

    _loadAccountTalents() {
        const data = loadGame();
        if (data) {
            this.unlockedTalents = data.unlockedTalents || [];
            this.talentPoints = data.talentPoints || 0;
        } else {
            this.unlockedTalents = [];
            this.talentPoints = 0;
        }
        this.talentEffects = getTalentEffects(this.unlockedTalents);
    }

    _setupZone(zoneName, ...args) {
        if (this.currentZone) {
            this.currentZone.clear();
        }
        const zone = this.zones[zoneName];
        if (zone) {
            this.currentZone = zone;
            zone.setup(...args);
        }
    }

    floatingText(x, y, text, color) {
        if (this.ui) return this.ui.floatingText(x, y, text, color);
    }

    addEquip(item) {
        if (this.playerSys) return this.playerSys.addEquip(item);
        return false;
    }

    addMaterial(item) {
        if (this.playerSys) return this.playerSys.addMaterial(item);
        return false;
