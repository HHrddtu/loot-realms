{
  "$schema": "https://opencode.ai/config.json",
  "username": "pvova",
  "model": "opencode-go/mimo-v2.5",
  "logLevel": "INFO",
  "share": "manual",
  "snapshot": true,

  "skills": {
    "paths": [".opencode/skills"]
  },

  "agent": {
    "build": {
      "model": "opencode-go/mimo-v2.5",
      "description": "General builder for everyday edits in Loot Realms."
    },
    "plan": {
      "model": "opencode-go/mimo-v2.5",
      "description": "Planning specialist for breaking down large features into steps."
    },
    "knowledge": {
      "model": "opencode-go/mimo-v2.5",
      "description": "Knowledge manager — ingests resources, updates knowledge base, maintains indexes."
    }
  },

  "permission": {
    "edit": "ask",
    "bash": {
      "npm *": "allow",
      "npx *": "allow",
      "git *": "ask",
      "vite*": "allow",
      "node *": "allow",
      "*": "ask"
    },
    "task": "allow",
    "external_directory": { "*": "deny" }
  },

  "compaction": {
    "auto": true,
    "tail_turns": 5,
    "reserved": 4000
  },

  "experimental": {
    "batch_tool": true,
    "primary_tools": ["edit", "bash", "task", "todowrite"]
  },

  "tool_output": {
    "max_lines": 300,
    "max_bytes": 65536
  }
}
